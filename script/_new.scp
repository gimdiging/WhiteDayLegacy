_리스트추가()
{	
	if($신관_세환_은미이벤트 == 2)
		return;	

	SendMessage("복도거미", "리스트초기화", "2");	

	for($n = 10; $n < 5 * 5; $n++)
	{		
		$i = $n / 5;
		$j = ($n % 5) + 1;

		SendMessage("복도거미", "리스트추가", "거미" + $i + "_" + $j + " 2");
	}		
}

_본관2로()
{
	if($USER_CAPTUREITEM == TRUE)
	{		
		SendMessage("자막", "문자출력후대기", GetString("s0"));
		return;
	}

	if($수위추적모드 == ON)
	{
		SendMessage("자막", "문자출력후대기", GetString("s2"));
		return;
	}
	
	if($EnterObj == "유저")
	{
	SendMessage("자막", "활성화", "");
	SendMessage("자막", "와이드모드", "켜기");
	SendMessage("자막", "실행함수", "_new._본관2로제대로");
	SendMessage("자막", "선택", GetString("s223"));
	}
}

_본관2로제대로()
{
	SendMessage("자막", "와이드모드", "끄기");
	SendMessage("자막", "비활성", "");

//	if($HP < 1)
//	{
//		$GameOverMode = 0;
//		RunScript("", "오브젝트_유저._유저.dead");
//		return;
//	}

	if($G_UserSelect == 0)
	{
		Destroy();
//		SetTimer(0, "_main2.Create");
		RunScript("유저", "_main2.Create");
	}
}

_강당으로()
{
	SendMessage("자막", "활성화", "");
	SendMessage("자막", "와이드모드", "켜기");
	SendMessage("자막", "실행함수", "_new._강당으로제대로");
	SendMessage("자막", "선택", GetString("s224"));
}

_강당으로제대로()
{
	SendMessage("자막", "와이드모드", "끄기");
	SendMessage("자막", "비활성", "");

	if($G_UserSelect == 0)
	{
		Destroy();
//		SetTimer(0, "_gym.Create");
		RunScript("유저", "_gym.Create");
	}
}

// 옥상 수맥 이벤트

test()
{		
	if($문_K3 == LOCK && $신관_세환_watertrap == OFF)
	{
		SendMessage("유저", "x축강제이동", FindPoint("test시작위치") + " 1200 *script _new.test2");
		RunScript("문_신관옥상","문_신관.force_close");
		$신관_세환_watertrap = ON;
		$현성_더미 = 0;
		SendMessage("사운드","연주","loop,미끌,수의진_물미끄러지기.wav");
		surfing();
	}	
}

test2()
{		
	if($문_K3 == LOCK)
	{
		SendMessage("사운드","연주멈춤","미끌");
		SendMessage("사운드","연주","수의진_물기둥.wav");
		$현성_더미 = 1;
		SendMessage("유저", "파티클생성", "*origin pos %o " +  GetWDBParticle("particle2.wdb", "물02", "파티클내용"));
		SendMessage("유저", "z축강제이동", FindPoint("test시작위치") + " 600 *script _new.test4");		
		SendMessage("유저", "공격", "수맥");
	}
}

test3()
{
	return "보기";
}

test4()
{
	$신관_세환_watertrap = OFF;
	SetTimer(0.5, "_new.test5");
}

test5()
{
	SendMessage("유저", "이동속도", "0.5");
}

excepttest()
{	
	SendMessage("사운드", "연주", "loop,옥상비,수의진_비.wav");

	if($신관_세환_얍삽한놈 == ON && $문_K3 == LOCK)
	{
		SendMessage("유저", "x축강제이동", FindPoint("test시작위치") + " 1200 *script _new.test2");
		RunScript("문_신관옥상","문_신관.force_close");
		$신관_세환_watertrap = ON;
		$현성_더미 = 0;
		SendMessage("사운드","연주","loop,미끌,수의진_물미끄러지기.wav");
		surfing();		
	}
}

exceptcase()	// 유저가 얍삽한 짓을 할 때 죽여버리기 -_-;;
{
	SendMessage("유저", "이동속도", "1");
	SendMessage("사운드", "연주멈춤", "옥상비");
	$신관_세환_얍삽한놈 = ON;
}

surfing()
{
	if( $현성_더미 == 0 )
	{
		SendMessage("유저", "파티클생성", "*origin pos %o " +  GetWDBParticle("particle2.wdb", "물01", "파티클내용"));
		SetTimer(0.1, "_new.surfing");
	}
}
