Create()
{
	RunScript("","_testValue.Init");

	$현재스테이지 = "신관";
	RunScript("", "_whiteday.StartBanner");
	
	LoadWed("data/new.wep", 1);

	SetTimer(0, "_new.Create_init");
}

Create_init()
{
	LoadObject("WObjParticle", "파티", "");
	LoadObject("WObjParticle", "물0", "");
	LoadObject("WObjParticle", "물1", "");
	LoadObject("WObjParticle", "물2", "");
	LoadObject("WObjParticle", "물3", "");
	LoadObject("WObjParticle", "물4", "");
	LoadObject("WObjParticle", "물5", "");
	LoadObject("WTune", "오디오BGM", "");		

	if($신관_세환_무용실이벤트 == 0)
	{
		LoadObject("WObjFaker", "기쉰", "*pet data/puppet/char/캐릭터_희민.pet *pos 2117 5 1441");	
		SendMessage("기쉰", "파트너설정", "유저");
		SendMessage("기쉰", "끄기", "");

		LoadObject("WObjFaker", "기쉰수위", "*pet data/puppet/char/캐릭터_손수위.pet *pos 2117 5 1441");	
		SendMessage("기쉰수위", "파트너설정", "정찰용수위");	
		SendMessage("기쉰수위", "끄기", "");
	}

	if ($게임모드 == 3)
	{
		SendMessage("카메라", "카메라거리", "10 3000");
		SendMessage("카메라", "포그", "500 3000 010101 0.2 1.0 0");
	}	else
		SendMessage("배경", "SKYBOX로딩", "night_");
	SendMessage("사운드", "연주", "loop,신관천둥,신관_비와천둥.wav"); 		

	if($진행루트 == 0 && $신관_세환_어학실이벤트 == FALSE)
	{		
		SendMessage("지현", "좋은위치", "808.2 134.7 1190.6");
		SendMessage("지현", "회전", "-7");
		SendMessage("지현", "애니메이션", "^%sc17_cut01_지현.MTN");
		SendMessage("사운드", "연주3d", GetObjPos("지현", "머리") + " loop,지현울기,sence_15지현울음.adp");
		RunScript("스위치_어학실","o_신관스위치._켜");
	}	

	switch($신관_세환_배전판)
	{
		case 0:
			SendMessage("전등퓨즈", "페이드", "Recursive 0 1 1");
			break;
		case 1:
			SendMessage("전원퓨즈", "페이드", "Recursive 0 1 1");
			break;
		case 2:
			SendMessage("도난퓨즈", "페이드", "Recursive 0 1 1");
			break;		
	}

	if($b_카드키_황 == 0)
	{
		SendMessage("신관_남자교복견본2","공격대상추가","유저");
		SendMessage("신관_남자교복견본3","공격대상추가","유저");
		SendMessage("신관_여자교복견본1","공격대상추가","유저");
		SendMessage("신관_여자교복견본3","공격대상추가","유저");
	}
	else	
	{		
		SendMessage("신관_남자교복견본2","애니메이션","넘어져있기");
		SendMessage("신관_남자교복견본3","애니메이션","넘어져있기");
		SendMessage("신관_여자교복견본1","애니메이션","넘어져있기");
		SendMessage("신관_여자교복견본3","애니메이션","넘어져있기");

		for($i = 1; $i <= 4; $i++)
			DeleteObject("역사관더미" + $i);
	}

	LoadObject("WObjDyLight", "배전판light", "*pos " + FindPoint("배전판조명") + " *diffuse ffffff");
	SendMessage("배전판light", "켜기", "");

/*	if($신관_세환_캔커피이벤트 == 1 && $b_카드키_황 == 0)
	{
		$신관_세환_캔커피남은시간 = $신관_세환_제한시간 - GetRemainTime($신관_세환_캔커피시작시간);

		if($신관_세환_캔커피남은시간 > 0)
		{
			SendMessage("소영", "좋은위치", "1429.6 132.4 972.8");
			SendMessage("소영", "회전", "180");
			SendMessage("소영", "애니메이션", "%Sc43_cut02_소영.MTN");
			SetTimer($신관_세환_캔커피남은시간, "call_macro.NoAction");
		}
		else
		{
			SendMessage("소영", "위치", "" + FindPoint("소영마중나오기"));
			SendMessage("소영", "쳐다보기", "유저");
		}
	}	
	else if($신관_세환_캔커피이벤트 == 2 && $b_카드키_황 == 0)
	{
		SendMessage("소영", "좋은위치", "" + FindPoint("소영캔커피시작위치"));
		SetTimer(5, "_new._소영.첨부터 *obj 소영");
	}	
*/
	if($문_K3 == UNLOCK)
	{
		DeleteObject("피범벅");		// 무릎높이의 물
		DeleteObject("물방울");		// 무릎까지 내리는 비
		DeleteObject("바닥글씨수");	// 수 글자

		SendMessage("빗줄기", "켜기", "");
		SendMessage("땀범벅", "켜기", "");
		SendMessage("땀범벅", "수면높이고정", "on");
	}
	else
	{		
		SendMessage("빗줄기", "끄기", "");	// 바닥까지 내리는 비		
		SendMessage("땀범벅", "끄기", "");	// 바닥에 깔린 물		
	}

	if($신관_세환_은미이벤트 == 2)
	{
		DeleteObject("성아");
		DeleteObject("지현");
		DeleteObject("소영");		
		DeleteObject("크아악테잎");

//		DeleteObject("매크로용이수위");
//		DeleteObject("매크로용손수위");

		SendMessage("매크로용이수위", "위치", "2166.944 130.098 1268.535");
		SendMessage("매크로용이수위", "회전", "-90 0");
		SendMessage("매크로용이수위", "애니메이션", "%sc23_cut03_이수위.MTN");
		SendMessage("매크로용이수위", "충돌체크", "off");

		SendMessage("매크로용손수위", "위치", "2252.311 130.039 1249.018");
		SendMessage("매크로용손수위", "회전", "-110 0");
		SendMessage("매크로용손수위", "애니메이션", "%sc23_cut03_손수위.MTN");
		SendMessage("매크로용손수위", "충돌체크", "off");
	}		

	if($신관_세환_은미이벤트 == 0)
	{
		if($AI_신관_Active == 2)
			SetTimer(0, "캐릭터_수위._리셋 *obj 정찰용수위");		
	}

	SendMessage("유저", "픽금지", "off");

	if($b_노리군더미 == 1)
		DeleteObject("노리군더미");

	$신관_세환_불켜질교실수 = 0;
	$신관_세환_불안켜질교실수 = 0;

	if($게임모드 == 4 && $신관_세환_열쇠이벤트 == FALSE)
	{		
		$신관_세환_불켜질교실수 = 5;
		$신관_세환_불안켜질교실수 = 0;

		for($i = 1; $i < 13; $i++)
		{
			if(TakeObjValue("스위치_3학년" + $i + "반", "event") == 1)
				RunScript("스위치_3학년" + $i + "반", "o_신관스위치._불켜기");
		}
	}

	if ($게임모드 != 0 && $게임모드 != 4)
	{
		SetTimer(0,"e_2d귀신._본관귀신");
		RunScript("", "e_2d귀신._1분후에머리귀신살아라");
	}
}

Destroy()
{
	DeleteObject("파티");
	DeleteObject("물0");
	DeleteObject("물1");
	DeleteObject("물2");
	DeleteObject("물3");
	DeleteObject("물4");
	DeleteObject("물5");
	DeleteObject("렌턴_매크로용이수위");
	DeleteObject("렌턴_매크로용손수위");
	DeleteObject("렌턴_정찰용수위");
	DeleteObject("배전판light");
	DeleteObject("오디오BGM");

	RunScript("", "_whiteday.ResetMainGameObject");
	if($신관_세환_무용실이벤트 == 0)
	{
		DeleteObject("기쉰");
		DeleteObject("기쉰수위");
	}

	$AI_신관_Active = $AI_수위_Active;

	if($게임모드 != 0 && $게임모드 != 4)
		RunScript("", "e_2d귀신._본관귀신날려");
}

Create4Debug()
{
	LoadObject("WObjPlayer", "유저", "*ai 오브젝트_유저._유저 *gravity");

	SendMessage("유저", "회전", "270");
	SendMessage("유저", "캡춰", "카메라 머리");
	SendMessage("허드", "켜기", "normal");

	SendMessage("타이머", "켜기", "");
	SendMessage("타이머", "스크립트설정", "0 0 1 _new._게임시작");
	SendMessage("main", "게임시작", "시작");
}

ScriptMain()
{
	Create();
	Create4Debug();
}

