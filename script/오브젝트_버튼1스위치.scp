_켜다()
{
	if($현재스테이지 == "본관1" && GetObjValue("상태") == ON)
	{
		if(GetObjValue("LightName1") == "A2-11")
		{
			for($i = 1; $i <= 4; $i++)
				SendMessage("빛_2학년7반" + $i, "켜기", "");
		}

		if(GetObjValue("LightName1") == "A2-22")
			SendMessage("빛_녹음실", "켜기", "");
	}

	if($현재스테이지 == "본관2" && GetObjValue("상태") == ON)
	{
		if(GetObjValue("LightName1") == "A1-17")
		{
			for($i = 1; $i <= 2; $i++)
				SendMessage("빛_숙직실" + $i, "켜기", "");
		}

		if(GetObjValue("LightName1") == "A1-18")
		{
			for($i = 1; $i <= 2; $i++)
				SendMessage("빛_양호실" + $i, "켜기", "");
		}
	}
}

