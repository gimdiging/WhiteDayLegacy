Init()
{
	SendMessage("", "스크립트설정", "switch " + $G_File);
	SendMessage("", "TurnGlow", "on 0");
	SetObjValue("MotionName", "");
	SetObjValue("상태", OFF);
	SetObjValue("전구갯수", 1);
	SetObjValue("바퀴벌레출현", 0);
	SetObjValue("전등종류", "형광등");
	SetObjValue("깜박임",0);
	SetObjValue("trick", 0);
	SetObjValue("exList", 0);
	SetObjValue("고장", 0);
}

_불켜기()
{
	if(GetObjValue("상태") == ON)
		return;

	if(GetObjValue("exList") == 0)
		SendMessage("", "리스트추가", "" + GetObjName());

	SendMessage("", "TurnGlow", "off 0");
	SendMessage("", "애니메이션", "켜기");
	SetObjValue("상태", ON);
	SendMessage("배경", "켜기", GetObjValue("LightName1"));
}

_불끄기()
{
	if(GetObjValue("상태") == OFF)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
	{
		SendMessage("", "리스트삭제", "" + GetObjName());
		if(GetObjName() == $detect_object)
			$detect_object = "";
	}

	SendMessage("", "TurnGlow", "on 0");
	SendMessage("", "애니메이션", "끄기");
	SetObjValue("상태", OFF);
	SendMessage("배경", "끄기", GetObjValue("LightName1"));
	SetObjValue("trick", GetObjValue("trick") + 1);
	if(GetObjValue("trick") >= 3)
		$trick_num++;	
}

_켜()
{
	if(GetObjValue("상태") == ON)
		return;

	if(GetObjValue("exList") == 0)
		SendMessage("", "리스트추가", "" + GetObjName());

	SendMessage("", "TurnGlow", "off 0");
	SendMessage("", "애니메이션", "켜기");
	SetObjValue("상태", ON);
	SendMessage("배경", "켜기", GetObjValue("LightName1"));		
}

_꺼()
{
	if(GetObjValue("상태") == OFF)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
	{
		SendMessage("", "리스트삭제", "" + GetObjName());
		if(GetObjName() == $detect_object)
			$detect_object = "";
	}

	SendMessage("", "TurnGlow", "on 0");
	SendMessage("", "애니메이션", "끄기");
	SetObjValue("상태", OFF);
	SendMessage("배경", "끄기", GetObjValue("LightName1"));
}

