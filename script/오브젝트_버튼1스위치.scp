pick()
{
	return "잡기";
}

click()
{
	$상태 = GetObjValue("상태");

	if(GetObjName() == "스위치_3층화장실남" )
	{
		$켤까 = $본2스위치_3층화장실남%2;
		if($켤까 == 0)
		{
			$초 = (1 + Random()%5) / 2;
			SetTimer($초,"오브젝트_버튼1스위치.click *obj 스위치_3층화장실남");
		}
		$본2스위치_3층화장실남++;
	}

	if($정전 == 1)
	{
		SendMessage("자막", "문자출력후대기", GetString("s79"));
		return;
	}

		if(GetObjName() == "스위치_과학부속실")
		{
		if($본관불껐냐 == FALSE && $화재진압중 == 1)
			{
			SendMessage("자막", "문자출력후대기", GetString("s79"));
			return;
			}
		}
		
	if($상태 == OFF)
	{
		if(GetObjValue("MotionName") == "켜기")
			return;

		if(GetObjValue("exList") == 0)
			SendMessage("", "리스트추가", "" + GetObjName());

		if(GetObjValue("LightName1") == "A1-11")		// 서무실 전원
		{
			SendMessage("서무실전원", "발광색", "red_lamp 200 0 0");
			SendMessage("서무실전원", "발광색", "gr_lamp01 0 150 0");			
		}	

		if(GetObjValue("LightName1") == "A2-11" || GetObjValue("LightName1") == "A2-22" || GetObjValue("LightName1") == "A1-17" || GetObjValue("LightName1") == "A1-18")
		{
			SetTimer(0.06, "_켜다");
			SetTimer(0.11, "_끄다");
			SetTimer(0.17, "_켜다");
			SetTimer(0.22, "_끄다");
			SetTimer(0.41, "_켜다");
			SetTimer(0.65, "_끄다");
			SetTimer(0.80, "_켜다");
			SetTimer(1.15, "_끄다");
			SetTimer(1.50, "_켜다");
		}

		if(GetObjValue("바퀴벌레출현") == 1)		
			SetTimer(0, "_바퀴벌레출현");		

		SendMessage("", "애니메이션", "켜기");		
		SendMessage("", "TurnGlow", "off 0");
		SetObjValue("상태", ON);		
		
		if(GetObjValue("고장") == 1)
		{
			SendMessage("자막", "문자출력후대기", GetString("s79"));
			return;
		}

		SetTimer(0.1, GetObjValue("전등종류") == "형광등" ? "_형광등켜기" : "_전기공급ON");		
	}
	else if($상태 == ON)
	{
		if(GetObjValue("MotionName") == "끄기")
			return;

		if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
		{
			SendMessage("", "리스트삭제", "" + GetObjName());
			if(GetObjName() == $detect_object)
				$detect_object = "";
		}

		if(GetObjValue("LightName1") == "A1-11")		// 서무실 전원
		{
			SendMessage("서무실전원", "발광색", "red_lamp 100 0 0");
			SendMessage("서무실전원", "발광색", "gr_lamp01 0 100 0");			
		}	

		if(GetObjValue("LightName1") == "A2-11" || GetObjValue("LightName1") == "A2-22" || GetObjValue("LightName1") == "A1-17" || GetObjValue("LightName1") == "A1-18")
			RunScript("", "오브젝트_버튼1스위치._끄다");

		SendMessage("", "애니메이션", "끄기");		
		SendMessage("", "TurnGlow", "on 0");		
		SetObjValue("상태", OFF);		
		
		if(GetObjValue("고장") == 1)
		{
			SendMessage("자막", "문자출력후대기", GetString("s79"));
			return;
		}		

		if(GetObjValue("전등종류") == "형광등")
			SendMessage("사운드", "연주멈춤", "형광등켜지는소리");

		SetTimer(0.01, GetObjValue("전등종류") == "형광등" ? "_전기공급OFF" + $세환_형광등중복 : "_전기공급OFF");				
	}
}

_전기공급ON()
{
	for($i = 1, $ii = GetObjValue("전구갯수"); $i <= $ii; $i++)
		SendMessage("배경", "켜기", GetObjValue("LightName" + $i));
}

_전기공급OFF()
{
	for($i = 1, $ii = GetObjValue("전구갯수"); $i <= $ii; $i++)
		SendMessage("배경", "끄기", GetObjValue("LightName" + $i));
}

_형광등켜기()
{
	$세환_형광등중복 = ($세환_형광등중복++) % 3; 

	$ON = "_전기공급ON" + $세환_형광등중복;
	$OFF = "_전기공급OFF" + $세환_형광등중복;

	SetTimer(0.06, $ON);
	SetTimer(0.11, $OFF);
	SetTimer(0.17, $ON);
	SetTimer(0.22, $OFF);
	SetTimer(0.41, $ON);
	SetTimer(0.65, $OFF);
	SetTimer(0.80, $ON);
	SetTimer(1.15, $OFF);
	SetTimer(1.50, $ON);
	
	if(GetObjValue("LightName1"))
		SendMessage("사운드", "연주", "형광등켜지는소리,data/sound/형광등켜지기.wav");
}

_바퀴벌레출현()
{	
	RunScript(GetObjValue("바퀴벌레1"), "e_바퀴_스위치용._벌레출현");
	RunScript(GetObjValue("바퀴벌레2"), "e_바퀴_바닥용._벌레출현");
	SetObjValue("바퀴벌레출현", 0);	
}

_전기공급ON0()
{
	if($세환_형광등중복 == 0 && GetObjValue("상태") == ON)
	{
		for($i = 1, $ii = GetObjValue("전구갯수"); $i <= $ii; $i++)
			SendMessage("배경", "켜기", GetObjValue("LightName" + $i));
	}
}

_전기공급OFF0()
{
	if($세환_형광등중복 == 0)
	{
		for($i = 1, $ii = GetObjValue("전구갯수"); $i <= $ii; $i++)
			SendMessage("배경", "끄기", GetObjValue("LightName" + $i));
	}
}

