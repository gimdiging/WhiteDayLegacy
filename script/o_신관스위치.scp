pick()
{
	return "잡기";
}

click()
{
	$TurnOnFlag = GetObjValue("TurnOnFlag");
	$LightCount = GetObjValue("LightCount");
	$Event		= GetObjValue("event");
	$LightPower = GetObjValue("LightPower");

	SendMessage("", "시끄러워", "0");

		if($신관_세환_교실전력 == OFF && $Event != 2 && $게임모드 != 4)
		{
			SendMessage("자막","문자출력","3," + GetString("s45"));
			return;
		}
		if(GetObjName() == "스위치_음악실" && $음악감상실귀신진행 == 1)
		{	
			SendMessage("자막","문자출력","3," + GetString("s77"));
			return;
		}	
			
		if($정전 == 1 && $Event == 2)
		{
			SendMessage("자막","문자출력","3," + GetString("s78"));
			return;
		}
		
	if($TurnOnFlag == OFF)
	{				
		if(GetObjName() == "스위치_역사관1" || GetObjName() == "스위치_역사관2")
		{
			RunScript("스위치_역사관1", $G_File + ".flagon" );
			RunScript("스위치_역사관2", $G_File + ".flagon" );
			return;
		}

		if(GetObjName() == "스위치_무용실1" || GetObjName() == "스위치_무용실2")
		{
			if($신관_세환_무용실이벤트 == 1)
			{
				SendMessage("자막", "문자출력후대기", GetString("s77"));
				return;
			}

			RunScript("스위치_무용실1", $G_File + ".flagon" );
			RunScript("스위치_무용실2", $G_File + ".flagon" );
			return;
		}

		if($LightPower == 2)
		{
			if(GetObjName() == "스위치_열람실1" || GetObjName() == "스위치_열람실2" || GetObjName() == "스위치_열람실3")
			{
				RunScript("스위치_열람실1", $G_File + ".flagon");
				RunScript("스위치_열람실2", $G_File + ".flagon");
				RunScript("스위치_열람실3", $G_File + ".flagon");
				return;
			}
			RunScript("", $G_File + ".flagon");
			return;
		}

		if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
			SendMessage("정찰용수위", "리스트추가", "" + GetObjName());

		SendMessage("", "애니메이션", "켜기");
		SendMessage("", "TurnGlow", "off 0");		
		SetObjValue("TurnOnFlag", ON);

		if(GetObjValue("고장") == 1)
		{			
			SendMessage("자막","문자출력","3," + GetString("s78"));			
			return;
		}

		if($Event == 1)
			$신관_세환_불켜질교실수++;
		else if($Event == 0) 
			$신관_세환_불안켜질교실수++;				
		
		for($i = 1; $i <= $LightCount; $i++)				
			SendMessage("배경", "켜기", GetObjValue("LightName" + $i));			

		if($신관_세환_불켜질교실수 == 5 && $신관_세환_불안켜질교실수 == 0 && $신관_세환_열쇠이벤트 == FALSE && $신관_세환_홀조명 == ON)
			SendMessage("매크로", "Play", "light_explode.cut01");		
	}
	else if($TurnOnFlag == ON)
	{				
		if(GetObjName() == "스위치_역사관1" || GetObjName() == "스위치_역사관2")
		{
			RunScript("스위치_역사관1", $G_File + ".flagoff" );
			RunScript("스위치_역사관2", $G_File + ".flagoff" );
			return;
		}

		if(GetObjName() == "스위치_무용실1" || GetObjName() == "스위치_무용실2")
		{
			if($신관_세환_무용실이벤트 == 1)
			{
				SendMessage("자막", "문자출력후대기", GetString("s77"));
				return;
			}

			RunScript("스위치_무용실1", $G_File + ".flagoff" );
			RunScript("스위치_무용실2", $G_File + ".flagoff" );
			return;
		}

		if($LightPower == 2)
		{
			if(GetObjName() == "스위치_열람실1" || GetObjName() == "스위치_열람실2" || GetObjName() == "스위치_열람실3")
			{
				RunScript("스위치_열람실1", $G_File + ".flagoff");
				RunScript("스위치_열람실2", $G_File + ".flagoff");
				RunScript("스위치_열람실3", $G_File + ".flagoff");
				return;
			}
			RunScript("", $G_File + ".flagoff");
			return;
		}

		if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
		{
			SendMessage("정찰용수위", "리스트삭제", "" + GetObjName());
			if(GetObjName() == $detect_object)
				$detect_object = "";
		}

		SendMessage("", "애니메이션", "끄기");
		SendMessage("", "TurnGlow", "on 0");		
		SetObjValue("TurnOnFlag", OFF);

		if(GetObjValue("고장") == 1)
		{			
			SendMessage("자막","문자출력","3," + GetString("s78"));			
			return;
		}
		
		if($Event == 1)
			$신관_세환_불켜질교실수--;
		else if($Event == 0)
			$신관_세환_불안켜질교실수--;
		
		for($i = 1; $i <= $LightCount; $i++)				
			SendMessage("배경", "끄기", GetObjValue("LightName" + $i));

		if($신관_세환_불켜질교실수 == 5 && $신관_세환_불안켜질교실수 == 0 && $신관_세환_열쇠이벤트 == FALSE && $신관_세환_홀조명 == ON)
			SendMessage("매크로", "Play", "light_explode.cut01");		
	}
}

_불켜기()
{	
	if(GetObjValue("TurnOnFlag") == ON)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
		SendMessage("", "리스트추가", "" + GetObjName());

	SendMessage("", "TurnGlow", "off 0");
	SetObjValue("TurnOnFlag", ON);	
	SendMessage("배경", "켜기", GetObjValue("LightName1"));
}

_불끄기()
{
	if(GetObjValue("TurnOnFlag") == OFF)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
	{
		SendMessage("", "리스트삭제", "" + GetObjName());
		if(GetObjName() == $detect_object)
			$detect_object = "";
	}

	SendMessage("", "TurnGlow", "on 0");
	SetObjValue("TurnOnFlag", OFF);	
	SendMessage("배경", "끄기", GetObjValue("LightName1"));
}

_켜()
{
	if(GetObjValue("TurnOnFlag") == ON)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
		SendMessage("정찰용수위", "리스트추가", "" + GetObjName());

	SendMessage("", "TurnGlow", "off 0");
	SetObjValue("TurnOnFlag", ON);
	SendMessage("", "애니메이션", "켜기");
	SendMessage("배경", "켜기", GetObjValue("LightName1"));
}

_꺼()
{
	if(GetObjValue("TurnOnFlag") == OFF)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
	{
		SendMessage("정찰용수위", "리스트삭제", "" + GetObjName());
		if(GetObjName() == $detect_object)
			$detect_object = "";
	}

	SendMessage("", "TurnGlow", "on 0");
	SetObjValue("TurnOnFlag", OFF);
	SendMessage("", "애니메이션", "끄기");
	SendMessage("배경", "끄기", GetObjValue("LightName1"));
}

