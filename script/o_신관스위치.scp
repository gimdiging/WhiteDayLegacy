Init()
{
	SendMessage("", "스크립트설정", "switch " + $G_File);
	SetObjValue("MotionName", "");
	SetObjValue("TurnOnFlag", OFF);
	SetObjValue("LightCount", 1);
	SetObjValue("LightName1", "");
	SetObjValue("event",2);
	SetObjValue("LightPower",1);		// LightPower 0: 교실 1: 기타 2: 4층 배전판 
	SetObjValue("exList", 0);
	SetObjValue("고장", 0);

	if($b_교실스위치랜덤 == 0)
	{
		$b_교실스위치랜덤 = 1;
		$전등폭파_randomset = Random(4) + 1;
	}
}

