flagon()
{
	$aa = ON;

	if(GetObjValue("LightPower") == 2 && $신관_세환_배전판 != 0)
		$aa = OFF;
		
	SendMessage("", "애니메이션", "켜기");
	SendMessage("", "TurnGlow", "off 0");	

	if($aa == ON)
	{
		SendMessage("배경", "켜기", GetObjValue("LightName1"));
		if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
			SendMessage("정찰용수위", "리스트추가", "" + GetObjName());
	}

	SetObjValue("TurnOnFlag", ON);
}

flagoff()
{
	$bb = ON;

	if(GetObjValue("LightPower") == 2 && $신관_세환_배전판 != 0)
		$bb = OFF;

	SendMessage("", "애니메이션", "끄기");
	SendMessage("", "TurnGlow", "on 0");	

	if($bb == ON)	
	{
		SendMessage("배경", "끄기", GetObjValue("LightName1"));
		if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
		{
			SendMessage("정찰용수위", "리스트삭제", "" + GetObjName());
			if(GetObjName() == $detect_object)
				$detect_object = "";
		}
	}

	SetObjValue("TurnOnFlag", OFF);
}

_4층켜기()
{
	for($i = 1; $i <= 3; $i++)
		RunScript("스위치_열람실" + $i, $G_File + "._불켜라");
	
	for($i = 1; $i <= 2; $i++)
		RunScript("스위치_서고" + $i, $G_File + "._불켜라");

//	RunScript("자료검색실", $G_File + "._불켜기");
}

_4층끄기()
{
	for($i = 1; $i <= 3; $i++)
		RunScript("스위치_열람실" + $i, $G_File + "._불꺼라");
	
	for($i = 1; $i <= 2; $i++)
		RunScript("스위치_서고" + $i, $G_File + "._불꺼라");

//	RunScript("자료검색실", $G_File + "._불끄기");
}

_불켜라()
{
	if(GetObjValue("TurnOnFlag") == OFF)
		return;

	SendMessage("배경", "켜기", GetObjValue("LightName1"));
}

_불꺼라()
{
	if(GetObjValue("TurnOnFlag") == OFF)
		return;

	SendMessage("배경", "끄기", GetObjValue("LightName1"));
}

_수위불끄기()
{
	if(GetObjName() == "스위치_역사관1" || GetObjName() == "스위치_역사관2")
	{
		RunScript("스위치_역사관1", $G_File + ".flagoff" );
		RunScript("스위치_역사관2", $G_File + ".flagoff" );
		return;
	}

	if(GetObjName() == "스위치_무용실1" || GetObjName() == "스위치_무용실2")
	{
		RunScript("스위치_무용실1", $G_File + ".flagoff" );
		RunScript("스위치_무용실2", $G_File + ".flagoff" );
		return;
	}

	if(TakeObjValue("", "LightPower") == 2)
	{
		if(GetObjName() == "스위치_열람실1" || GetObjName() == "스위치_열람실2" || GetObjName() == "스위치_열람실3")
		{
			RunScript("스위치_열람실1", $G_File + ".flagoff");
			RunScript("스위치_열람실2", $G_File + ".flagoff");
			RunScript("스위치_열람실3", $G_File + ".flagoff");
			return;
		}
		RunScript("", $G_File + ".flagoff");
		return;
	}
	
	SendMessage("정찰용수위", "리스트삭제", "" + GetObjName());

	SendMessage("", "애니메이션", "끄기");
	SendMessage("", "TurnGlow", "on 0");				
	
	for($i = 1; $i <= $LightCount; $i++)				
		SendMessage("배경", "끄기", GetObjValue("LightName" + $i));

	SetObjValue("TurnOnFlag", OFF);
}

/////////////////// 전등 폭파 이벤트 ///////////////////////

flicker()
{
	$ON = "_전기공급ON";
	$OFF = "_전기공급OFF";
	$_ON = "o_신관조명.on";
	$_OFF = "o_신관조명.off";

	SetTimer(0.06, $OFF);
	SetTimer(0.06, $_OFF);
	
	SetTimer(0.11, $ON);
	SetTimer(0.11, $_ON);
	
	SetTimer(0.17, $OFF);
	SetTimer(0.17, $_OFF);

	SetTimer(0.22, $ON);
	SetTimer(0.22, $_ON);

	SetTimer(0.41, $OFF);
	SetTimer(0.41, $_OFF);

	SetTimer(0.65, $ON);
	SetTimer(0.65, $_ON);

	SetTimer(0.80, $OFF);
	SetTimer(0.80, $_OFF);

	SetTimer(1.15, $ON);
	SetTimer(1.15, $_ON);

	SetTimer(1.50, $OFF);
	SetTimer(1.50, $_OFF);

	SetTimer(1.80, $ON);
	SetTimer(1.80, $_ON);

//	SetTimer(2.50, $OFF);
	SetTimer(2.50, $_OFF);	
}

_전기공급ON()
{	
	SendMessage("배경", "켜기", "hall");	
}

_전기공급OFF()
{
	SendMessage("배경", "끄기", "hall");	
}

particle()
{
	RunScript("신관홀조명","o_신관조명.fade");
//	RunScript("신관홀조명","o_신관조명.off");	

	SendMessage("사운드", "연주", "신관_진열장깨짐.wav");
	LoadObject("WObjFragments", "", "*area 1900 150 880 2050 190 1000 *fragnum 256 *defvec -150 0 -150 *defamin 0 0 0 *defamax 300 0 300 *gennum 100 *gencount 1 *genfreq 4 *lifetime 3 *fadetime 1 *timedelta 1 *genscale 0.5 *genscaledelta 1 *rotangle -20 -5 0 *rotangledelta 0 10 -10 *gravec 0 -980 0 *fr 0.2 *elastic 0.3 *bcol 0 *pet0 data/puppet/obj/o_유리파편.pet");	
	$b_중앙홀조명 = 1;
	SendMessage("열쇠10", "중력", "on");
	SendMessage("열쇠10", "애니메이션", "떨어지기");
}
