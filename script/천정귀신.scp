//////////////////////	음악실 천정귀신 /////////////////////////////////


_음악실거미.StartUp()
{		
	if($b_음악실거미 == 1)
		DeleteObject("");	

//	SendMessage("", "NOCLIP", "on");
	SendMessage("", "TurnGlow", "off 0");
	SendMessage("", "TurnGlow", "off 1");	
}

_음악실거미.damage()
{
	if($b_음악실거미 == 1)
		return;	

	switch(GetObjValue("enemy"))
	{
		case "태극패":
			$AI_천정귀신 = OFF;
			SendMessage("", "거미공격체크", "");
			SetTimer(0, "e_핸드폰메시지._신관어학실");			
			SendMessage("", "페이드", "Recursive 5 1 0");			
			SendMessage("사운드", "연주3d", GetObjPos("", "머리") + " 거미_도망.wav");

//			SetTimer(3, "_태극패깨짐");			
			SetTimer(5, "Release");
			$b_음악실거미 = 1;

//			태극패 부서지는 연출추가

			break;		
	}	
}

_태극패깨짐()
{
	if($b_깨진태극패 == 0)
	{
	SendMessage("자막", "문자출력", "3," +  GetString("s180"));
	SendMessage("유저", "폐기", "@태극패");
	SendMessage("유저", "획득", "@깨진태극패");
	SendMessage("사운드", "연주", "태극패_깨짐.wav");
	SendMessage("유저", "아이템장비", "취소");
	SendMessage("유저", "아이템장비취소", "");
	$b_깨진태극패 = 1;
	}
}

_음악실거미.아파이눔아()
{
	SendMessage("사운드", "연주3d", GetObjPos("", "머리") + " 앗뜨거,거미_데미지.wav");
//	현성씨 파티클
	SendMessage("","파티클생성", "*origin pos %p " + GetWDBParticle("particle2.wdb", "거미소녀죽을때", "파티클내용");
}

_음악실거미.이젠괜찮아()
{
//	SendMessage("사운드", "연주멈춤", "앗뜨거");	
}

Release()
{
	DeleteObject("음악실천정귀신");
}

hide()
{	
	SendMessage("사운드", "연주멈춤", "거미발소리");
	DeleteObject("음악실천정귀신");
}

attack()
{	
	if($b_음악실진입 == 0)
	{
		$b_음악실진입 = 1;
		SetTimer(0, "e_핸드폰메시지._신관거미소녀");
	}

	if($b_음악실거미 == 1)
	{
		DeleteObject("");
		return;
	}	
	
	if($AI_천정귀신 == OFF)
	{
		$AI_천정귀신 = ON;
		SendMessage("음악실천정귀신", "거미공격체크", "유저 " + FindPoint("음악실벽"));	
	}
}

stop()
{
	if($b_음악실거미 == 1)
	{
		DeleteObject("");
		return;
	}
	
	if($AI_천정귀신 == ON)
	{
		$AI_천정귀신 = OFF;
		SendMessage("음악실천정귀신", "Stop", "");
		SendMessage("음악실천정귀신", "애니메이션", "서있기");
		SendMessage("음악실천정귀신", "거미공격체크", "");
	}
}

check_user()
{		
	if($b_음악실거미 == 1)
		return;	
	
	SendMessage("", "애니메이션", "서있기");
	SendMessage("음악실천정귀신", "거미공격체크", "유저 " + FindPoint("음악실벽"));
}

_음악실거미.Attack()
{	
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("", "거미공격체크", "");	
	SetTimer(0,"spider_attack");	
}

_음악실거미.Attack_ready()
{	
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("", "거미공격체크", "");
	SendMessage("사운드", "연주", "loop,거미발소리,거미_이동02.wav");
	SendMessage("", "애니메이션", "전진");
	SendMessage("", "거미공격", "유저 600");
}

_음악실거미.SideMove()
{	
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("", "회전", "-90 0.5");
	SendMessage("", "애니메이션", "전진");
	SendMessage("", "z축강제이동", GetWallPos(GetObjPos(""), GetObjPos("유저")) + " 600");							
	SendMessage("사운드", "연주", "거미_이동01.wav");	
}

_음악실거미.Stare()
{
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("", "동작하며돌기", GetObjPos("유저") + " 20 숨쉬기");		
}

_음악실거미.Return()
{
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("", "회전", "-90 0.5");
	SendMessage("", "강제이동", FindPoint("음악실벽") + " 600 *script 천정귀신.check_user");
	SendMessage("사운드", "연주멈춤", "거미발소리");
	SendMessage("사운드", "연주", "거미발소리,거미_이동02.wav");
}

_음악실거미.Rotate()
{
	if($AI_천정귀신 == OFF)
		return;

	if(x_distance(FindPoint("음악실벽"), GetObjPos("유저")) < 50)
		SendMessage("", "회전", "90 0.5");
	else
		SendMessage("", "회전", "-90 0.5");
}

spider_attack()
{
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("", "Stop", "");
	SendMessage("", "애니메이션", "서있기");
//	SendMessage("", "TurnGlow", "off 0");
//	SendMessage("", "TurnGlow", "off 1");	
	SendMessage("사운드", "연주멈춤", "거미발소리");
	SendMessage("자막", "활성화", "");	
	SendMessage("유저", "강제이동", GetObjPos("음악실천정귀신","머리") + " 500 *script 천정귀신.look");		
}

look()
{
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("유저", "쳐다보기", "음악실천정귀신 180");			
	SetTimer(1,"ascent");
}

ascent()
{
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("유저", "중력", "off");	
	SendMessage("사운드", "연주", "거미_올리기.wav");
	SendMessage("유저", "끌려올라가기", "음악실천정귀신 200");
	SetTimer(1, "damage");
}

damage()
{
	if($AI_천정귀신 == OFF)
		return;

//	SendMessage("음악실천정귀신", "TurnGlow", "on 0");
//	SendMessage("음악실천정귀신", "TurnGlow", "on 1");
	SendMessage("유저", "쳐다보지말기", "");				
	SendMessage("유저", "x축강제이동", FindPoint("음악실뒤벽") + " 1200 *script 천정귀신.play");		
}

play()
{	
	if($AI_천정귀신 == OFF)
		return;

	SendMessage("음악실천정귀신", "빨리돌기포인트", "" + GetObjPos("유저"));
	SendMessage("음악실천정귀신", "애니메이션", "전진");
	SendMessage("음악실천정귀신", "강제이동", FindPoint("음악실벽") + " 600 *script 천정귀신.check_user");
	SendMessage("사운드", "연주", "거미_벽부딪힘.wav");
	SendMessage("유저", "공격", "천정귀신");
	SendMessage("유저", "중력", "on");	
	SendMessage("자막", "비활성", "");	
}


///////////////////////// 교실 거미 ////////////////////////////////////////////

_교실거미.StartUp()
{
	if($b_교실거미 == 1)
		DeleteObject("");	

	SendMessage("", "위치", "0 0 0");
	SendMessage("", "TurnGlow", "off 0");	
	SendMessage("", "TurnGlow", "off 1");
	SetObjValue("status", "stop");		// stop, attack, chase, return, wait, stay, attack_ready
	SetObjValue("damage", "true");
}

_교실거미.아파이눔아()
{
	if(GetObjValue("damage") == "false")
		return;

	SendMessage("사운드", "연주3d", GetObjPos("", "머리") + " 앗뜨거,거미_데미지.wav");
// 현성씨 파티클
	SendMessage("","파티클생성", "*origin pos %p " + GetWDBParticle("particle2.wdb", "거미소녀죽을때", "파티클내용");
}

_교실거미.이젠괜찮아()
{
//	SendMessage("사운드", "연주멈춤", "앗뜨거");	
}

_교실거미.damage()
{	
	if(GetObjValue("damage") == "false")
		return;

	$AI_교실거미 = OFF;
	$b_교실거미 = 1;	
	SetTimer(3, "_태극패깨짐");	
	
	SendMessage("", "Stop", "");
//	SendMessage("", "TurnGlow", "off 0");
//	SendMessage("", "TurnGlow", "off 1");
	SendMessage("", "페이드", "Recursive 3 1 0");
	SendMessage("사운드", "연주3d", GetObjPos("", "머리") + " 거미_도망.wav");

	if(GetObjValue("status") == "chase")
	{
		SendMessage("", "애니메이션", "서있기");
		SendMessage("사운드", "연주멈춤", "거미이동");
	}

	SetObjValue("status", "wait");
	SetTimer(5,"classspider_wait *obj 교실거미");
	SetObjValue("damage", "false");

	$spider_showfactor *= 2;

/*	switch($spider_showfactor)
	{
		case 1:
			$spider_showfactor = 2;
			break;
		case 2:
			$spider_showfactor = 4;
			break;
		case 5:
			$spider_showfactor = 10;
			break;
		case 10:
			$spider_showfactor = -1;
			break;
	}*/
}

classspider_appear()
{	
	$AI_교실거미 = ON;
	SetObjValue("status", "stop");	

	SendMessage("", "중심위치", "" + GetGhostPos("" + $user_class));
	SendMessage("", "페이드", "Recursive 1 0 1");
//	SendMessage("", "TurnGlow", "on 0");
//	SendMessage("", "TurnGlow", "on 1");	
	SendMessage("사운드", "연주", "거미_나타남.wav");
	SetTimer(1, "classspider_chase *obj 교실거미");	
}

classspider_chase()
{	
	if($AI_교실거미 == OFF || GetObjValue("status") == "return" || GetObjValue("status") == "attack" || GetObjValue("status") == "wait")
		return;

	if(xz_distance(GetObjPos("유저"), GetObjPos("", "머리")) < 100)				
		SetTimer(0, "classspider_attract *obj 교실거미");	
	else
	{		
		if(GetObjValue("status") != "chase")
		{			
			SendMessage("사운드", "연주", "loop,거미이동,거미_이동01.wav");
			SendMessage("", "애니메이션", "전진");
		}

		SetObjValue("status", "chase");		
		SendMessage("", "빨리돌기포인트", "" + GetObjPos("유저"));		
		SendMessage("", "강제이동", GetObjPos("유저") + " 300");
		SetTimer(0.3, "classspider_chase *obj 교실거미");
	}
}

classspider_attract()
{
	if($AI_교실거미 == OFF)
		return;

	if(GetObjValue("status") == "chase")	
		SendMessage("사운드" ,"연주멈춤", "거미이동");

	$AI_형체있는인간 = OFF;
	SetObjValue("status", "attack");
	SendMessage("", "Stop", "");
	SendMessage("", "애니메이션", "서있기");
//	SendMessage("", "TurnGlow", "off 0");
//	SendMessage("", "TurnGlow", "off 1");
	SendMessage("자막", "활성화", "");
	SendMessage("유저", "강제이동", GetObjPos("교실거미", "머리") + " 100 *script 천정귀신.classspider_look");	
}

classspider_look()
{
//	SendMessage("", "위치쳐다보기", GetObjPos("교실거미", "머리") + " 360");
	SendMessage("", "중력", "off");
	SendMessage("", "끌려올라가기", "교실거미 200");
	SetTimer(2, "classspider_throw *obj 교실거미");
}

classspider_throw()
{
//	SendMessage("", "TurnGlow", "on 0");	
//	SendMessage("", "TurnGlow", "on 1");		

//	SendMessage("유저", "쳐다보지말기", "");	
//	$throw_point = GetThrowPoint("" + $user_class, "" + GetObjPos("유저", "머리"));	
//	SendMessage("유저", "x축강제이동", $throw_point + " 1200 *script 천정귀신.classspider_damage");

	$throw_point = GetThrowPoint("" + $user_class, GetObjPos("유저"));	
	SendMessage("유저", "강제이동", $throw_point + " 1000 *script 천정귀신.classspider_damage");
}

classspider_damage()
{	
	SendMessage("사운드", "연주", "교실벽.wav");
	SendMessage("유저", "공격", "교실거미");	
	SendMessage("유저", "중력", "on");
	SendMessage("자막", "비활성", "");	
	ChangeObjValue("교실거미", "status", "attack_ready");
	SetTimer(4, "classspider_chase *obj 교실거미");
	if(xz_distance(GetObjPos("유저"), GetObjPos("교실거미")) > 900)
	SendMessage("유저", "위치", "" + $교실유저좌표);
	$AI_형체있는인간 = ON;
}

classspider_hide()
{	
	if(GetObjValue("status") != "stay" && GetObjValue("status") != "stop")
		return;

	$AI_교실거미 = OFF;
	SendMessage("사운드", "연주", "거미_사라짐.wav");
//	SendMessage("", "TurnGlow", "off 0");
//	SendMessage("", "TurnGlow", "off 1");
	SendMessage("", "페이드", "Recursive 1 1 0");	
	SetObjValue("status", "wait");
	SetObjValue("damage", "true");
	SetTimer(5, "classspider_wait *obj 교실거미");
}

classspider_forcehide()
{
	$AI_교실거미 = OFF;

	if(GetObjValue("status") == "chase")
	{
		SendMessage("사운드", "연주멈춤", "거미이동");
		SendMessage("", "애니메이션", "서있기");
	}

	SendMessage("", "Stop", "");	
//	SendMessage("", "TurnGlow", "off 0");
//	SendMessage("", "TurnGlow", "off 1");
	SendMessage("", "페이드", "Recursive 0 0 0");	
	SetObjValue("status", "stop");
}

classspider_wait()
{
	SetObjValue("status", "stop");
}

classspider_return()
{
	SetObjValue("status", "return");	
	SendMessage("사운드", "연주", "loop,거미이동,거미_이동01.wav");
	SendMessage("", "빨리돌기포인트", "" + GetStayPos("" + $user_class));		
	SendMessage("", "애니메이션", "전진");
	SendMessage("", "강제이동", GetStayPos("" + $user_class) + " 200 *script 천정귀신.classspider_stay");
}

classspider_stay()
{
	if($AI_교실거미 == OFF)	
		return;

	SetObjValue("status", "stay");

	if($신관_세환_교실들어감 == TRUE)	
		RunScript("교실거미", "천정귀신.classspider_chase");	
	else
	{		
		SendMessage("사운드", "연주멈춤", "거미이동");
		SendMessage("", "애니메이션", "서있기");	
		SendMessage("", "빨리돌기포인트", "" + GetObjPos("유저"));	
		SetTimer(5,"classspider_hide *obj 교실거미");
	}
}

classspider_status()
{
	$status = GetObjValue("status");

	switch($status)
	{
		case "stop":					
			if($신관_세환_교실들어감 == FALSE)
			{								
//				$show = 3 * $spider_showfactor;
//				if(Random($show) == 0)
					RunScript("교실거미", "천정귀신.classspider_appear");
			}
			break;

		case "chase":
			RunScript("교실거미", "천정귀신.classspider_return");			
			break;

		case "wait":
		case "attack":
		case "return":	
		case "attack_ready":
			break;
		
		case "stay":
			RunScript("교실거미", "천정귀신.classspider_chase");
			break;	
	}

	$신관_세환_교실들어감 = TRUE;
}

