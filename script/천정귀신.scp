_out()
{
	if($b_교실거미 == 1)
	{
		DeleteObject("");
		return;
	}

	if($신관_세환_교실들어감 == FALSE)
		return;

	$교실유저좌표 = "";

	$신관_세환_교실들어감 = FALSE;
	if(TakeObjValue("교실거미", "status") == "chase" || TakeObjValue("교실거미", "status") == "attack_ready")	
		RunScript("교실거미", "천정귀신.classspider_return");	
}




///////////////////////// 은미배틀용 복도거미 ///////////////////////////////////

_복도거미.StartUp()
{
	if($신관_세환_은미이벤트 == 2)
		DeleteObject("");	

	$AI_복도거미 = OFF;
	
//	SendMessage("", "끄기", "");
	SendMessage("", "페이드", "Recursive 0 0 0");
	SendMessage("", "TurnGlow", "off 0");
	SendMessage("", "TurnGlow", "off 1");
	SendMessage("", "발광", "Recursive on");
}

_복도거미.damage()
{
	if(GetObjValue("status") == "attack")
		return;

	$AI_복도거미 = OFF;

	SendMessage("사운드", "연주멈춤", "거미이동");
	SendMessage("사운드", "연주", "loop,거미도망,거미_이동02.wav");

	if(ComparePos(FindPoint("fix_camera"), GetObjPos("복도거미"), 2) > 0)	
	{
		SendMessage("", "빨리돌기포인트", "" + FindPoint("복도거미hide_1"));	
		SetTimer(1,"corridorspider_runaway1 *obj 복도거미");		
	}
	else	
	{
		SendMessage("", "빨리돌기포인트", "" + FindPoint("복도거미hide_2"));	
		SetTimer(1,"corridorspider_runaway2 *obj 복도거미");		
	}		
}

corridorspider_runaway1()
{
	SendMessage("", "z축강제이동", GetWallPos(GetObjPos("복도거미"), FindPoint("복도거미hide_1")) + " 300 *script 천정귀신.corridorspider_hide");	
}

corridorspider_runaway2()
{
	SendMessage("", "z축강제이동", GetWallPos(GetObjPos("복도거미"), FindPoint("복도거미hide_2")) + " 300 *script 천정귀신.corridorspider_hide");	
}

corridorspider_hide()
{		
	SetObjValue("status", "stop");
	SendMessage("", "애니메이션", "서있기");
	SendMessage("", "페이드", "Recursive 0 0 0");
	SendMessage("사운드", "연주멈춤", "거미도망");
}

corridorspider_appear()
{
	if($AI_복도거미 == ON)
		return;

	$AI_복도거미 = ON;
	SetObjValue("status", "stop");

//	$spider_point = GetSpiderPoint("유저");

//	if($spider_point != "0")
//	{
//		SendMessage("", "위치", "" + FindPoint("" + $spider_point));
		SendMessage("", "빨리돌기포인트", "" + GetObjPos("유저"));
		SendMessage("", "페이드", "Recursive 1 0 1");		
		SendMessage("사운드", "연주", "거미_나타남.wav");	
		SetTimer(1,"corridorspider_chase *obj 복도거미");
//	}
//	else
//	{
//		TextOut("No StartPoint Near You");	// debug
//		$AI_복도거미 = OFF;
//		SetTimer(5,"corridorspider_appear *obj 복도거미");
//		return;
//	}
}

corridorspider_chase()
{
	if($AI_복도거미 == OFF)
		return;

	$xz_dis = xz_distance(GetObjPos("유저"), GetObjPos("복도거미", "머리"));
	$y = GetObjPosY("유저");

	if($y < 240)
	{
		RunScript("복도거미", "천정귀신.corridorspider_restrict");
		SetTimer(0.1, "corridorspider_rechase1");
		return;
	}

	if($y > 370 && xz_distance(GetObjPos("유저"), GetObjPos("신관배전판")) < 300)
	{
		RunScript("복도거미", "천정귀신.corridorspider_restrict");
		SetTimer(0.1, "corridorspider_rechase2");
		return;
	}

	if($xz_dis < 150)
	{
		SetTimer(0, "corridorspider_attract *obj 복도거미");
		return;
	}
//	else if($xz_dis > 500)
//	{
//		TextOut("Chase_Fail!!");	// debug		
//		SendMessage("", "Stop", "");
//		SendMessage("", "애니메이션", "서있기");
//		SendMessage("", "페이드", "Recursive 1 1 0");		
//		SendMessage("사운드", "연주멈춤", "거미이동");
//		SetObjValue("status", "stop");
//		$AI_복도거미 = OFF;
//		return;
//	}

	if(GetObjValue("status") != "chase")
	{
		SendMessage("사운드", "연주", "loop,거미이동,거미_이동01.wav");
		SendMessage("", "애니메이션", "전진");
		SetObjValue("status", "chase");
	}

	if(x_distance(GetObjPos("유저"), GetObjPos("","머리")) > 100)
	{				
		if(ComparePos(GetObjPos("유저"), GetObjPos("", "머리"), 0) > 0)
		{			
			SendMessage("", "회전", "90");			
			SendMessage("", "x축강제이동", ConvObjPos("유저", "0 -100") + " 500");
		}
		else
		{			
			SendMessage("", "회전", "-90");			
			SendMessage("", "x축강제이동", ConvObjPos("유저", "0 100") + " 500");
		}
		
		SetTimer(0.5, "corridorspider_chase *obj 복도거미");
	}
	else if(z_distance(GetObjPos("유저"), GetObjPos("","머리")) > 100)
	{				
		if(ComparePos(GetObjPos("유저"), GetObjPos("", "머리"), 2) > 0)
		{
			SendMessage("", "회전", "180");			
			SendMessage("", "z축강제이동", ConvObjPos("유저", "2 -100") + " 500");
		}
		else
		{
			SendMessage("", "회전", "0");			
			SendMessage("", "z축강제이동", ConvObjPos("유저", "2 100") + " 500");
		}
		
		SetTimer(0.5, "corridorspider_chase *obj 복도거미");
	}
}

corridorspider_rechase1()
{
	$y = GetObjPosY("유저");

	if($y > 240)
	{
		RunScript("복도거미", "천정귀신.corridorspider_appear");
		return;
	}

	SetTimer(0.1, "corridorspider_rechase1");
}

corridorspider_rechase2()
{
	$y = GetObjPosY("유저");

	if($y > 370 && xz_distance(GetObjPos("유저"), GetObjPos("신관배전판")) > 300)
	{
		RunScript("복도거미", "천정귀신.corridorspider_appear");
		return;
	}
	SetTimer(0.1, "corridorspider_rechase2");
}

corridorspider_attract()
{	
	if($AI_복도거미 == OFF)
		return;

	$AI_형체있는인간 = OFF;	
	$복도거미잡히기전 = GetObjPos("유저");
	SendMessage("", "Stop", "");
	SendMessage("", "애니메이션", "서있기");
	SendMessage("사운드", "연주멈춤", "거미이동");
	SetObjValue("status", "attack");
	SendMessage("자막", "활성화", "");
	SendMessage("유저", "강제이동", GetObjPos("복도거미") + " 100");
	SetTimer(1,"corridorspider_look *obj 유저");
	SendMessage("사운드", "연주", "거미_올리기.wav");	
}

corridorspider_look()
{		
	$y = GetObjPosY("유저");

	SendMessage("", "위치쳐다보기", GetObjPos("복도거미", "머리") + " 360");
	SendMessage("", "중력", "off");
	SendMessage("", "끌려올라가기", "복도거미 200");
	if($y > 370)
	SetTimer(2,"corridorspider_damage *obj 유저");
	else
	SetTimer(3,"corridorspider_damage *obj 유저");
}

corridorspider_damage()
{
	SendMessage("유저", "공격", "복도거미");
	SendMessage("", "쳐다보지말기", "");
	SendMessage("", "중력", "on");
	SendMessage("자막", "비활성", "");
	SetTimer(4,"corridorspider_chase *obj 복도거미");
	$AI_형체있는인간 = ON;
	SendMessage("유저", "위치", "" + $복도거미잡히기전);
	SendMessage("사운드", "연주", "거미_벽부딪힘.wav");
}

corridorspider_restrict()
{			
	if($AI_복도거미 == OFF)
		return;
	
	$AI_복도거미 = OFF;
	SetObjValue("status", "stop");

	SendMessage("사운드", "연주멈춤", "거미이동");
	SendMessage("사운드", "연주", "거미_사라짐.wav");
	SendMessage("", "Stop", "");
	SendMessage("", "애니메이션", "서있기");	
	SendMessage("", "페이드", "Recursive 1 1 0");	
}

///////////////////////// 본관 거미 ////////////////////////////////////////////

_본관거미.StartUp()
{
	if($게임모드 == 0 || $게임모드 == 4)
		DeleteObject("");	

	SendMessage("", "페이드", "Recursive 0 0 0");
	SendMessage("", "TurnGlow", "off 0");	
	SendMessage("", "TurnGlow", "off 1");
	SetObjValue("status", "stop");		// stop, attack, chase, return, wait, stay, attack_ready
}

mbspider_appear()
{	
	$AI_본관거미 = ON;
	SetObjValue("status", "stop");	

	SendMessage("", "페이드", "Recursive 1 0 1");
	SendMessage("", "TurnGlow", "on 0");
	SendMessage("", "TurnGlow", "on 1");	
	SendMessage("사운드", "연주", "거미_나타남.wav");
	SetTimer(1, "mbspider_chase *obj 본관거미");	
}

mbspider_chase()
{	
	if($AI_본관거미등장 == FALSE)
	{
		RunScript("본관거미", "천정귀신.mbspider_return");
		return;
	}

	if($AI_본관거미 == OFF || GetObjValue("status") == "return" || GetObjValue("status") == "attack" || GetObjValue("status") == "wait")
		return;

	if(xz_distance(GetObjPos("유저"), GetObjPos("", "머리")) < 100)				
		SetTimer(0, "mbspider_attract *obj 본관거미");	
	else
	{		
		if(GetObjValue("status") != "chase")
		{			
			SendMessage("사운드", "연주", "loop,거미이동,거미_이동01.wav");
			SendMessage("", "애니메이션", "전진");
		}

		SetObjValue("status", "chase");		
		SendMessage("", "빨리돌기포인트", "" + GetObjPos("유저"));		
		SendMessage("", "강제이동", GetObjPos("유저") + " 300");
		SetTimer(0.3, "mbspider_chase *obj 본관거미");
	}
}

mbspider_attract()
{
	if($AI_본관거미 == OFF)
		return;

	if(GetObjValue("status") == "chase")	
		SendMessage("사운드" ,"연주멈춤", "거미이동");

	$AI_형체있는인간 = OFF;
	SetObjValue("status", "attack");
	SendMessage("", "Stop", "");
	SendMessage("", "애니메이션", "서있기");
	SendMessage("", "TurnGlow", "off 0");
	SendMessage("", "TurnGlow", "off 1");
	SendMessage("자막", "활성화", "");
	SendMessage("유저", "쳐다보기", "본관거미 180");
	SendMessage("유저", "강제이동", GetObjPos("본관거미", "머리") + " 100 *script 천정귀신.mbspider_look");	
}

mbspider_look()
{
	SendMessage("", "중력", "off");
	SendMessage("", "끌려올라가기", "본관거미 200");
	SetTimer(2, "mbspider_throw *obj 본관거미");
}

mbspider_throw()
{
	SendMessage("", "TurnGlow", "on 0");	
	SendMessage("", "TurnGlow", "on 1");		

	SendMessage("유저", "강제이동", FindPoint("본관거미데미지") + " 1000 *script 천정귀신.mbspider_damage");
}

mbspider_damage()
{	
	SendMessage("사운드", "연주", "교실벽.wav");
	SendMessage("유저", "공격", "교실거미");	
	SendMessage("유저", "중력", "on");
	SendMessage("유저", "쳐다보지말기", "");
	SendMessage("자막", "비활성", "");	
	ChangeObjValue("본관거미", "status", "attack_ready");
	SetTimer(4, "mbspider_chase *obj 본관거미");
	$AI_형체있는인간 = ON;
}

mbspider_hide()
{	
	if(GetObjValue("status") != "stay" && GetObjValue("status") != "stop")
		return;

	$AI_본관거미 = OFF;
	SendMessage("사운드", "연주", "거미_사라짐.wav");
	SendMessage("", "TurnGlow", "off 0");
	SendMessage("", "TurnGlow", "off 1");
	SendMessage("", "페이드", "Recursive 1 1 0");	
	SetObjValue("status", "wait");
	SetTimer(0, "mbspider_wait *obj 본관거미");
}

mbspider_forcehide()
{
	$AI_본관거미 = OFF;

	if(GetObjValue("status") == "chase")
	{
		SendMessage("사운드", "연주멈춤", "거미이동");
		SendMessage("", "애니메이션", "서있기");
	}

	SendMessage("", "Stop", "");	
	SendMessage("", "TurnGlow", "off 0");
	SendMessage("", "TurnGlow", "off 1");
	SendMessage("", "페이드", "Recursive 0 0 0");	
	SetObjValue("status", "stop");
}

mbspider_wait()
{
	SetObjValue("status", "stop");
}

mbspider_return()
{
	SetObjValue("status", "return");	
	SendMessage("사운드", "연주", "loop,거미이동,거미_이동01.wav");
	SendMessage("", "빨리돌기포인트", "" + FindPoint("본관거미중심"));		
	SendMessage("", "애니메이션", "전진");
	SendMessage("", "강제이동", FindPoint("본관거미중심") + " 200 *script 천정귀신.mbspider_stay");
}

mbspider_stay()
{
	if($AI_본관거미 == OFF)	
		return;

	SetObjValue("status", "stay");

	if($AI_본관거미등장 == TRUE)	
		RunScript("본관거미", "천정귀신.mbspider_chase");	
	else
	{		
		SendMessage("사운드", "연주멈춤", "거미이동");
		SendMessage("", "애니메이션", "서있기");	
		SendMessage("", "빨리돌기포인트", "" + GetObjPos("유저"));	
		SetTimer(1,"mbspider_hide *obj 본관거미");
	}
}

mbspider_status()
{
	$status = GetObjValue("status");

	switch($status)
	{
		case "stop":					
			if($AI_본관거미등장 == FALSE)
				RunScript("본관거미", "천정귀신.mbspider_appear");
			break;

		case "chase":
			RunScript("본관거미", "천정귀신.mbspider_return");			
			break;

		case "wait":
		case "attack":
		case "return":	
		case "attack_ready":
			break;
		
		case "stay":
			RunScript("본관거미", "천정귀신.mbspider_chase");
			break;	
	}

	$AI_본관거미등장 = TRUE;
}

mbspider_check()
{			
	if($게임모드 == 0 || $게임모드 == 4)
	{
		DeleteObject("");
		return;
	}

	RunScript("본관거미", "천정귀신.mbspider_status");	
}

mbspider_out()
{
	if($게임모드 == 0 || $게임모드 == 4)
	{
		DeleteObject("");
		return;
	}

	if($AI_본관거미등장 == FALSE)
		return;

	$AI_본관거미등장 = FALSE;
	if(TakeObjValue("본관거미", "status") == "chase" || TakeObjValue("본관거미", "status") == "attack_ready")	
		RunScript("본관거미", "천정귀신.mbspider_return");	
}
