_강당연결통로불켜기1()
{
	if($e_강당연결통로조명상태 != 1)
	{
		if($e_강당연결통로조명상태)
		{
			SendMessage("배경", "끄기", "sense_" + $e_강당연결통로조명상태);
			SendMessage("복도천정등" + $e_강당연결통로조명상태, "발광", "Recursive off");
		}

		$e_강당연결통로조명상태 = 1;
		SendMessage("배경", "켜기", "sense_" + $e_강당연결통로조명상태);
		SendMessage("복도천정등" + $e_강당연결통로조명상태, "발광", "Recursive on");
	}
}

