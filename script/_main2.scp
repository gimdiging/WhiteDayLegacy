_지진()
{	
//	TextOut(TakeObjValue("정찰용수위", "정책") + " " + $수위추적모드);
	if($수위추적모드 == ON)
		return;

	DeleteObject("");
	
	if($본2_영호_미술실문쾅 == 0)
	{
		$본2_영호_미술실문쾅 = 1;
		RunScript("","e_지진._단독지진");
		SendMessage("매크로", "Play", "main2_scenez._001");
	}

}

