Inito_나무상자3()
{
	SendMessage("", "스크립트설정", "dummy0 null");
	SendMessage("", "스크립트설정", "dummy1 null");
	SendMessage("", "스크립트설정", "dummy2 null");
	SendMessage("", "스크립트설정", "dummy3 null");
}

test.fire2.Collision()
{
	if($본2_영호_비이커를들었나 == TRUE && $본2_영호_물이있냐 == 10)
	{
	$본2_영호_물이있냐 = 0;
	SetTimer(0, "_main2.test.fire2.Damage");
	}
	else if($본2_영호_비이커를들었나 == FALSE)
	{
	if($강당_바닥불 > 4)
	$강당_바닥불 = 1;

	SendMessage("유저","공격","바닥불" + $강당_바닥불);
	$강당_바닥불++;
	}
}

test.fire2.Init()
{
	SetObjValue("밝기", 1.0);
}

test.fire2.Damage()
{
	SetObjValue("밝기", GetObjValue("밝기") - 0.2);

	if (GetObjValue("밝기") < 0.2)
	{
		DeleteObject("");
		SetTimer(4, "_main2.give1");
	}

	SendMessage("유저", "이동속도", "0");
	SetTimer(4,"오브젝트_유저._이동속도");
	SendMessage("", "사이즈변환", GetObjValue("밝기") + " 1");
	SendMessage("비이커", "애니메이션", "*물부어");
	SendMessage("사운드", "연주", "data/sound/event/비이커로불끄는소리.wav");
	SendMessage("진짜지현", "위치", "" + FindPoint("진짜지현위치"));
}

test.fire3.Collision()
{
	if($본2_영호_양동이를들었나 == TRUE && $본2_영호_양동이를들었나2 == 10)
	{
	$본2_영호_양동이를들었나2 = 0;
	SetTimer(0, "_main2.test.fire3.Damage");
	}
	else if($본2_영호_양동이를들었나 == FALSE)
	{
	if($강당_바닥불 > 4)
	$강당_바닥불 = 1;

	SendMessage("유저","공격","바닥불" + $강당_바닥불);
	$강당_바닥불++;
	}
}

test.fire3.Init()
{
	SetObjValue("밝기", 1.0);
}

test.fire3.Damage()
{
	SetObjValue("밝기", GetObjValue("밝기") - 0.3);

	if (GetObjValue("밝기") < 0.2)
	{
		DeleteObject("");
		SetTimer(5, "_main2.give2");
	}

	SendMessage("유저", "이동속도", "0");
	SetTimer(5,"오브젝트_유저._이동속도");
	SendMessage("", "사이즈변환", GetObjValue("밝기") + " 1");
	SendMessage("물양동이", "애니메이션", "*물부기");
	SendMessage("사운드", "연주", "data/sound/event/양동이로불끄는소리.wav");
	SendMessage("진짜지현", "위치", "" + FindPoint("진짜지현위치"));
}

give1()
{
	SendMessage("비이커", "위치", "0.0 0.0 0.0");
	SendMessage("유저", "놓기", "팔");
	$본2_영호_비이커를들었나 = FALSE;
	$USER_CAPTUREITEM = FALSE;
	SendMessage("유저", "폐기", "비이커");
}

give2()
{
	SendMessage("배경", "끄기", "fire");
	SendMessage("물양동이", "위치", "0.0 0.0 0.0");
	SendMessage("유저", "놓기", "팔");
	$본2_영호_양동이를들었나 = FALSE;
	$USER_CAPTUREITEM = FALSE;
	SendMessage("유저", "폐기", "양동이");
	SendMessage("사운드", "연주멈춤", "불소리");
	SendMessage("사운드", "연주멈춤", "지현고통");
//	SendMessage("진짜지현", "애니메이션","안도하기");
	SendMessage("진짜지현", "애니메이션","서있기");
	RunScript("스위치_과학부속실","오브젝트_버튼1스위치._켜");
	SetTimer(0, "_main2.give3");
}

give3()
{
	if(xz_distance(GetObjPos("유저"), GetObjPos("진짜지현")) < 100);
	{
	if($진행루트 == 0)
	{
	SendMessage("지현", "켜기", "");
	$AI_지현 = ON;
	}
	if($진행루트 == 1)
	RunScript("정찰용수위","캐릭터_수위._리셋");
	DeleteObject("진짜지현");
	RunScript("", "_whiteday.FadeIn");
	LoadObject("WObjStaticBody", "가짜지현","*scale 1.00 *pet 지현-립싱크.pet  *block 0 *group -1 *optimize *pos -637 263 2116  *rot 0.00 180.00 0.00 *FlagShow 1 *Show 1");
	SendMessage("사운드", "연주", "data/sound/나영웃음.wav");
	SendMessage("유저", "쳐다보기", "가짜지현 1000");
	SendMessage("유저", "이동속도", "0");
	SetTimer(3, "_main2.give4");
	if($게임모드 != 0 && $게임모드 != 4)
	SendMessage("허드", "가스게이지꺼", "");
	return;
	}
	SendMessage("진짜지현", "위치", "" + FindPoint("진짜지현위치"));
	SetTimer(0.1, "_main2.give3");
}

give4()
{
	DeleteObject("가짜지현");
	LoadObject("WObjStaticBody", "수위뒤돌기","*scale 1.00 *pet 수위뒤돌기.pet  *block 0 *group -1 *optimize *pos -637 263 2191  *rot 0.00 0.00 0.00 *FlagShow 1 *Show 1");
	SendMessage("유저", "쳐다보기", "수위뒤돌기 1000");
	SendMessage("카메라", "카메라떨림", "40 30 2");
	SendMessage("카메라", "카메라떨림", "30 25 3");
	SendMessage("카메라", "카메라떨림", "20 20 3");
	SendMessage("카메라", "공격", "-100 30 10 75 200 5");
	LoadObject("WObjPanel", "", "*diffuse ff0000 *delay 1 *type 1");
	SendMessage("사운드", "연주", "data/sound/event/본관1_벼락강타.wav");
	SetTimer(5, "_main2.give5");
}

give5()
{
	SendMessage("유저", "쳐다보지말기", "");
	SendMessage("유저", "이동속도", "1");
	SendMessage("유저", "회전", "0");
	DeleteObject("수위뒤돌기");
	SendMessage("카메라", "카메라떨림", "40 30 2");
	SendMessage("카메라", "카메라떨림", "30 25 3");
	SendMessage("카메라", "카메라떨림", "20 20 3");
	SendMessage("카메라", "공격", "-100 30 10 75 200 5");
	LoadObject("WObjPanel", "", "*diffuse ff0000 *delay 1 *type 1");
	RunScript("","_whiteday.FlashBack");
	SendMessage("유저", "위치", "" + FindPoint("시작위치"));
	SendMessage("사운드", "연주", "data/sound/귀신놀림.wav");
	$본관불껐냐 = TRUE;
	$화재진압중 = 0;
	$문_본관화장실2F남 = UNLOCK;
	$문_본관화장실4F남 = UNLOCK;
}