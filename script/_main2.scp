}

_장갑떨어져()
{
	if($똥침장갑은한번만 == 0)
	{
		SendMessage("흰색장갑", "위치", "" + GetObjPos("해부마네킹"));
		SendMessage("흰색장갑", "중력", "on");
		$똥침장갑은한번만 = 1;
	}
}


