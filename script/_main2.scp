Create()
{
	RunScript("","_testValue.Init");
	$현재스테이지 = "본관2";
	RunScript("", "_whiteday.StartBanner");

	//	WEP 읽기
	LoadWed("data/main2.wep", 1);
	SetTimer(0, "_main2.Create_init");
	// SetRegistry("Option\\LowTexture","1"); // 이런식으로하라.
}

Create_init()
{
	LoadObject("WObjParticle", "파티", "");
	LoadObject("WObjCctvmode", "cctv", "");
	LoadObject("WObjNumLock","번호자물","");

	SendMessage("사운드", "연주", "loop,비온다,본관2_빗소리.wav");
	
	for($i=1;$i<=8;$i++)
	{
		LoadObject("WObjParticle","문" + $i,"");
	}

	if ($게임모드 == 3)
	{
		SendMessage("카메라", "카메라거리", "10 3000");
		SendMessage("카메라", "포그", "500 3000 010101 0.2 1.0 0");
	}	else
		SendMessage("배경", "SKYBOX로딩", "default");

	RunScript("스위치_미술실b","오브젝트_버튼1스위치._켜"); 
	RunScript("스위치_학생부실","오브젝트_버튼1스위치._켜"); 
	RunScript("스위치_교무실Cb","오브젝트_버튼1스위치._켜"); 

	if ($게임모드 != 0 && $게임모드 != 4)
	{
		SetTimer(0,"e_2d귀신._본관귀신");
		RunScript("", "e_2d귀신._1분후에머리귀신살아라");
	}

	if($본2_영호_미술실이벤트완료 == 0)
	{
		$지진가동중 = 1;
		SetTimer(10, "e_지진._지진이벤트");
	}	

	if($신관_세환_은미이벤트 == 0)
	{
		if($AI_본관2_Active == 2)
			SetTimer(0, "캐릭터_수위._리셋 *obj 정찰용수위");
		else if($AI_본관2_Active == 1)
		{
			$AI_수위예약등장 = TRUE;				
			SetTimer(60, "캐릭터_수위._예약등장 *obj 정찰용수위");
		}
	}

	LoadObject("WObjDyLight", "자판기light", "*pos " + FindPoint("자판기조명") + " *diffuse ffffff *intensity 200");
	SendMessage("자판기light", "켜기", "");

	SendMessage("유저", "픽금지", "off");
}

Destroy()
{
	DeleteObject("자판기light");

	for($i=1;$i<=8;$i++)
	{
		DeleteObject("문"+$i);
	}

	DeleteObject("cctv");
	DeleteObject("파티");
	DeleteObject("번호자물");
	DeleteObject("렌턴_정찰용수위");
	DeleteObject("렌턴_매크로용이수위");
	
	if ($게임모드 != 0 && $게임모드 != 4)
	{
		RunScript("", "e_2d귀신._본관귀신날려");
	}
	
	if($본2_영호_전화둘중한이벤트만 == 2)
	{
		SendMessage("사운드", "연주멈춤", "교무실전화벨소리");
		$본2_영호_전화둘중한이벤트만 = 1;
	}

	RunScript("", "_whiteday.ResetMainGameObject");
	$AI_본관2_Active = $AI_수위_Active;
}


_신관으로()
{
	if($USER_CAPTUREITEM == TRUE)
	{		
		SendMessage("자막", "문자출력후대기", GetString("s0"));
		return;
	}

	if($수위추적모드 == ON)
	{
		SendMessage("자막", "문자출력후대기", GetString("s2"));
		return;
	}
	
	if ($EnterObj == "유저" )
	{
		SendMessage("자막", "활성화", "");
		SendMessage("자막", "와이드모드", "켜기");
		SendMessage("자막", "실행함수", "_main2._신관으로제대로");
		SendMessage("자막", "선택", GetString("s221"));
	}
}

_신관으로제대로()
{
	SendMessage("자막", "와이드모드", "끄기");
	SendMessage("자막", "비활성", "");

//	if($HP < 1)
//	{
//		$GameOverMode = 0;
//		RunScript("", "오브젝트_유저._유저.dead");
//		return;
//	}

	if($G_UserSelect == 0)
	{
		Destroy();
//		SetTimer(0,"_new.Create");	
		RunScript("유저", "_new.Create");
	}
}

_본관1로()
{
	if($USER_CAPTUREITEM == TRUE)
	{		
		SendMessage("자막", "문자출력후대기", GetString("s0"));
		return;
	}

	if($본2_영호_아기발동중 == 1)
	{
		SendMessage("자막", "문자출력후대기", GetString("s1"));
		return;
	}

	if($수위추적모드 == ON)
	{
		SendMessage("자막", "문자출력후대기", GetString("s2"));
		return;
	}

	if($AI_지현 == ON || $AI_소영 == ON || $소영이때문에못나가기 == 1)
	{
		SendMessage("자막", "문자출력후대기", GetString("s191"));
		return;
	}

	if ($EnterObj == "유저" )
	{
	
		SendMessage("자막", "활성화", "");
		SendMessage("자막", "와이드모드", "켜기");
		SendMessage("자막", "실행함수", "_main2._본관1로제대로");
		SendMessage("자막", "선택", GetString("s222"));
	}
}

_본관1로제대로()
{
	SendMessage("자막", "와이드모드", "끄기");
	SendMessage("자막", "비활성", "");

//	if($HP < 1)
//	{
//		$GameOverMode = 0;
//		RunScript("", "오브젝트_유저._유저.dead");
//		return;
//	}

	if($G_UserSelect == 0)
	{
		Destroy();
//		SetTimer(0, "_main1.Create");
		RunScript("유저", "_main1.Create");
	}
}

