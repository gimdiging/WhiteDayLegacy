*/
	if($신관_세환_홀조명 == OFF)
	{		
		$신관_세환_홀조명 = ON;
		SendMessage("","본회전","C-Ext02 " + "-90 0");
		SendMessage("","TurnGlow","on 0");
		SendMessage("사운드","연주","대형판넬레버.wav");					

		SendMessage("배경","켜기","hall");
		SendMessage("배경","켜기","center");
		SendMessage("배경","켜기","light1f");
