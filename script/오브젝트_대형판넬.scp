_가동()
{
	if($신관_세환_연주루프 == ON)
		SendMessage("사운드","연주3d", GetObjPos("전원차단기") + " loop,발전기_루프,data/sound/발전기루프.wav");
}

auto_off()
{
	if($신관_세환_시간간격유지A != 1 || GetObjValue("Left_Flag") == OFF)
	{
		$신관_세환_시간간격유지A--;
		return;
	}

	$신관_세환_시간간격유지A--;
	SendMessage("자막","활성화","");
	SendMessage("자막","와이드모드","켜기");
	SendMessage("카메라", "쳐다보기", FindPoint("카메라위치2") + " " + FindPoint("카메라대상2_"));

	SetTimer(3,"오브젝트_대형판넬.switch_down");
}

switch_down()
{
	SendMessage("전원차단기","본회전","C-Ext02 " + "-90 0");
	SendMessage("사운드","연주","data/sound/대형판넬레버.wav");		
	SetObjValue("Left_Flag", OFF);
	SendMessage("","TurnGlow","off 0");
			
	$신관_세환_홀조명 = OFF;

	if(GetObjValue("Right_Flag") == OFF)
		RunScript("전원차단기","오브젝트_대형판넬._끝");

	SendMessage("배경","끄기","hall");
	SendMessage("배경","끄기","center");
	RunScript("신관홀조명","o_신관조명.off");

	SetTimer(3,"오브젝트_대형판넬.end");
}

end()
{
	SendMessage("자막","와이드모드","끄기");
	SendMessage("자막","비활성","");
	SendMessage("카메라","쳐다보지말기","");	
}
*/
soundon()
{
	SendMessage("사운드","연주3d", GetObjPos("전원차단기") + " loop,발전기_루프,data/sound/발전기루프.wav");
}

soundoff()
{
	SendMessage("사운드", "연주멈춤", "발전기_루프");
}

// 매크로용

switch_up()
{
	SendMessage("", "본회전", "C-Ext03 0 0");
	SendMessage("", "TurnGlow", "off 1");
}

switch_down()
{
	SendMessage("", "본회전", "C-Ext03 -90 0");
	SendMessage("", "TurnGlow", "on 1");
	SendMessage("신관배전판", "TurnGlow", "off 2");	
}