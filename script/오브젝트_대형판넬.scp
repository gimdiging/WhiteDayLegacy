Init()
{	
	SendMessage("", "스크립트설정", "left " + $G_File + ".left_switch");
	SendMessage("", "스크립트설정", "right " + $G_File + ".right_switch");
	SendMessage("","TurnGlow","off 0");
	SendMessage("","TurnGlow","off 1");
	
	SetObjValue("Right_Step",0);
	SetObjValue("Left_Step",0);

//	SetObjValue("Right_Flag",ON);
//	SetObjValue("Left_Flag",OFF);

	SendMessage("","본회전","C-Ext02 " + "0 0");
	SendMessage("","본회전","C-Ext03 " + "0 0");

	if($신관_세환_홀조명 == ON)
	{		
		SendMessage("","본회전","C-Ext02 " + "-90 0");
		SendMessage("","TurnGlow","on 0");		

		SendMessage("배경","켜기","hall");		
	}

	if($게임모드 == 4 || $신관_세환_교실전력 == ON)
	{		
		$신관_세환_교실전력 = ON;
		SendMessage("","본회전","C-Ext03 " + "-90 0");
		SendMessage("","TurnGlow","on 1");				
	}

}

left_switch.pick()
{
	if(GetObjValue("Left_Step") == 0 || $G_LightFactor <= $standard_light)
		return "보기";

	return "잡기";
}

left_switch.click()
{
	if($G_LightFactor < $standard_light)
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));	
		return;
	}

//	$left_flag = GetObjValue("Left_Flag");
//	$right_flag = GetObjValue("Right_Flag");

	if(GetObjValue("Left_Step") == 0)
	{
		SendMessage("자막","문자출력후대기", GetString("s137"));
		SetObjValue("Left_Step",1);
		return;
	}
/*
	if($left_flag == OFF)
	{		
		SendMessage("전원차단기","본회전","C-Ext02 " + "0 0");
