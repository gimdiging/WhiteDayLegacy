Destroy()
{
	SendMessage("오디오", "연주멈춤", "");
	SendMessage("타이머", "씬삭제", "");
	SendMessage("main", "씬삭제", "");
	DeleteObject("cctv");
	DeleteObject("staffboard");
	
}

ScriptMain()
{
	if(GetRegistry("Option\OldVersion") == "1")
	{
	ChangeScript("main1");
	return;
	}

	Create();
	SendMessage("오디오", "SetVolume", "1.0");
	SendMessage("main", "게임시작", "시작");
	SetTimer(0, "StartUp");
}

StartUp()
{
	SendMessage("매크로", "Play", "b_type.cut00");
}

_goMain1()
{
	RunScript("", "_whiteday.FadeOut");
	RunScript("", "_btype.Destroy");
	_gomain1_1();
}

_gomain1_1()
{
	RunScript("", "_whiteday.FadeIn");
	SendMessage("main", "게임시작", "멈춤");
	
	ChangeScript("main1");
}


