Create()
{
	LoadWed("data/b_type.wep");
	SetTimer(0, "_btype.Create_init");

	RunScript("", "_whiteday._Display_Loading_panel");
	$atypeload = 0; // 
	if($게임모드 == 3)
	$게임모드 = 1;
	if($게임모드 != 0 && $게임모드 != 4)
	{
	$랜덤A = Random(6);
	$랜덤B = Random(5);
	$랜덤C = Random(5);
	$랜덤D = Random(5);
	$랜덤E = Random(3);
	$랜덤F = Random(3);
	}
}

