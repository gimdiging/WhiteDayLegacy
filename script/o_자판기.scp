		SendMessage("자막", "문자출력후대기", GetString("s4"));
		return;
	}	
	
	SendMessage("", "애니메이션", "5번누름");
	SetObjValue("MotionName", "5번누름");

	if(GetObjValue("coin") > 0 && GetObjValue("Game") == OFF)
	{				
		SetObjValue("Game", ON);
		SendMessage("", "발광", "5 on");
		SendMessage("", "GlowFlicker", "5");		
	}
}

