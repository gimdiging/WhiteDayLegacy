		SetObjValue("MotionName", "6번누름");
		return;
	}

	if(GetObjValue("can") == TRUE)
	{
		if(GetObjValue("item") == "캔커피")
		$자판기아이템 = GetString("s511");
		if(GetObjValue("item") == "도시락")
		$자판기아이템 = GetString("s512");
		if(GetObjValue("item") == "콩의눈")
		$자판기아이템 = GetString("s513");

			SendMessage("자막", "문자출력후대기", GetString("s514") + " " + $자판기아이템 + " " + GetString("s515"));
//		else
//			SendMessage("자막", "문자출력후대기", "배출구에 " + GetObjValue("item") + "이 남아있다.");
		return;
	}

	switch(GetObjValue("item"))
	{
		case "캔커피":
			SetObjValue("coin", GetObjValue("coin") - 1);			
			break;

		case "콩의눈":
			SetObjValue("coin", GetObjValue("coin") - 1);			
			break;

		case "도시락":
			SetObjValue("coin", GetObjValue("coin") - 2);			
			break;
	}
		
	SetObjValue("can", TRUE);
	SetObjValue("motion", ON);
	SendMessage("", "애니메이션", "6번누름");	
	SetObjValue("MotionName", "6번누름");
	SetTimer(1,"can_out");

	if(GetObjValue("coin") == 0 || (GetObjValue("coin") == 1 && GetObjValue("item") == "도시락"))
	{
		for($i = 1; $i < GetObjValue("버튼개수") + 1; $i++)
			SendMessage("", "TurnGlow", "hide " + $i);	
	}
}

door.pick()
{
	if($G_UserItem == "자판기열쇠")
		return "i열쇠9";			

	if($문_패스맨자판기 == LOCK || $b_노리군 == 1)
		return "";

	if(GetObjValue("MotionName") == "열기" || GetObjValue("MotionName") == "닫기" || GetObjValue("motion") == 1);
	{
		SendMessage("", "캐쉬초기화", "");
		return;
	}

	if($G_LightFactor < $standard_light)
		return "보기";	

	if($문_패스맨자판기 == UNLOCK)
		return "잡기";	
}

door.click()
{
	if($G_LightFactor < $standard_light)
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));
		return;
	}

	if($문_패스맨자판기 == LOCK && $G_UserItem == "자판기열쇠")
	{		
		SendMessage("자막", "문자출력후대기", GetString("s101"));	
		SendMessage("유저", "폐기", "@자판기열쇠");
		SendMessage("사운드", "연주", "신관_안쪽열기.wav");
		$문_패스맨자판기 = UNLOCK;
		return;		
	}
	
	if(GetObjValue("can") == FALSE)
		SendMessage("", "페이드", "food 0 0 0");	

	if(GetObjValue("OpenFlag") == 0)
	{		
		SendMessage("", "애니메이션", "열기 0.5");
		SetObjValue("OpenFlag", 1);
		if($수위추적모드 == OFF)					
		{
			if($b_노리군 == 0)
			$b_노리군 = 1;			
			SetTimer(1, "노리군.appear *obj 노리군");
		}
		return;
	}

	SendMessage("", "애니메이션", "닫기 0.5");
	SetObjValue("OpenFlag", 0);
}

slot.pick()
{	
	if(GetObjValue("MotionName") == "1번누름" || GetObjValue("MotionName") == "2번누름" || GetObjValue("MotionName") == "3번누름" || GetObjValue("MotionName") == "4번누름" || GetObjValue("MotionName") == "5번누름" || GetObjValue("MotionName") == "6번누름" || GetObjValue("MotionName") == "빈반환" || GetObjValue("MotionName") == "동전투입" || GetObjValue("OpenFlag") == 1 || GetObjValue("motion") == 1)
	{
		SendMessage("", "캐쉬초기화", "");
		return "";
	}

	if($G_LightFactor < $standard_light)
		return "보기";

	if($G_UserItem == "동전")
		return "i동전";	
		
	return "보기";
}

slot.click()
{
	if($G_LightFactor < $standard_light)
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));
		return;
	}

	if($G_UserItem == "동전")
	{
		SetObjValue("coin", GetObjValue("coin") + 1);
		SendMessage("", "페이드", "coin 0 1 1");
		SendMessage("", "애니메이션", "동전투입");
		SendMessage("유저", "폐기", "@동전");		

	if(GetObjValue("item") == "도시락" && GetObjValue("coin") == 1)
		return;

	if($정전 == 0)
	{
	for($i = 1; $i < GetObjValue("버튼개수") + 1; $i++)
		SendMessage("", "TurnGlow", "on " + $i);	
	}
	}
	else	
		SendMessage("자막", "문자출력후대기", GetString("s102"));	
}

change.pick()
{	
	if(GetObjValue("MotionName") == "1번누름" || GetObjValue("MotionName") == "2번누름" || GetObjValue("MotionName") == "3번누름" || GetObjValue("MotionName") == "4번누름" || GetObjValue("MotionName") == "5번누름" || GetObjValue("MotionName") == "6번누름" || GetObjValue("MotionName") == "빈반환" || GetObjValue("MotionName") == "동전투입" || GetObjValue("OpenFlag") == 1 || GetObjValue("motion") == ON)
	{
		SendMessage("", "캐쉬초기화", "");
		return "";
	}

	if($G_LightFactor < $standard_light)
		return "보기";

	return "잡기";
}

change.click()
{
	if($G_LightFactor < $standard_light)
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));
		return;
	}

	if(GetObjValue("coin") == 0)
	{		
		SendMessage("", "애니메이션", "빈반환");	
		return;
	}

	if(GetObjValue("coin") == 1)	
		SendMessage("유저", "획득", "@동전");			
	else	
		SendMessage("유저", "획득", "@동전 " + GetObjValue("coin"));						

	$coin = GetObjValue("coin") > 1 ? GetObjValue("coin") : "";
	$verb = GetObjValue("coin") > 1 ? GetString("s516") : GetString("s517");

//	if(GetLang() == "kor")
		SendMessage("자막", "문자출력후대기", GetString("s518") + " " + $coin + $verb);	// s_recheck
//	else
//		RunScript("", "english_conv.o_자판기_2");

	SetObjValue("coin", 0);

	SendMessage("", "애니메이션", "반환");

	for($i = 1; $i < GetObjValue("버튼개수") + 1; $i++)
		SendMessage("", "TurnGlow", "hide " + $i);	
}

outlet.pick()
{
	if(GetObjValue("motion") == ON)
	{
		SendMessage("", "캐쉬초기화", "");
		return "";
	}

	if($G_LightFactor < $standard_light)
		return "보기";

	if(GetObjValue("can") == TRUE)	
		return "잡기";
		
	return "보기";	
}

outlet.click()
{
	if($G_LightFactor < $standard_light)
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));
		return;
	}

	if(GetObjValue("can") == TRUE)
	{
		SendMessage("유저", "획득", "@" + GetObjValue("item"));		
		SendMessage("사운드", "연주", "아이템획득.wav");
		SetObjValue("can", FALSE);			
		switch(GetObjValue("item"))
