changes.pick()
{	
	if(GetObjValue("MotionName") == "1번누름" || GetObjValue("MotionName") == "2번누름" || GetObjValue("MotionName") == "3번누름" || GetObjValue("MotionName") == "4번누름" || GetObjValue("MotionName") == "5번누름" || GetObjValue("MotionName") == "6번누름" || GetObjValue("MotionName") == "빈반환" || GetObjValue("MotionName") == "동전투입")
	{
		SendMessage("", "캐쉬초기화", "");
		return "";
	}

	if($G_LightFactor < $standard_light)
