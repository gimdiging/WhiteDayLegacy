_게임시작()
{
	if ($게임모드 == 3)
	{
		SendMessage("카메라", "카메라거리", "10 3000");
		SendMessage("카메라", "포그", "500 3000 010101 0.2 1.0 0");
	}	else
	{
		SendMessage("배경", "SKYBOX로딩", "night_");
	}

	SendMessage("사운드", "연주", "loop,배경음01,data/sound/bgm/배경음03.wav"); 	

	RunScript("스위치_체육창고b", "오브젝트_버튼1스위치._켜");			
//	RunScript("스위치_1층여자화장실", "오브젝트_버튼1스위치._켜");			
//	RunScript("스위치_1층남자화장실", "오브젝트_버튼1스위치._켜");			
//	RunScript("스위치_2층남자화장실", "오브젝트_버튼1스위치._켜");			
	
	SetTimer(20, "o_물든수도꼭지.drip *obj 수도꼭지");

	SetTimer(16.5, "오브젝트_유저._이동모션");

//	SendMessage("정찰용수위", "리스트추가", "문_1층여자화장실");

	for($i = 1; $i<= $거미줄; $i++)
	{
		SendMessage("거미줄말짱" + $i, "페이드", "Recursive 0 0 0");
		SendMessage("거미줄아야" + $i, "페이드", "Recursive 0 1 1");
	}		

	SendMessage("유저", "획득", "허드");
	SendMessage("유저", "획득", "다이어리");
	SendMessage("유저", "획득", "가방");
	SendMessage("유저", "획득", "지도");
	SendMessage("유저", "획득", "핸드폰");
	SendMessage("유저", "획득", "포즈");
	SendMessage("유저", "획득", "@선물봉투");
	SendMessage("유저", "획득", "@소영다이어리");	
	SendMessage("유저", "획득", "@지갑");
	switch($게임모드)
	{
		case 0:
			SendMessage("유저", "획득", "@동전 4");	
			break;
		case 1:
//			SendMessage("유저", "획득", "@동전 2");	
			break;
		case 2:
			SendMessage("유저", "획득", "@동전");	
			break;
		case 3:
			SendMessage("유저", "획득", "@동전");	
			break;
		case 4:
//			SendMessage("유저", "획득", "@동전 4");
			break;
	}	

//	if ($게임모드 != 0 && $게임모드 != 4)
//		SendMessage("핸드폰", "mode", "끄기");

	SendMessage("허드", "끄기", "프로세스");

	TestItem();	
	
//	매크로용 세팅

	SendMessage("매크로", "Play", "main1_intro.cut01");
	
	RunScript("스위치_학적부실", "오브젝트_버튼1스위치._켜");		
	RunScript("스위치_가정실습실", "오브젝트_버튼1스위치._켜");				
	
	$이름종류 = GetNameType("" + $성 + $이름);

	if(GetLang() == "kor")
	$성이름간격 = " ";

// 귀신은 한번만해야합니다.
	if ($게임모드 != 0 && $게임모드 != 4)
	{
		SetTimer(0,"e_2d귀신._본관귀신");
		RunScript("", "e_2d귀신._1분후에머리귀신살아라");
	}

//	이벤트용 세팅

	RunScript("교실상자_1", "o_공상자.Init");	
	RunScript("교실상자_4", "o_공상자.Init");
	RunScript("교실상자_5", "o_공상자.Init");
	RunScript("교실상자_7", "o_공상자.Init");
	RunScript("교실상자_9", "o_공상자.Init");
	RunScript("교실상자_11", "o_공상자.Init");
	RunScript("교실상자_12", "o_공상자.Init");	

	RunScript("야구공상자", "오브젝트_우_공상자.ReInit");
	RunScript("축구공상자", "오브젝트_우_공상자.ReInit");
	RunScript("농구공상자", "오브젝트_좌_공상자.ReInit");
	RunScript("배구공상자", "오브젝트_좌_공상자.ReInit");	
	
	SetTimer(0, "e_나무아랫쪽.before_event");
	SetTimer(0, "e_배전판.before_event");	
}

