Init1_1()
{
//	SendMessage("타이머", "스크립트설정", "0 0 1 대화#1-1.Talking");
	SendMessage("매크로", "Play", "old_talk1_1.cut01");
	DeleteObject("");	// EventArea
	$old_TalkingStep = 0;
}

old_talk1_2()
{
//	$TalkingStep = 0;
	SetValue("$old_TalkingStep", $old_TalkingStep <= 2 ? $old_TalkingStep + 1 : 1);
}

old_talk1_3()
{
	$old_TalkingStep = 0;
}

old_talk1_4()
{
//	$TalkingStep = 0;
	SetValue("$old_TalkingStep", $old_TalkingStep <= 1 ? $old_TalkingStep + 1 : 1);
}

