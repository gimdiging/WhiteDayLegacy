ShotUp()
{
	if($old_GameOver == TRUE)
		return;

	if($old_Mission4_나무 == OFF)
	{
//		SendMessage("사운드", "연주3d", GetObjPos("소영") + " data/sound/voice/" + (GetObjValue("ShotIndex") ? "d04_002.adp" : "d04_003.adp"));
		if(xz_distance(GetObjPos("유저"), GetObjPos("소영")) < 1000)
		{
			SendMessage("자막", "말하는사람", "소영");
			SendMessage("자막", "다이얼로그출력", "" + (GetObjValue("ShotIndex") ? "old_d04_002" : "old_d04_003"));
			SetObjValue("ShotIndex", !GetObjValue("ShotIndex"));
		}
		else
			SendMessage("자막", "말하는사람", "");
		SendMessage("타이머", "스크립트설정", "8 0 1 old_대화.ShotUp *obj 나무윗쪽");
	}
}

