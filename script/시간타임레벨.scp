_복구()
{
	$정전 = 0;
	SendMessage("배경", "켜기", "default");
	if($현재스테이지 == "본관1" || $현재스테이지 == "본관2" || $현재스테이지 == "신관")
	{
	if($AI_정찰용수위 == ON)
	SendMessage("렌턴_정찰용수위", "끄기", "");
	}

	if($현재스테이지 == "신관")
	{
	if($신관_세환_홀조명 == ON)
	{
	SendMessage("배경","켜기","hall");
	SendMessage("배경","켜기","center");
	SendMessage("배경","켜기","light1f");
	SendMessage("신관홀조명","발광","Box09 on");
	}
	SendMessage("1층홀천정등", "발광", "Recursive on");
	SendMessage("2층홀천정등", "발광", "Recursive on");
	SendMessage("3층홀천정등", "발광", "Recursive on");
	}
}