_시간타임체크()
{
	if($게임모드 == 0 || $게임모드 == 4)
		return;

	if($현재스테이지 != "본관1" && $현재스테이지 != "본관2" && $현재스테이지 != "신관")
		return;

	SendMessage("배경", "켜기", "default");
	if($정전 == 1)
	SetTimer(1,"시간타임레벨._정전");
	SetTimer(1,"시간타임레벨._시간타임레벨");
}

_시간타임레벨()
{
	$ALLTIME = GetTime("시간계산용");
	SetTimer(1,"시간타임레벨._시간타임레벨");

	if($ALLTIME > 600 && $시간현재레벨난이도 == 0)
	{
		$시간현재레벨난이도++;
		SetTimer(1,"시간타임레벨._정전");
		return;
	}
	if($ALLTIME > 900 && $시간현재레벨난이도 == 1)
	{
		$시간현재레벨난이도++;
		SetTimer(1,"시간타임레벨._복구");
		return;
	}
	if($ALLTIME > 2400 && $시간현재레벨난이도 == 2)
	{
		$시간현재레벨난이도++;
		SetTimer(1,"시간타임레벨._정전");
		return;
	}

	if($ALLTIME > 2700 && $시간현재레벨난이도 == 3)
	{
		$시간현재레벨난이도++;
		SetTimer(1,"시간타임레벨._복구");
		return;
	}

	if($ALLTIME > 4200 && $시간현재레벨난이도 == 4)
	{
		$시간현재레벨난이도++;
		SetTimer(1,"시간타임레벨._정전");
		return;
	}

	if($ALLTIME > 4500 && $시간현재레벨난이도 == 5)
	{
		$시간현재레벨난이도++;
		SetTimer(1,"시간타임레벨._복구");
		return;
	}

	if($ALLTIME > 6000 && $시간현재레벨난이도 == 6)
	{
		$시간현재레벨난이도++;
		SetTimer(1,"시간타임레벨._정전");
		return;
	}

	if($ALLTIME > 6300 && $시간현재레벨난이도 == 7)
	{
		$시간현재레벨난이도++;
		SetTimer(1,"시간타임레벨._복구");
		return;
	}

//	if($ALLTIME > 9000 && $시간현재레벨난이도 == 8)
//	{
//		$시간현재레벨난이도++;
//		SetTimer(1,"시간타임레벨._정전");
//		return;
//	}

//	if($ALLTIME > 10800 && $시간현재레벨난이도 == 9)
//	{
//		$시간현재레벨난이도++;
//		SetTimer(1,"시간타임레벨._복구");
//		return;
//	}
}
