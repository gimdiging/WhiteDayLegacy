_유저.test_3()
{		
	if($debug_info == 0)
	{
		SendMessage("은미", "캡춰", "카메라 머리");
		$chase_cam = 0;
		$debug_info = 1;
		SendMessage("허드", "디버그정보", "on");
		return;
	}

	$debug_info = 0;
	SendMessage("허드", "디버그정보", "off");
	SendMessage("유저", "캡춰", "카메라 머리");
}

_유저.test_4()
{		
	if($chase_cam == 0)
	{
		SendMessage("정찰용수위", "캡춰", "카메라 머리");
		$debug_info = 0;
		$chase_cam = 1;				
		if($Cam_Target != "");
			SendMessage("카메라", "추적카메라", "" + $Cam_Target);		
		return;
	}
	
	$chase_cam = 0;
	SendMessage("카메라", "쳐다보지말기", "");	
	SendMessage("유저", "캡춰", "카메라 머리");	
}

