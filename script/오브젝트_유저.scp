_유저._아이템사용()
{
	switch(	GetObjValue("GETITEMNAME"))
	{
		case "열쇠안뺀시디":
			SendMessage("유저", "획득", "열쇠뺀시디");
			SendMessage("가방", "아이템추가", "열쇠뺀시디 1");
			SendMessage("유저", "획득", "미술실열쇠");
			SendMessage("가방", "아이템추가", "미술실열쇠 1");
			break;

		case "지갑":
			SendMessage("유저", "획득", "동전 8");
			SendMessage("자막", "문자출력", "3," +  GetString("it_342"));
			/*SendMessage("유저", "획득", "@지갑");
			SendMessage("가방", "아이템추가", "지갑 1");
			if($G_UserItem == "동전")
			{
			SendMessage("유저", "폐기", "동전");
			SendMessage("자막", "문자출력", "1," + GetString("s932"));
			$지갑속동전++;
			if($G_UserItem != "동전")
			SendMessage("유저", "폐기", "지갑");
			}
			else if($G_UserItem != "동전" && $지갑속동전 > 0)
			{
			SendMessage("유저", "획득", "동전");
			SendMessage("자막", "문자출력", "1," + GetString("s933"));
			$지갑속동전--;
			}*/
			break;

		case "엠피맨" :
/*
			if ($CD_play == FALSE)
			{
				$CD_play = TRUE;
				LoadObject("WTune", "엠퓌맨", "");
			}	else
			{
				$CD_cnt++;
			}

			if ($CD_cnt > 6)
				$CD_cnt = 1;

			SendMessage("엠퓌맨", "연주", "data/mp3/audio_0" + $CD_cnt + ".mp3");
*/

			SendMessage("자막", "활성화", "");
			SendMessage("자막", "와이드모드", "켜기");
			SendMessage("자막", "실행함수", "오브젝트_유저._WMA");
			SendMessage("자막", "선택", "[이전]\n[재생]\n[다음]");
			return;

		case "구급상자":
			SendMessage("", "heal","100");
			SendMessage("허드", "더하기BPM", "-130");
			LoadObject("WObjPanel", "", "*diffuse 2cb2c2 *delay 2 *type 1");
			SendMessage("사운드", "연주", "data/sound/item/구급약.wav");
			$HP = 100;
			TextOut(GetString("it_94"));
			break;

		case "도시락":
			SendMessage("", "heal","70");
			SendMessage("허드", "더하기BPM", "-100");
			LoadObject("WObjPanel", "", "*diffuse 2c92c2 *delay 1.5 *type 1");
			SendMessage("사운드", "연주", "data/sound/item/두유_먹기.wav");
			$HP = Min($HP + 70, 100);
			TextOut(GetString("it_329"));
			break;

		case "콩의눈":
			SendMessage("", "heal","35");
			SendMessage("허드", "더하기BPM", "-70");
			LoadObject("WObjPanel", "", "*diffuse 2c80c2 *delay 0.6 *type 1");
			SendMessage("사운드", "연주", "data/sound/item/두유_먹기.wav");
			$HP = Min($HP + 35, 100);
			TextOut(GetString("it_334"));
			break;

		case "캔커피":
			SendMessage("", "heal","50");
			LoadObject("WObjPanel", "", "*diffuse 2c60c2 *delay 0.6 *type 1");
			SendMessage("허드", "더하기BPM", "50");
			SendMessage("사운드", "연주", "data/sound/item/캔커피_먹기.wav");
			$신관_세환_캔커피소지--;			
			$HP = Min($HP + 50, 100);
			TextOut(GetString("it_339"));
			break;

		case "캔코피":
			SendMessage("", "heal","15");
			LoadObject("WObjPanel", "", "*diffuse 2c60c2 *delay 0.6 *type 1");
			SendMessage("허드", "더하기BPM", "15");
			SendMessage("사운드", "연주", "data/sound/item/캔커피.wav");			
			$HP = Min($HP + 15, 100);
			TextOut(GetString("it_934"));
			break;

		case "모기약":
			$본관1_세환_모기약사용 = ON;
			TextOut(GetString("s211"));
			LoadObject("WObjPanel", "", "*diffuse 2c92c2 *delay 2 *type 1");
			SendMessage("사운드", "연주", "data/sound/item/모기약.wav");
			SendMessage("허드", "더하기BPM", "-130");
			break;

		case "반창고":
			SendMessage("", "heal","50");
			SendMessage("허드", "더하기BPM", "-45");
			LoadObject("WObjPanel", "", "*diffuse 2c92c2 *delay 1.5 *type 1");
			SendMessage("사운드", "연주", "data/sound/item/반창고.wav");	//data/sound/item/도시락.wav
			$HP = Min($HP + 50, 100);
			TextOut(GetString("it_254"));
			break;

		case "드링크":
			SendMessage("", "heal","25");
			SendMessage("허드", "더하기BPM", "-100");
			LoadObject("WObjPanel", "", "*diffuse 2c92c2 *delay 1.5 *type 1");
			SendMessage("사운드", "연주", "data/sound/item/음료수_먹기.wav");
			$HP = Min($HP + 25, 100);
			TextOut(GetString("it_309"));
			break;

		case "게임설정":
			SendMessage("자막", "활성화", "" );
			SendMessage("자막", "와이드모드", "켜기");
			SendMessage("자막", "실행함수", "오브젝트_유저.gameoption");
			SendMessage("자막", "선택", GetString("s934"));
			SendMessage("유저", "획득", "@게임설정");
			break;
	}

	SendMessage("유저", "시끄러워", "0");
	SendMessage("main", "캐쉬초기화", "");
}

_WMA()
{
	SendMessage("자막", "와이드모드", "끄기");
	SendMessage("자막", "비활성", "");

	if($G_UserSelect == 0)
	{
		if ($CD_play == TRUE)
		{
		$CD_cnt--;
		if ($CD_cnt < 1)
			$CD_cnt = 6;

		SendMessage("엠퓌맨", "연주", "data/mp3/audio_0" + $CD_cnt + ".mp3");
		TextOut("" + $CD_cnt);
		}
	}

	if($G_UserSelect == 1)
	{
		if ($CD_play == FALSE)
		{
		$CD_play = TRUE;
		LoadObject("WTune", "엠퓌맨", "");
		SendMessage("엠퓌맨", "연주", "data/mp3/audio_0" + $CD_cnt + ".mp3");
		TextOut("" + $CD_cnt);
		}
		else
		{
		$CD_play = FALSE;
		DeleteObject("엠퓌맨");
		}
	}

	if($G_UserSelect == 2)
	{
		if ($CD_play == TRUE)
		{
		$CD_cnt++;
		if ($CD_cnt > 6)
			$CD_cnt = 1;

		SendMessage("엠퓌맨", "연주", "data/mp3/audio_0" + $CD_cnt + ".mp3");
		TextOut("" + $CD_cnt);
		}
	}
}

_유저._유저함수()
{
	switch(GetObjValue("장비중아이템"))
	{
		case "성냥" :
		{
			if (GetObjValue("MotionName") != "달리기")
			{
				SendMessage("장비형성냥", "이동속도", "1.0");
//				TextOut("불적당히..");
			}	else
			{
				SendMessage("장비형성냥", "이동속도", "5.0");
//				TextOut("조심해불..");
			}
			SendMessage("유저", "사용자함수", "움직일때");
			return;
		}

		case "양초" :
		{
			if (GetObjValue("MotionName") == "달리기")
			{
			SendMessage("사운드", "연주", "data/sound/item/양초놓는소리.wav");
			SendMessage("유저", "아이템장비취소", "");
			}
			SendMessage("유저", "사용자함수", "움직일때");
			return;
		}

		case "흰색장갑" :
		{
			if (GetObjValue("MotionName") == "서있기" || GetObjValue("MotionName") == "앉기")
			{
				SendMessage("유저", "사용자함수", "움직일때");
				SendMessage("똥침장갑", "스케일", "0");
			}	else
			{
				SendMessage("유저", "사용자함수", "서있을때");
				SendMessage("똥침장갑", "스케일", "1.0");
			}
		}

		case "라이터" :
		{
			if (GetObjValue("MotionName") == "서있기" || GetObjValue("MotionName") == "앉기")
			{
				SendMessage("유저", "사용자함수", "움직일때");
				SendMessage("장비형라이터", "스케일", "1.0");
//				TextOut("불적당히..");
			}	else
			{
				SendMessage("유저", "사용자함수", "서있을때");
				SendMessage("장비형라이터", "스케일", "0.5");
//				TextOut("조심해불..");
			}
			return;
		}
		case "전기충격기" :
		{
			if (GetObjValue("MotionName") == "서있기" || GetObjValue("MotionName") == "앉기")
			{
				SendMessage("유저", "사용자함수", "움직일때");
				SendMessage("장비형전기충격기", "스케일", "0");
			}	else
			{
				SendMessage("유저", "사용자함수", "서있을때");
				SendMessage("장비형전기충격기", "스케일", "1.0");
			}
			return;
		}
		case "스프레이" :
		{
			if (GetObjValue("MotionName") == "서있기" || GetObjValue("MotionName") == "앉기")
			{
				SendMessage("유저", "사용자함수", "움직일때");
				SendMessage("장비형스프레이", "스케일", "0");
			}	else
			{
				SendMessage("유저", "사용자함수", "서있을때");
				SendMessage("장비형스프레이", "스케일", "1.0");
			}
			return;
		}
	}
}

_유저._카메라변환()
{
	if (GetObjValue("뷰") == "3인칭뷰")
	{
		if (GetObjValue("장비중아이템") != "")
		{
			SetObjValue("GETITEMNAME", GetObjValue("장비중아이템"));
			SetTimer(0, "오브젝트_유저._유저._아이템장비취소");
		}	else
			SetObjValue("GETITEMNAME", "");
	}	else
	{
		if (GetObjValue("GETITEMNAME") != "")
			SetTimer(0, "오브젝트_유저._유저._아이템장비");
	}
}

_유저._아이템획득()
{
	switch(	GetObjValue("GETITEMNAME"))
	{
		case "포즈":
			LoadObject("WObjPause", "포즈", "");
			break;
		case "나침반":
			SendMessage("허드", "나침반얻기", "");
			//	SendMessage("허드", "뱅뱅돌기", "");
			break;
		case "허드":
			LoadObject("WObjIndicator", "허드", "");
			SendMessage("허드", "켜기", "");
			break;

		case "다이어리":
			LoadObject("WObjDiary", "다이어리", "");
			break;

		case "지도":
			LoadObject("WObjMap", "지도", "");
			break;

		case "본관1지도":
			SendMessage("지도", "맵획득", "0");
			break;

		case "본관2지도":
			SendMessage("지도", "맵획득", "1");
			break;

		case "신관지도":
			SendMessage("지도", "맵획득", "2");
			break;

		case "강당지도":
			SendMessage("지도", "맵획득", "3");
			break;

		case "콜렉트":
		// 백에 통합되었다고함
		//	LoadObject("WObjPuzzle", "콜렉트", "data/ini/iconPuzzle.ini data/ini/rectPuzzle.ini");
			break;

		case "핸드폰":
			LoadObject("WObjHandphone", "핸드폰", "data/ini/sms.ini data/ini/icon.ini data/ini/rect.ini data/ini/color.ini data/misc/돋음12.fnt");
			break;

		case "가방":
			LoadObject("WObjBag", "가방", "data/ini/icon.ini data/ini/rect.ini data/misc/돋음12.fnt data/misc/aa견고딕18.wft");
			break;
		
		case "도움말상자":
//			LoadObject("WObjHelp", "도움말상자", "data/ini/iconHelp.ini data/ini/rectHelp.ini data/ini/help.ini data/misc/돋음12.fnt data/misc/aa견고딕18.wft");
			break;		
	}
}

_유저._아이템폐기()
{
	switch(	GetObjValue("GETITEMNAME"))
	{
		case "포즈":
			DeleteObject("포즈");
			break;

		case "허드":
			DeleteObject("허드");
			return;

		case "다이어리":
			DeleteObject("다이어리");
			break;

		case "지도":
			DeleteObject("지도");
			break;

		case "핸드폰":
			DeleteObject("핸드폰");
			break;

		case "가방":
			DeleteObject("가방");
			return;
		
		case "야광스틱":
			DeleteObject("야광스틱");
			break;
	}

	SendMessage("가방", "가방리세트", "");
	SendMessage("허드", "선택아이템", "NULL");
}

_유저._인벤토리끄기()
{
	SendMessage(GetObjValue("인벤토리"), "끄기", "");
	if($캠코더 == 1)
	SetTimer(0.1, "오브젝트_유저._캠코더");
	SendMessage("허드", "켜기");
	SetObjValue("인벤토리", "");

//	if ($CD_play == TRUE)
//	{
//		$CD_play = FALSE;
//		DeleteObject("엠퓌맨");
//	}

	// 0 이지모드 , 1 노말모드, 2 하드모드, 3 왕리얼모드, 4 왕이지모드
	
	if($게임모드 == 4)
	{
		SendMessage("main", "게임시작","다시");
	}
}

_유저._다이어리()
{
	SendMessage("다이어리", "켜기", "");
	SetObjValue("인벤토리", "다이어리");
	SendMessage("허드", "끄기");
	if($게임모드 == 4)
	{
		SendMessage("main", "게임시작","멈춤");
	}
}

_유저._지도()
{
	if (GetObjPosY("유저") > 400.0 || $본2워프지도표시불가 == 1)
	{
		TextOut(GetString("s212"));
		return;
	}

	SendMessage("지도", "켜기", "");
	SetObjValue("인벤토리", "지도");
	SendMessage("허드", "끄기");
	if($게임모드 == 4)
	{
		SendMessage("main", "게임시작","멈춤");
	}
}

_유저._핸펀_그림조각()
{
	SendMessage("핸드폰", "켜기", "");
	SetObjValue("인벤토리", "핸드폰");
	SendMessage("허드", "끄기");
	if($게임모드 == 4)
	{
		SendMessage("main", "게임시작","멈춤");
	}
}

_유저._인벤토리()
{
	if (GetObjValue("인벤토리") == "가방")
		return;

	SendMessage("가방", "켜기", "");
	SendMessage("유저", "세트허드헬쓰", "");
	SetObjValue("인벤토리", "가방");
	SendMessage("허드", "끄기");

//	TextOut("인벤토리");
	if($게임모드 == 4)
	{
		SendMessage("main", "게임시작","멈춤");
	}
}

_유저._ESC()
{
	SendMessage("포즈", "켜기");

}

_유저._패닉on()
{
	$b_심장발작초 = 1;
	SetTimer(0,"오브젝트_유저._패닉으로인한사망");

	if($현재스테이지 == "본관2" && $본2_영호_아기발동중 == 0)
		SendMessage("해부마네킹", "쫓아가라","유저 팔올리기");
}

_유저._패닉off()
{
	$b_심장발작초 = 0;

	if($현재스테이지 == "본관2" && $본2_영호_아기발동중 == 0)
	{
		SendMessage("해부마네킹", "Stop","");
		SendMessage("해부마네킹", "애니메이션","서있기");
		SendMessage("해부마네킹", "좋은위치", "" + FindPoint("해부마네킹위치"));
		SendMessage("해부마네킹", "회전", "90");
	}
}

_패닉으로인한사망()
{
	if($b_심장발작초 > 0)
	{
		$b_심장발작초++;
		SetTimer(1,"오브젝트_유저._패닉으로인한사망");
	}
	if($b_심장발작초 > 16 && $매크로가동중 == 0 && GetObjValue("MotionName") == "달리기" || GetObjValue("MotionName") == "걷기")
	{
		$b_심장발작초 = 0;
		$GameOverMode = 7;
		RunScript("", "오브젝트_유저._유저.dead");
	}
}

