_희민움직임동작()
{
	if($유저맘선택권 == 1)
	{
		SendMessage("카메라", "카메라떨림", "0 0 0.1");
		if(GetObjValue("MotionName") == "걷기" && $상하로흔들어 == 0)
		{
			SendMessage("카메라", "카메라떨림", "15 0.5 0.5");
			$상하로흔들어 = 1;
			SetTimer(0.5, "오브젝트_유저._희민움직임동작");
			return;
		}
		if(GetObjValue("MotionName") == "걷기" && $상하로흔들어 == 1)
		{
			SendMessage("카메라", "카메라떨림", "15 -0.5 0.5");
			$상하로흔들어 = 0;
			SetTimer(0.5, "오브젝트_유저._희민움직임동작");
			return;
		}
		if(GetObjValue("MotionName") == "달리기" && $상하로흔들어 == 0)
		{
			SendMessage("카메라", "카메라떨림", "15 0.5 0.2");
			$상하로흔들어 = 1;
			SetTimer(0.2, "오브젝트_유저._희민움직임동작");
			return;
		}
		if(GetObjValue("MotionName") == "달리기" && $상하로흔들어 == 1)
		{
			SendMessage("카메라", "카메라떨림", "15 -0.5 0.2");
			$상하로흔들어 = 0;
			SetTimer(0.2, "오브젝트_유저._희민움직임동작");
			return;
		}
		SetTimer(0.1, "오브젝트_유저._희민움직임동작");
	}
	else if($유저맘선택권 == 2)
	{
		SendMessage("카메라", "카메라비틀기", "0 0 0.1");
		if(GetObjValue("MotionName") == "걷기" && $좌우로흔들어 == 0)
		{
			SendMessage("카메라", "카메라비틀기", "0 -1.5 0.5");
			$좌우로흔들어 = 1;
			SetTimer(0.5, "오브젝트_유저._희민움직임동작");
			return;
		}
		if(GetObjValue("MotionName") == "걷기" && $좌우로흔들어 == 1)
		{
			SendMessage("카메라", "카메라비틀기", "0 1.5 0.5");
			$좌우로흔들어 = 0;
			SetTimer(0.5, "오브젝트_유저._희민움직임동작");
			return;
		}
		if(GetObjValue("MotionName") == "달리기" && $좌우로흔들어 == 0)
		{
			SendMessage("카메라", "카메라비틀기", "0 -1.5 0.2");
			$좌우로흔들어 = 1;
			SetTimer(0.2, "오브젝트_유저._희민움직임동작");
			return;
		}
		if(GetObjValue("MotionName") == "달리기" && $좌우로흔들어 == 1)
		{
			SendMessage("카메라", "카메라비틀기", "0 1.5 0.2");
			$좌우로흔들어 = 0;
			SetTimer(0.2, "오브젝트_유저._희민움직임동작");
			return;
		}
		SetTimer(0.1, "오브젝트_유저._희민움직임동작");
	}
}

