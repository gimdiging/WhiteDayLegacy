gameoption()
{
	SendMessage("자막", "비활성", "" );
	SendMessage("자막", "와이드모드", "끄기");
	if($G_UserSelect == 0)
	{
	if($DIE == 0)
		{
		$DIE = 1;
		SetTimer(0.1, "_무적");
		TextOut(GetString("s935"));
		}
		else
		{
		$DIE = 0;
		TextOut(GetString("s936"));
		}
	return;
	}
	else if($G_UserSelect == 1)
	{
		if($진행루트 == 0)
		{
		$진행루트 = 1;
		TextOut(GetString("s937"));
		}
		else
		{
		$진행루트 = 0;
		TextOut(GetString("s938"));
		}
	return;
	}
	else if($G_UserSelect == 2)
	{
		if($지현_호감도 < 5 || $성아_호감도 < 11 || $소영_호감도 < 11)
		{
		$소영_호감도 = 20;		
		$지현_호감도 = 20;		
		$성아_호감도 = 20;
		TextOut(GetString("s939"));
		}
		else
		{
		$소영_호감도 = 0;		
		$지현_호감도 = 0;		
		$성아_호감도 = 0;
		TextOut(GetString("s940"));
		}
	return;
	} 
	break;
}

_무적() 
{
	if($DIE == 1)
	{
	SendMessage("유저", "heal", "100");
	SendMessage("허드", "더하기BPM", "-100");
	SetTimer(0.1, "_무적");
	}
}

_캠코더()
{
	SendMessage("허드", "끄기", "프로세스");
}

_야광스틱()
{
	if($유저_조명아이템장비 == FALSE)
		return;

	if($야광스틱 == 9)
	{
		SendMessage("유저", "아이템장비취소", "");
		return;
	}

	if(GetObjValue("MotionName") == "달리기" && $야광스틱 > 4)
	{
		SetTimer(1, "오브젝트_유저._유저._아이템장비취소");
		return;
	}

	$야광스틱++;
	SetTimer(1,"_야광스틱");
}

_깨진태극패()
{
	if($유저_조명아이템장비 == FALSE)
		return;

	if($깨진태극패 == 4)
	{
		SendMessage("유저", "아이템장비취소", "");
		return;
	}

	$깨진태극패++;
	SetTimer(1,"_깨진태극패");
}

_소화기D()
{
	if($소화기변수 == 0)
		return;

	if(xz_distance(GetObjPos("유저"), GetObjPos("더미8")) < 200 && $현재스테이지 == "강당")
	SendMessage("유저", "픽금지", "off");
	else
	SendMessage("유저", "픽금지", "on");

	SetTimer(0.1,"_소화기D");
}

