_유저.StartUp()
{
	SetObjValue("장비대기", "");
	SetObjValue("장비중아이템", "");
	SetObjValue("마지막장비아이템", "");
	SetObjValue("enemy", "Not Yet");	
//	SetRegistry("Option\Bright", "0.108696");

	if (GetRegistry("Option\CustomGameSpeed") != "")
	SendMessage("main", "게임속도", "" + GetRegistry("Option\CustomGameSpeed"));

	if($DIE == 1)
	SetTimer(0.1, "오브젝트_유저._무적");

	if($게임처음시작 == FALSE)
	{
		SetTimer(1, "형체있는인간._형체있는인간3");	
		RunScript("유저", "오브젝트_유저._희민움직임동작");	

		if($현재스테이지 == "본관1" || $현재스테이지 == "본관2")
			SetTimer(1, "캐릭터_수위._수위지능판단0");

		if($현재스테이지 == "본관1" || $현재스테이지 == "본관2" || $현재스테이지 == "신관")
		{
			if($게임모드 != 0 && $게임모드 != 4)
			{
				SetTimer(0,"e_2d귀신._본관귀신날려");
				SetTimer(1,"e_2d귀신._본관귀신");
				SetTimer(1, "e_2d귀신._1분후에머리귀신살아라");
			}
			SetTimer(1,"시간타임레벨._시간타임체크");
			SetTimer(0.1, "o_양동이._양동이사운드");
		}	
	}
}

//
//	장비장착관련

_유저._아이템장비()
{
	if (GetObjValue("장비상태") != "") // 장비대기 중입니다
		return;

	SetObjValue("장비상태", "장비");
	SetObjValue("장비중아이템", GetObjValue("GETITEMNAME"));
	SetObjValue("마지막장비아이템", GetObjValue("장비중아이템"));
	SendMessage("허드", "장비때플립온", "");
	SendMessage("유저", "현재장비아이템요청", GetObjValue("GETITEMNAME")); // 장비했어요	

	switch(GetObjValue("장비중아이템"))
	{
		case "성냥" :
			$밝기이름 = "성냥이";
			if($i_성냥갯수 < 1)
			{
				$i_성냥갯수 = -1;
				TextOut($밝기이름+" "+GetString("s918"));
				SendMessage("유저", "아이템장비", "취소");
				return;
			}
			if($게임모드 != 0 && $게임모드 != 4)
			{
			$i_성냥갯수--;
			TextOut($밝기이름+" "+$i_성냥갯수+""+GetString("s917"));
			}
			SendMessage("자막", "오버레이바탕검정", "켜기");
			LoadObject("WObjEquip", "장비형성냥", "*puppet data/puppet/item/i_장비형성냥.pet *성냥 *pivot *randommove");
			SendMessage("유저", "사용자함수", "움직일때");
			SendMessage("장비형성냥", "애니메이션", "일반");
			SendMessage("사운드", "연주", "data/sound/item/성냥.wav");			

			if (GetObjValue("MotionName") != "달리기")
				SendMessage("장비형성냥", "이동속도", "1.0");
			else
				SendMessage("장비형성냥", "이동속도", "5.0");
			break;

		case "흰색장갑" :
			LoadObject("WObjEquip", "똥침장갑", "*puppet i_장비형똥침공격.pet *randommove *scale 0.8 *똥침");
			SendMessage("유저", "픽금지", "on");
			$똥침장갑 = TRUE;
			SendMessage("똥침장갑", "이동속도", "2.0");
			SendMessage("똥침장갑", "애니메이션", "사용");
			SendMessage("유저", "사용자함수", "움직일때");
			SendMessage("유저", "사용자함수", "서있을때");
			break;

		case "라이터" :
			$밝기이름 = "가스가";
			if($i_라이터가스 < 1)
			{
				$i_라이터가스 = -1;
				TextOut($밝기이름+" "+GetString("s916"));
				SendMessage("유저", "아이템장비", "취소");
				SendMessage("유저", "아이템장비취소", "");
				return;
			}
			if($게임모드 != 0 && $게임모드 != 4)
			{
				if($i_라이터가스 < 801)
					TextOut($밝기이름+" "+GetString("s913"));
				if($i_라이터가스 < 500)
					TextOut($밝기이름+" "+GetString("s914"));
				if($i_라이터가스 < 200)
					TextOut($밝기이름+" "+GetString("s915"));

				SetTimer(1,"오브젝트_유저._라이터");
			}
			SendMessage("자막", "오버레이바탕검정", "켜기");
			LoadObject("WObjEquip", "장비형라이터", "*puppet data/puppet/item/i_장비형라이터.pet *scale 1.2 *randommove");
			SendMessage("유저", "사용자함수", "움직일때");
			SendMessage("유저", "사용자함수", "서있을때");
			SendMessage("사운드", "연주", "data/sound/item/지포라이터_열기.wav");
			$유저_조명아이템장비 = TRUE;
			break;

		case "다우징" :
			LoadObject("WObjEquip", "장비형다우징", "*puppet data/puppet/item/i_장비형l자스틱.pet *다우징 *pivot *randommove *area 440.89 216.27 473.19 1500.58 465.08 1272.06");
			SendMessage("유저", "픽금지", "on");
			break;

		case "렌턴" :
			$밝기이름 = "건전지가";
			if($i_렌턴건전지 < 1)
			{
				$i_렌턴건전지 = -1;
				TextOut($밝기이름+" "+GetString("s916"));
				SendMessage("유저", "아이템장비", "취소");
				SendMessage("유저", "아이템장비취소", "");
				return;
			}
			if($게임모드 != 0 && $게임모드 != 4)
			{
				if($i_렌턴건전지 < 1001)
					TextOut($밝기이름+" "+GetString("s913"));
				if($i_렌턴건전지 < 600)
					TextOut($밝기이름+" "+GetString("s914"));
				if($i_렌턴건전지 < 200)
					TextOut($밝기이름+" "+GetString("s915"));

				SetTimer(1,"오브젝트_유저._렌턴");
			}
			SendMessage("허드", "오버레이바탕검정", "켜기");
			LoadObject("WObjEquip", "장비형렌턴", "*puppet data/puppet/item/i_장비형플래시.pet *플래시 *scale 0.15 *randommove");
			$유저_조명아이템장비 = TRUE;
			SendMessage("사운드", "연주", "data/sound/item/손전등.wav");
			break;

		case "태극패" :
			if($음악감상실귀신진행 != 1)
			LoadObject("WObjEquip", "장비형태극패", "*puppet data/puppet/item/i_장비형태극패.pet *태극패 *scale 3.0 *randommove");
			else
			{
			LoadObject("WObjEquip", "장비형태극패", "*puppet data/puppet/item/i_장비형태극패.pet *scale 3.0 *randommove");
			LoadObject("WObjEquip", "장비형렌턴", "*puppet data/puppet/item/i_장비형플래시.pet *플래시 *scale 0.00000000001 *randommove");
			$태극패 = 1;
			$깨진태극패 = 0;
			SetTimer(0, "_깨진태극패");
			$유저_조명아이템장비 = TRUE;
			}
			break;

		case "깨진태극패" :
			LoadObject("WObjEquip", "장비형태극패", "*puppet data/puppet/item/i_장비형태극패.pet *scale 3.0 *randommove");
			break;

		case "스프레이" :
			LoadObject("WObjEquip", "장비형스프레이", "*puppet data/puppet/item/i_장비형스프레이.pet *randommove *scale 1.8 *똥침");
//			SendMessage("사운드", "연주", "data/sound/item/호신용_스프레이.wav");
			SendMessage("장비형스프레이", "이동속도", "3.0");
			SendMessage("장비형스프레이", "애니메이션", "사용");
			SendMessage("유저", "사용자함수", "움직일때");
			SendMessage("유저", "사용자함수", "서있을때");
			if (GetObjValue("장비대기") == "")
			{
			SetObjValue("장비대기", "스프레이");
			SendMessage("유저", "아이템장비", "취소");
			SendMessage("유저", "아이템장비", "스프레이");
			}
			break;

		case "수위변장키트" :
			if($수위추적모드 == OFF)
			{
			$밝기이름 = "부적의 기운이";
			if($i_수위변장시간 < 1)
			{
				$i_수위변장시간 = -1;
				TextOut($밝기이름+" "+GetString("s916"));
				SendMessage("유저", "아이템장비", "취소");
				SendMessage("유저", "아이템장비취소", "");
				return;
			}
			if($게임모드 != 0 && $게임모드 != 4)
			{
				if($i_수위변장시간 < 301)
					TextOut($밝기이름+" "+GetString("s913"));
				if($i_수위변장시간 < 200)
					TextOut($밝기이름+" "+GetString("s914"));
				if($i_수위변장시간 < 100)
					TextOut($밝기이름+" "+GetString("s915"));

				SetTimer(1,"오브젝트_유저._수위변장키트");
			}
			LoadObject("WObjEquip", "장비형변장키트", "*puppet data/puppet/item/i_장비형변장키트.pet *플래시 *scale 0.8 *randommove");
			SendMessage("사운드", "연주", "data/sound/item/수위변장키트.wav");
			$수위변장 = 1;
			LoadObject("WObjFlash", "후라시", "");
			SendMessage("후라시", "켜기");
			SendMessage("유저", "캡춰", "후라시 손");
			SendMessage("유저", "픽금지", "on");
			}
			else
			{
			$밝기이름 = "부적이";
			if($i_수위부적갯수 < 1)
			{
				$i_수위부적갯수 = -1;
				TextOut($밝기이름+" "+GetString("s918"));
				SendMessage("유저", "아이템장비", "취소");
				return;
			}
			SendMessage("사운드", "연주", "data/sound/도플_기모으기.wav");
			SendMessage("카메라", "fov", "25");
			SendMessage("배경", "bspmode", "6");
			SendMessage("유저", "픽금지", "on");
			}
			break;

		case "전기충격기" :
			LoadObject("WObjEquip", "장비형전기충격기", "*puppet data/puppet/item/i_장비형전기충격기.pet *randommove *scale 2.0 *똥침");
			SendMessage("장비형전기충격기", "이동속도", "4.0");
			SendMessage("장비형전기충격기", "애니메이션", "사용");
			SendMessage("유저", "사용자함수", "움직일때");
			SendMessage("유저", "사용자함수", "서있을때");
			break;

		case "소화기A" :
			$소화기변수 = 1 ;
			SendMessage("허드", "오버레이바탕검정", "켜기");
			SendMessage("자막", "오버레이바탕검정", "켜기");
			SendMessage( "허드", "픽유니트", "소화기A");
			LoadObject("WObjEquip", "불장수", "*puppet data/puppet/item/i_장비형소화기.pet *pivot *randommove *scale 0.70 *소화기 *sfx 소화기a.wav *atktime 1.6");
			break;

		case "소화기B" :
			$소화기변수 = 2 ;
			SendMessage("허드", "오버레이바탕검정", "켜기");
			SendMessage("자막", "오버레이바탕검정", "켜기");
			SendMessage( "허드", "픽유니트", "소화기B");
			LoadObject("WObjEquip", "불장수", "*puppet data/puppet/item/i_장비형소화기.pet *pivot *randommove *scale 0.70 *소화기 *sfx 소화기b.wav *atktime 3.6");
			break;

		case "소화기C" :
			SendMessage("허드", "오버레이바탕검정", "켜기");
			SendMessage("자막", "오버레이바탕검정", "켜기");
			SendMessage( "허드", "픽유니트", "소화기C");
			$소화기변수 = 3 ;
			LoadObject("WObjEquip", "불장수", "*puppet data/puppet/item/i_장비형소화기.pet *pivot *randommove *scale 0.70 *소화기 *sfx 소화기c.wav *atktime 4.4");
			break;

		case "소화기D" :
			SendMessage("허드", "오버레이바탕검정", "켜기");
			SendMessage("자막", "오버레이바탕검정", "켜기");
			LoadObject("WObjEquip", "불장수", "*puppet data/puppet/item/i_장비형소화기.pet *pivot *randommove *scale 0.70 *소화기 *sfx 소화기d.wav *atktime 1.6");
			$소화기변수 = 4 ;
			SendMessage("유저", "픽금지", "on");
			SetTimer(0.1, "오브젝트_유저._소화기D");
			break;

		case "특수장비" :
			LoadObject("WObjEquip", "장비형라이터", "*puppet data/puppet/item/i_장비형라이터.pet *scale 1.2 *randommove");
			LoadObject("WObjEquip", "장비형렌턴", "*puppet data/puppet/item/i_장비형플래시.pet *플래시 *scale 0.15 *randommove");
			SendMessage("자막", "오버레이바탕검정", "켜기");
			SendMessage("배경", "bspmode", "1");
			break;

		case "야광스틱" :
			if($Item_야광스틱충전 == FALSE)
			{
			$야광스틱 = 1;
			LoadObject("WObjEquip", "장비형야광스틱", "*puppet data/puppet/item/아이템_야광봉.pet *scale 0.10 *randommove");
			}
			else
			{
			$밝기이름 = "야광봉이";
			if($i_야광스틱갯수 < 1)
			{
				$i_야광스틱갯수 = -1;
				TextOut($밝기이름+" "+GetString("s918"));
				SendMessage("유저", "아이템장비", "취소");
				return;
			}
			if($게임모드 != 0 && $게임모드 != 4)
			{
			$i_야광스틱갯수--;
			TextOut($밝기이름+" "+$i_야광스틱갯수+""+GetString("s917"));
			}
			LoadObject("WObjEquip", "장비형야광스틱", "*puppet data/puppet/item/아이템_야광봉.pet *플래시 *scale 0.10 *randommove");
			SendMessage("유저", "사용자함수", "움직일때");
			SendMessage("유저", "사용자함수", "서있을때");
			$유저_조명아이템장비 = TRUE;
			$야광스틱 = 0;
			SetTimer(0,"_야광스틱");
			}
			break;

		case "캠코더" :
			if($캠코더배터리 < 10)
			{
			SendMessage("유저", "아이템장비취소", "");
			return;
			}
			LoadObject("WObjCctvmode", "Camcorder", "");
			SendMessage("Camcorder","켜기","cctv,Camcorder");
			SendMessage("배경", "bspmode", "6");
			SendMessage("배경", "bspmode", "60");
			SendMessage("유저", "픽금지", "on");
			$캠코더 = 1;
			SetTimer(0.1, "오브젝트_유저._캠코더");
			SetTimer(0,"_캠코더ON");
			break;

		case "석판" :
			if($석판 == 0)
			SendMessage("배경", "bspmode", "1");
			else if($석판 == 1)
			SendMessage("배경", "bspmode", "2");
			else if($석판 == 2)
			SendMessage("배경", "bspmode", "3");
			else if($석판 == 3)
			{
			SendMessage("배경", "bspmode", "3");
			SendMessage("배경", "bspmode", "30");
			}
			else if($석판 == 4)
			SendMessage("배경", "bspmode", "4");
			else if($석판 == 5)
			SendMessage("배경", "bspmode", "5");
			else if($석판 == 6)
			{
			SendMessage("배경", "bspmode", "5");
			SendMessage("배경", "bspmode", "50");
			}
			else if($석판 == 7)
			SendMessage("배경", "bspmode", "6");
			else if($석판 == 8)
			{
			SendMessage("배경", "bspmode", "6");
			SendMessage("배경", "bspmode", "60");
			}
			SendMessage("유저", "픽금지", "on");
			break;

		case "양초" :
			SendMessage("사운드", "연주", "data/sound/item/성냥.wav");
			$유저_조명아이템장비 = TRUE;
			LoadObject("WObjEquip", "장비형라이터", "*puppet data/puppet/item/i_장비형라이터.pet *scale 0.00000000001 *randommove");
			LoadObject("WObjEquip", "장비형양초", "*puppet data/puppet/item/i_초.pet *scale 0.05 *randommove");
			SendMessage("유저", "사용자함수", "움직일때");
			if(GetObjValue("MotionName") == "달리기")
			{
			SendMessage("사운드", "연주", "data/sound/item/양초놓는소리.wav");
			SendMessage("유저", "아이템장비취소", "");
			}
			break;

		case "소방용도끼" :
			$소방용도끼 = 1;
			LoadObject("WObjEquip", "장비형도끼", "*puppet data/puppet/item/아이템_도끼선날.pet *scale 0.3 *pivot *randommove");
			break;

		case "도끼" :
			LoadObject("WObjEquip", "장비형도끼", "*puppet data/puppet/item/아이템_도끼안선날.pet *scale 0.3 *pivot *randommove");
			break;

		case "배냇저고리" :
			SendMessage("사운드", "연주", "data/sound/item/수위변장키트.wav");
			$배냇저고리 = 1;
			break;
	}

	if($신관_세환_은미이벤트 == 0)	
		RunScript("정찰용수위", "캐릭터_수위._발견조건");				

	SendMessage("유저", "시끄러워", "0");
}

_유저._아이템장비취소()
{
//	if (GetObjValue("장비상태") == "해제")
//	{
//		TextOut("장비해제중입니다");
//		return;
//	}

	if (GetObjValue("장비상태") == "")
		return;

//	SetObjValue("장비상태", "해제");
	SendMessage("허드", "장비때플립오프", "");
	SendMessage("유저", "현재장비아이템요청", "");
	SetObjValue("장비상태", "");

	switch(GetObjValue("장비중아이템"))
	{
		case "성냥" :
			if($i_성냥갯수 == -1)
				return;
			SendMessage("자막", "오버레이바탕검정", "끄기");
			DeleteObject("장비형성냥");
			$유저_조명아이템장비 = FALSE;
			break;

		case "흰색장갑" :
			SendMessage("유저", "픽금지", "off");
			$똥침장갑 = FALSE;
			DeleteObject("똥침장갑");
			break;

		case "라이터" :
			if($i_라이터가스 == -1)
				return;
			SendMessage("자막", "오버레이바탕검정", "끄기");
			DeleteObject("장비형라이터");
			$유저_조명아이템장비 = FALSE;
			SendMessage("사운드", "연주", "data/sound/item/지포라이터_닫기.wav");
			break;

		case "태극패" :
			if($음악감상실귀신진행 == 1)
			{
			DeleteObject("장비형렌턴");
			$유저_조명아이템장비 = FALSE;
			$태극패 = 0;
			}
			DeleteObject("장비형태극패");
			break;


		case "깨진태극패" :
			DeleteObject("장비형태극패");
			break;

		case "다우징" :
			SendMessage("유저", "픽금지", "off");
			DeleteObject("장비형다우징");
			break;

		case "렌턴" :
			if($i_렌턴건전지 == -1)
				return;
			SendMessage("허드", "오버레이바탕검정", "끄기");
			DeleteObject("장비형렌턴");
			$유저_조명아이템장비 = FALSE;
			break;

		case "스프레이" :
			DeleteObject("장비형스프레이");
			DeleteObject("탱탱볼");
			break;

		case "특수장비" :
			DeleteObject("장비형라이터");
			DeleteObject("장비형렌턴");
			SendMessage("자막", "오버레이바탕검정", "끄기");
			SendMessage("배경", "bspmode", "0");
			break;

		case "소화기A" :
			SendMessage("허드", "오버레이바탕검정", "끄기");
			SendMessage("자막", "오버레이바탕검정", "끄기");
			SendMessage( "허드", "픽유니트", "");
			$소화기변수 = 0 ;
			DeleteObject("불장수");
			break;

		case "소화기B" :
			SendMessage("허드", "오버레이바탕검정", "끄기");
			SendMessage("자막", "오버레이바탕검정", "끄기");
			SendMessage( "허드", "픽유니트", "");
			$소화기변수 = 0 ;
			DeleteObject("불장수");
			break;

		case "소화기C" :
			SendMessage("허드", "오버레이바탕검정", "끄기");
			SendMessage("자막", "오버레이바탕검정", "끄기");
			SendMessage( "허드", "픽유니트", "");
			$소화기변수 = 0 ;
			DeleteObject("불장수");
			break;

		case "소화기D" :
			SendMessage("허드", "오버레이바탕검정", "끄기");
			SendMessage("자막", "오버레이바탕검정", "끄기");
			DeleteObject("불장수");
			$소화기변수 = 0 ;
			SendMessage("유저", "픽금지", "off");
			break;

		case "야광스틱" :
			if($Item_야광스틱충전 == FALSE)
			$야광스틱 = 0;
			else
			{
			if($i_야광스틱갯수 == -1)
				return;
			$유저_조명아이템장비 = FALSE;
			}
			DeleteObject("장비형야광스틱");
			break;
			
		case "수위변장키트" :
			if($수위추적모드 == OFF && $i_수위변장시간 == -1)
				return;

			if($수위추적모드 == ON && $i_수위부적갯수 == -1)
				return;

			if($수위변장 == 1)
			{
			DeleteObject("장비형변장키트");
			$수위변장 = 0;
			if($AI_정찰용수위 == ON)
			RunScript("정찰용수위", "캐릭터_수위._수위가동");
			SendMessage("유저", "아이템장비", "취소");
			SendMessage("유저", "아이템장비취소", "");
			SendMessage("유저", "놓기", "손");
			DeleteObject("후라시");
			DeleteObject("칼");
			SendMessage("유저", "픽금지", "off");
			}
			else
			{
			SendMessage("사운드", "연주", "data/sound/도플_기.wav");
			SendMessage("카메라", "fov", "75");
			SendMessage("배경", "bspmode", "0");
			SendMessage("유저", "픽금지", "off");
			}
			break;

 		case "전기충격기" :
			DeleteObject("장비형전기충격기");
			DeleteObject("장풍");
			break;

		case "캠코더" :
			SendMessage("배경", "bspmode", "0");
			SendMessage("유저", "픽금지", "off");
			SendMessage("Camcorder","끄기","");
			DeleteObject("Camcorder");
			SendMessage("허드", "켜기", "프로세스"); 
			$캠코더 = 0;
			SetTimer(0,"_캠코더OFF");
			break;

		case "석판" :
			SendMessage("배경", "bspmode", "0");
			SendMessage("유저", "픽금지", "off");
			break;

		case "소방용도끼" :
			$소방용도끼 = 0;
			DeleteObject("장비형도끼");
			break;

		case "도끼" :
			DeleteObject("장비형도끼");
			break;

		case "양초" :
			$유저_조명아이템장비 = FALSE;
			SendMessage("사운드", "연주", "data/sound/양초불.wav");
			DeleteObject("장비형라이터");
			DeleteObject("장비형양초");
			break;

		case "배냇저고리" :
			SendMessage("사운드", "연주", "data/sound/item/수위변장키트.wav");
			$배냇저고리 = 0;
                        break; 
	}

	SetObjValue("장비중아이템", "");

	if($신관_세환_은미이벤트 == 0)
		RunScript("정찰용수위", "캐릭터_수위._발견조건");

	SendMessage("유저", "시끄러워", "0");
}

_유저._장비아이템_()
{
	SetObjValue("마지막장비아이템", "");
}

_유저._아이템장비플립()
{
	if (GetObjValue("장비상태") == "")
	{
		if (GetObjValue("마지막장비아이템") != "")
		{
			SetObjValue("GETITEMNAME", GetObjValue("마지막장비아이템"));
			RunScript("", "오브젝트_유저._유저._아이템장비");
		}
	}	else
	{
		if (GetObjValue("장비중아이템") != "")
		{
			SendMessage("유저", "아이템장비취소", "");
//			RunScript("", "오브젝트_유저._유저._아이템장비취소");
		}
	}
}

