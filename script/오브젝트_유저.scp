_캠코더ON()
{
	if($캠코더 == 0)
		return;

	if($캠코더배터리 == 0)
	{
		SendMessage("유저", "아이템장비취소", "");
		return;
	}
	$캠코더배터리--;
	SetTimer(1,"_캠코더ON");
}

_캠코더OFF()
{
	if($캠코더 == 1)
		return;

	if($캠코더배터리 == 10)
		return;

	$캠코더배터리++;
	SetTimer(1,"_캠코더OFF");
}

_라이터()
{
	$밝기이름 = "가스가";
	if($i_라이터가스 > 0)
	{
		if(GetObjValue("장비중아이템") == "라이터")
		{
			if($i_라이터가스 == 499)
				TextOut($밝기이름+" "+GetString("s914"));

			if($i_라이터가스 == 199)
				TextOut($밝기이름+" "+GetString("s915"));

			$i_라이터가스--;
			SetTimer(1,"오브젝트_유저._라이터");
		}
	}
	else
	{
		SendMessage("유저", "아이템장비", "취소");
		SendMessage("유저", "아이템장비취소", "");
	}
}

