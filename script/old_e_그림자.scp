			SetObjValue("FadeDelta", 255 / (30.0 * 0.26) + 1);
			SendMessage("타이머", "스크립트설정", "0 0.03333 " + (30.0 * 0.26) + " e_그림자.FadeOut *obj 그림자");

			SendMessage("그림자", "페이드", "Recursive 0.26 1 0");
			SendMessage("타이머", "스크립트설정", "0.26 0 1 e_그림자.RunEvent *obj 그림자");
			break;
		}
		case 3:
		{
			ShowAllObject();
			SendMessage("타이머", "스크립트설정", "0 0 1 e_그림자.RunEvent *obj 그림자");
			break;
		}
		case 4:
		{
			SetObjValue("FadeStep", 255);
			SetObjValue("FadeDelta", 255 / (30.0 * 3.0) + 1);
			SendMessage("타이머", "스크립트설정", "0 0.03333 " + (30.0 * 3.0) + " e_그림자.FadeOut *obj 그림자");

			SendMessage("그림자", "페이드", "Recursive 3 1 0");
			SendMessage("타이머", "스크립트설정", "6 0 1 e_그림자.RunEvent *obj 그림자");
			break;
		}
		case 5:
		{
			SendMessage("사운드", "연주", "data/sound/event/본관1_벼락준비.wav");
			SendMessage("나영", "발광", "Recursive off");
			SendMessage("창틀", "발광", "Recursive off");
			SendMessage("자막", "비활성", "");
			SendMessage("자막", "와이드모드", "끄기");
			SendMessage("유저", "쳐다보지말기", "");
			DeleteObject("");
			break;
		}
	}
}

ShowAllObject()
{
	SendMessage("그림자", "페이드", "Recursive 0 0 1");

	SendMessage("나영", "발광", "Recursive on");
	SendMessage("나영", "발광색", "Recursive 255 255 255");

	SendMessage("창틀", "발광", "Recursive on");
	SendMessage("창틀", "발광색", "Recursive 255 255 255");
}

Delete나영()
{
	DeleteObject("나영");
}

FadeOut()
{
	$FadeStep  = GetObjValue("FadeStep");
	$FadeDelta = GetObjValue("FadeDelta");
	
	if($FadeStep >= 0)
	{
		SendMessage("나영", "발광색", "Recursive " + $FadeStep + " " + $FadeStep + " " + $FadeStep);
		SendMessage("창틀", "발광색", "Recursive " + $FadeStep + " " + $FadeStep + " " + $FadeStep);
	
		SetObjValue("FadeStep", Max(Min($FadeStep - $FadeDelta, 255), 0));
	}
}
