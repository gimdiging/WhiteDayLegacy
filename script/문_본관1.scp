				$AI_걸음걸이 = ON;
				$본관1_세환_걸음걸이 = 1;				
				SendMessage("걸음걸이", "이동속도", "0.5");
				SendMessage("걸음걸이", "좋은위치", "" + FindPoint("걸음걸이등장위치"));
				SendMessage("걸음걸이", "이동", FindPoint("걸음걸이도착위치") + " 걷기 *script 형체없는인간.Stop");
			}
			break;		
	}

	if($LockFlag == LOCK || $LockValue == LOCK || ($LockValue == HALF_LOCK && $Direction == 1))
	{
		SendMessage("", "시끄러워", "1");
		
		switch(GetObjValue("lock_type"))
		{
			case "key" :
				SendMessage("자막", "문자출력후대기", GetString("s123"));
				break;

			case "inside" :
				SendMessage("자막", "문자출력후대기", GetString("s124"));
				break;

			case "button" :
				SendMessage("자막", "문자출력후대기", GetString("s125"));
				break;

			case "never" :
				SendMessage("자막", "문자출력후대기", GetString("s127"));
				return;

			case "custom" :
				SendMessage("자막", "문자출력후대기", GetString("s128"));
				break;

			case "dontmove" :
				SendMessage("자막", "문자출력후대기", GetString("s50"));
				break;

			case "default" :
				SendMessage("자막", "문자출력후대기", GetString("s16"));
				break;
		}				

		switch($TypeValue)
		{
			case 0:
				SendMessage("사운드", "연주", "잠긴소리01,data/sound/나무문잠긴것.wav");
				break;
				
			case 1:
				SendMessage("사운드", "연주", "잠긴소리02,data/sound/돌리는문잠긴것.wav");
				break;
				
			case 2:
				SendMessage("사운드", "연주", "신관_육중한문안열림,data/sound/신관_육중한문안열림.wav");
				break;
		}
		return;
	}

	if(GetObjValue("Lock") == "$문_본관21층연결문")
	{
		if(GetObjValue("MotionName") == "서있기")
		{
			RunScript("본관21층연결1", "문_본관1._열려라참깨");
			RunScript("본관21층연결2", "문_본관1._열려라참깨2");			
			return;
		}

		RunScript("본관21층연결1", "문_본관1._닫쳐라참깨");
		RunScript("본관21층연결2", "문_본관1._닫쳐라참깨2");		
		return;
	}

	if(GetObjName() == "문_수위퇴장1" || GetObjName() == "문_수위퇴장2")
	{
		if(GetObjValue("MotionName") == "서있기")
		{
			RunScript("문_수위퇴장1", "문_본관1._열려라참깨");
			RunScript("문_수위퇴장2", "문_본관1._열려라참깨2");			
			return;
		}

		RunScript("문_수위퇴장1", "문_본관1._닫쳐라참깨");
		RunScript("문_수위퇴장2", "문_본관1._닫쳐라참깨2");		
		return;
	}

	if($LockValue== HALF_LOCK && $Direction == -1)
	{
		SendMessage("자막", "문자출력후대기", GetString("s126"));
		SendMessage("사운드", "연주", "열쇠로나무문열기.wav");
		SetValue(GetObjValue("Lock"),UNLOCK);
		return;
	}
	
	SendMessage("", "시끄러워", "2");

	switch($OpenFlag)
	{
		case 0:		
			SetValue(GetObjValue("Lock"),UNLOCK);
			if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
				SendMessage("", "리스트추가", "" + GetObjName());
			
			if(GetObjName() == $user_donot_close)			
				$user_donot_close = "";			
			
			if($TypeValue == 0)
			{
				SendMessage("", "애니메이션", "!열기");
				SetObjValue("OpenFlag", 1);
				RunScript("", "문_본관1._VIS제어");
				return;
			}
				
			SendMessage("", "애니메이션", "!열기2");
			SetObjValue("OpenFlag", 2);
			RunScript("", "문_본관1._VIS제어");
			return;
		
		case 1:								
			SetObjValue("OpenFlag",0);
			RunScript("", "문_본관1._VIS제어");
			if(GetObjValue("exList") == 0 && GetObjName() != $user_donot_close && $신관_세환_은미이벤트 == 0)
			{
				SendMessage("", "리스트삭제", "" + GetObjName());
				if(GetObjName() == $detect_object)
					$detect_object = "";
			}
			
			if($TypeValue == 0)
			{				
				SendMessage("", "애니메이션", "!닫기");				
				return;
			}
			
			SendMessage("", "애니메이션", "!닫기1");						
			return;
		
		case 2:								
			SetObjValue("OpenFlag",0);
			RunScript("", "문_본관1._VIS제어");
			if(GetObjValue("exList") == 0 && GetObjName() != $user_donot_close && $신관_세환_은미이벤트 == 0)
			{
				SendMessage("", "리스트삭제", "" + GetObjName());
				if(GetObjName() == $detect_object)
					$detect_object = "";
			}
			
			if($TypeValue == 0)
			{					
				SendMessage("", "애니메이션", "!닫기");				
				return;
			}
			
			SendMessage("", "애니메이션", "!닫기2");									
			return;		
	}
}

