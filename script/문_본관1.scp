/////////////////////////// 교장실 //////////////////////////

numberpadopen()
{
	SendMessage("자막", "와이드모드", "켜기");
	SendMessage("자막", "활성화", "");
	SendMessage("유저", "위치쳐다보기", "" + FindPoint("교장실문1"));

	SendMessage("", "애니메이션", "열기1");
	SendMessage("main", "VIS켜기", GetObjValue("Vis제어"));

	SendMessage("타이머", "스크립트설정", "2 0 1 문_본관1.numberpadopen2"); // doorchange
	SetObjValue("OpenFlag", 1);
	RunScript("", "문_본관1._VIS제어");
	SetValue(GetObjValue("Lock"), UNLOCK);
}

numberpadopen2()
{
	SendMessage("자막", "비활성", "");
	SendMessage("자막", "와이드모드", "끄기");
	SendMessage("유저", "쳐다보지말기", "");
}

auto_force_open()
{
	if(GetObjValue("npcCant") == 1 || ((GetValue(GetObjValue("Lock")) == LOCK || GetValue(GetObjValue("Lock")) == HALF_LOCK) && (GetObjValue("exceptDoor") == 0 || (GetObjValue("exceptDoor") == 1 && $target != "정찰용수위"))))
		return;
	
	if(GetObjValue("toilet") == 1 && GetObjValue("MotionName") == "열려있기" && GetValue("$AI_" + $target) == ON)
	{
		SendMessage("" + $target, "잠깐서있어", "1");
		SendMessage("", "애니메이션", "닫기 10 f");
		return;
	}

	if(GetObjName() == $last_object)
	{
		$last_object = "";
		return;
	}

	$user_donot_close = GetObjName();

	if(GetObjValue("MotionName") == "서있기" && GetValue("$AI_" + $target) == ON)
	{		
		SendMessage("" + $target, "잠깐서있어", "1");		
		SendMessage("", "위치체크", GetObjPos($target));

		if ($ret == 1)
		{			
			if($target == "정찰용수위" && TakeObjValue("정찰용수위", "정책") == "추적")
				_쾅열려라수위();
			else
				_열려라수위();

			if($restrict_area == 0)	
				SetTimer(7, "_닫쳐라수위");
		}	else
		{
			if($target == "정찰용수위" && TakeObjValue("정찰용수위", "정책") == "추적")
				_쾅열려라수위2();
			else
				_열려라수위2();

			if($restrict_area == 0)	 
				SetTimer(7, "_닫쳐라수위2");
		}
	}
}

