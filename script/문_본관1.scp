/////////////////////// 방화셔터, 작은방, 중앙통로04 ///////////////////////

_열려라참깨()
{
	if(GetObjValue("OpenFlag") == 1)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
		SendMessage("", "리스트추가", "" + GetObjName());

	if(GetObjValue("Type") == 0)
		SendMessage("", "애니메이션", "열기");
	else
		SendMessage("", "애니메이션", "열기1");

	SetObjValue("OpenFlag", 1);
	RunScript("", "문_본관1._VIS제어");
}

_열려라참깨2()
{
	if(GetObjValue("OpenFlag") == 2)
		return;

