	if(GetObjValue("Vis제어") != "")
		SendMessage("main", "VIS켜기", GetObjValue("Vis제어"));
	SetObjValue("OpenFlag", 1);
}

_닫쳐라참깨()
{
	if(GetObjValue("OpenFlag") == 0)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
	{
		SendMessage("정찰용수위", "리스트삭제", "" + GetObjName());
		if(GetObjName() == $detect_object)
			$detect_object = "";
	}

	if(GetObjValue("Type") == 0)
		SendMessage("", "애니메이션", "닫기");
	else				
		SendMessage("", "애니메이션", "닫기1");

	SetObjValue("OpenFlag", 0);
	RunScript("", "문_본관1._VIS제어");
}

_닫쳐라참깨2()
{
	if(GetObjValue("OpenFlag") == 0)
		return;

	if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
	{
		SendMessage("정찰용수위", "리스트삭제", "" + GetObjName());
		if(GetObjName() == $detect_object)
			$detect_object = "";
	}

	if(GetObjValue("Type") == 0)
		SendMessage("", "애니메이션", "닫기");
	else				
		SendMessage("", "애니메이션", "닫기2");

	SetObjValue("OpenFlag", 0);
	RunScript("", "문_본관1._VIS제어");
}


/////////////////////// 방화셔터, 중앙통로03 ///////////////////////

_강제로닫기()
{
	SetValue(GetObjValue("Lock"), LOCK);
	
	if(GetObjValue("OpenFlag") != 0)
	{		
		SendMessage("", "애니메이션", "*닫기" + (GetObjValue("OpenFlag") == 1 ? "1" : "2"));					
		SetOsbjValue("OpenFlag", 0);
		RunScript("", "문_본관1._VIS제어");
		
		if(GetObjName() == "본관21층연결2")
			return;

		SendMessage("자막", "활성화", "");
		SendMessage("자막", "와이드모드", "켜기");
		SendMessage("타이머", "스크립트설정", "3 0 1 " + $G_File + "._강제로닫기종료");
	}
}

_강제로닫기종료()
{
	SendMessage("자막", "비활성", "");
	SendMessage("자막", "와이드모드", "끄기");
}

