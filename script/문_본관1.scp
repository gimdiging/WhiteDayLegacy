////////////////////////////////////////////////////////////////////////////////

Init()
{
	SetObjValue("MotionName", "서있기");
	SetObjValue("OpenFlag", 0);
	SetObjValue("LockFlag", UNLOCK);
	SetObjValue("Lock", "$문_이유없이열린문");
	SetObjValue("Vis제어", "");
	SetObjValue("exList", 0);			// 1: 수위가 정찰하지 않는 문
	SetObjValue("NoEnter", 0);			// 1: 수위가 들어갈 수 없는 제한구역의 문
	SetObjValue("Direction", 0);
	SetObjValue("lock_type", "default");
	SetObjValue("npcCant", 0);			// 1: 모든 NPC가 못여는 문
	SetObjValue("exceptDoor", 0);		// 1: 잠겨있지만 수위가 열 수 있는 문(순찰경로등등..)
	SendMessage("", "애니메이션", "서있기");
	SendMessage("", "값지정", "*openscript 문_본관1.auto_force_open");	
				
	// Type -> 0:교실여닫이 1:돌리는 손잡이 2:큰 통로문
	
	switch(GetObjValue("Type"))
	{
		case 0:			
			SendMessage("", "스크립트설정", "lock " + $G_File + ".lockbox");						
			
		case 1:
			SendMessage("", "스크립트설정", "handleA " + $G_File + ".handle1");
			SendMessage("", "스크립트설정", "handleB " + $G_File + ".handle2");
			SendMessage("", "스크립트설정", "dummy " + "null");
			break;
			
		case 2:	
			SendMessage("", "스크립트설정", "handleB " + $G_File + ".handle1");
			SendMessage("", "스크립트설정", "handleD " + $G_File + ".handle1");
			SendMessage("", "스크립트설정", "handleA " + $G_File + ".handle2");
			SendMessage("", "스크립트설정", "handleC " + $G_File + ".handle2");
			SendMessage("", "스크립트설정", "dummy0 null");
			SendMessage("", "스크립트설정", "dummy1 null");
			break;
	}
}

OpenDoor()
{
	if(GetObjValue("Type") == 0)
	{
		SendMessage("", "애니메이션", "열려있기");
		SetObjValue("OpenFlag", 1);
		RunScript("", "문_본관1._VIS제어");
		return;
	}

	SendMessage("", "애니메이션", "열려있기1");
	SetObjValue("OpenFlag", 1);
	RunScript("", "문_본관1._VIS제어");
}

lockbox.pick()
{
	if(GetObjValue("Lock") == "$문_중앙통로")
		return ($문_중앙통로 == UNLOCK && GetObjValue("LockFlag") == LOCK) ? "잡기" : "";	

	if(GetObjValue("LockFlag") == LOCK)	
		return $G_UserItem == GetObjValue("KeyName") ? "i" + GetObjValue("iconname") : "보기";	

	return "";
}

lockbox.click()
{
	$OpenFlag = GetObjValue("OpenFlag");
	$LockFlag = GetObjValue("LockFlag");
	
	if(GetObjValue("Lock") == "$문_중앙통로" && $문_중앙통로 == UNLOCK)
	{
		if(GetObjValue("LockFlag") == LOCK)
		{
			SendMessage("", "애니메이션", "자물쇠열기");
			SetObjValue("LockFlag", UNLOCK);			
			SendMessage("", "캐쉬초기화", "");
			SendMessage("", "시끄러워", "0");
		}
		
		return;
	}
	
	if($LockFlag == LOCK)
	{
		if($G_UserItem == GetObjValue("KeyName"))
		{
			SendMessage("자막", "문자출력후대기", GetString("s120"));
			SendMessage("유저", "폐기", "@" + GetObjValue("iconname"));
			SetObjValue("LockFlag", UNLOCK);
			SetValue(GetObjValue("Lock"),UNLOCK);
			SendMessage("사운드", "연주", "잠긴소리01,data/sound/열쇠로나무문열기.wav");
			SendMessage("", "캐쉬초기화", "");	
			SendMessage("", "시끄러워", "0");
		}
		else
			SendMessage("자막", "문자출력후대기", GetString("s121"));
	}
}

handle1.pick()
{
		if(GetObjValue("Lock") == "$문_1층방화셔터" && $문_1층방화셔터 == LOCK && $G_UserItem == "방화셔터열쇠")
		return "i방화셔터열쇠";

		if(GetObjValue("Lock") == "$문_2층방송실옆방화셔터" && $문_2층방송실옆방화셔터 == LOCK && $G_UserItem == "방화셔터열쇠")
		return "i방화셔터열쇠";

		if(GetObjValue("Lock") == "$문_1층계단" && $문_1층계단 == LOCK && $G_UserItem == "방화셔터열쇠")
		return "i방화셔터열쇠";

	if(GetObjValue("MotionName") == "열기" || GetObjValue("MotionName") == "열기1" || GetObjValue("MotionName") == "열기2" || GetObjValue("MotionName") == "열기1" || GetObjValue("MotionName") == "닫기" || GetObjValue("MotionName") == "닫기1" || GetObjValue("MotionName") == "닫기2" || GetObjValue("MotionName") == "흔들기")
	{
		SendMessage("", "캐쉬초기화", "");		
		return "";
	}

	if(GetObjValue("Lock") == "$문_중앙통로" && GetObjValue("MotionName") == "자물쇠열기")
	{
		SendMessage("", "캐쉬초기화", "");
		return "";
	}

	return GetObjValue("lock_type") == "never" ? "보기" : "잡기";
}

_VIS끄기()
{
	if (GetObjValue("MotionName") == "서있기")
		SendMessage("main", "VIS끄기", GetObjValue("Vis제어"));
}

handle1.click()
{
	$OpenFlag   = GetObjValue("OpenFlag");
	$LockFlag   = GetObjValue("LockFlag");
	$LockValue  = GetValue(GetObjValue("Lock"));
	$TypeValue  = GetObjValue("Type");
	$Direction  = GetObjValue("Direction"); 
	
	switch(GetObjValue("Lock"))
	{
		case "$문_1층방화셔터":
			if($문_1층방화셔터 == LOCK)
			{
			if($G_UserItem == "방화셔터열쇠")
			{
			$문_1층방화셔터 = UNLOCK;
			SendMessage("사운드", "연주", "data/sound/열쇠로나무문열기.wav");
			$방화셔터Unlock++;
			if($방화셔터Unlock == 8)
			{
			SendMessage("유저", "폐기", "@" + $G_UserItem);
			SendMessage("자막", "문자출력후대기", GetString("s120"));
			}
			else
			SendMessage("자막", "문자출력후대기", GetString("s126"));
			}
			else
			{
			SendMessage("자막", "문자출력후대기", GetString("s16"));
			SendMessage("사운드", "연주", "잠긴소리02,data/sound/돌리는문잠긴것.wav");
			}
			return;
			}
			break;

		case "$문_2층방송실옆방화셔터":
			if($문_2층방송실옆방화셔터 == LOCK)
			{
			if($G_UserItem == "방화셔터열쇠")
			{
			$문_2층방송실옆방화셔터 = UNLOCK;
			SendMessage("사운드", "연주", "data/sound/열쇠로나무문열기.wav");
			$방화셔터Unlock++;
			if($방화셔터Unlock == 8)
			{
			SendMessage("유저", "폐기", "@" + $G_UserItem);
			SendMessage("자막", "문자출력후대기", GetString("s120"));
			}
			else
			SendMessage("자막", "문자출력후대기", GetString("s126"));
			}
			else
			{
			SendMessage("자막", "문자출력후대기", GetString("s16"));
			SendMessage("사운드", "연주", "잠긴소리02,data/sound/돌리는문잠긴것.wav");
			}
			return;
			}
			break;

		case "$문_1층계단":
			if($문_1층계단 == LOCK)
			{
			if($G_UserItem == "방화셔터열쇠")
			{
			$문_1층계단 = UNLOCK;
			SendMessage("사운드", "연주", "data/sound/열쇠로나무문열기.wav");
			$방화셔터Unlock++;
			if($방화셔터Unlock == 8)
			{
			SendMessage("유저", "폐기", "@" + $G_UserItem);
			SendMessage("자막", "문자출력후대기", GetString("s120"));
			}
			else
			SendMessage("자막", "문자출력후대기", GetString("s126"));
			}
			else
			{
			SendMessage("자막", "문자출력후대기", GetString("s16"));
			SendMessage("사운드", "연주", "잠긴소리02,data/sound/돌리는문잠긴것.wav");
			}
			return;
			}
			break;

		case "$문_과학부속실":
			if($문_과학부속실 == LOCK)
			{
			if($소방용도끼 == 0)
			{
			SendMessage("자막", "문자출력후대기", GetString("s923"));
			SendMessage("사운드", "연주", "잠긴소리02,data/sound/돌리는문잠긴것.wav");
			}
			else
			{
			$문_과학부속실 = UNLOCK;
			SendMessage("자막", "문자출력후대기", GetString("s126"));
			SendMessage("사운드", "연주", "data/sound/문나무열기_f.wav");
			SendMessage("유저", "아이템장비", "취소");
			SendMessage("유저", "아이템장비취소", "");
			}
			return;
			}
			break;

		case "$문_과학부속실4층":
			if($문_과학부속실4층 == LOCK)
			{
			if($소방용도끼 == 0)
			{
			SendMessage("자막", "문자출력후대기", GetString("s923"));
			SendMessage("사운드", "연주", "잠긴소리02,data/sound/돌리는문잠긴것.wav");
			}
			else
			{
			$문_과학부속실4층 = UNLOCK;
			SendMessage("자막", "문자출력후대기", GetString("s126"));
			SendMessage("사운드", "연주", "data/sound/문나무열기_f.wav");
			SendMessage("유저", "아이템장비", "취소");
			SendMessage("유저", "아이템장비취소", "");
			}
			return;
			}
			break;

		case "$문_현관1":
			SendMessage("", "애니메이션", "흔들기");
			SendMessage("", "시끄러워", "3");
			SendMessage("자막", "문자출력후대기", GetString("s122"));
			return;		
					
		case "$문_강당통로":
			if($본관1_세환_걸음걸이 == 0 && $수위추적모드 == OFF && $b_번개 == 1)
			{
				$본관1_세환_조명걸음 = 1;
				$본관1_세환_조명1사람수++;							
				SetTimer(0, "e_main1잡다한이벤트.CheckNum");

				SendMessage("유저", "충돌체크", "off");

				$AI_걸음걸이 = ON;
				$본관1_세환_걸음걸이 = 1;				
				SendMessage("걸음걸이", "이동속도", "0.5");
				SendMessage("걸음걸이", "좋은위치", "" + FindPoint("걸음걸이등장위치"));
				SendMessage("걸음걸이", "이동", FindPoint("걸음걸이도착위치") + " 걷기 *script 형체없는인간.Stop");
			}
			break;
	}

	if($LockFlag == LOCK || $LockValue == LOCK || ($LockValue == HALF_LOCK && $Direction == -1))
	{	
		SendMessage("", "시끄러워", "1");
		
		switch(GetObjValue("lock_type"))
		{
			case "key" :
				SendMessage("자막", "문자출력후대기", GetString("s123"));
				break;

			case "inside" :
				SendMessage("자막", "문자출력후대기", GetString("s124"));
				break;

			case "button" :
				SendMessage("자막", "문자출력후대기", GetString("s125"));
				break;

			case "never" :
				SendMessage("자막", "문자출력후대기", GetString("s127"));
				return;

			case "custom" :
				SendMessage("자막", "문자출력후대기", GetString("s128"));
				break;

			case "dontmove" :
				SendMessage("자막", "문자출력후대기", GetString("s50"));
				break;

			case "default" :
				SendMessage("자막", "문자출력후대기", GetString("s16"));
				break;
		}				

		switch($TypeValue)
		{
			case 0:
				SendMessage("사운드", "연주", "잠긴소리01,data/sound/나무문잠긴것.wav");
				break;
				
			case 1:
				SendMessage("사운드", "연주", "잠긴소리02,data/sound/돌리는문잠긴것.wav");
				break;
				
			case 2:
				SendMessage("사운드", "연주", "신관_육중한문안열림,data/sound/신관_육중한문안열림.wav");
				break;
		}
		return;
	}

	if($LockValue== HALF_LOCK && $Direction == 1)
	{
		SendMessage("자막", "문자출력후대기", GetString("s126"));
		SendMessage("사운드", "연주", "열쇠로나무문열기.wav");
		SetValue(GetObjValue("Lock"),UNLOCK);
		return;
	}
	
	if(GetObjValue("Lock") == "$문_본관21층연결문")
	{
		if(GetObjValue("MotionName") == "서있기")
		{
			RunScript("본관21층연결1", "문_본관1._열려라참깨");
			RunScript("본관21층연결2", "문_본관1._열려라참깨2");			
			return;
		}

		RunScript("본관21층연결1", "문_본관1._닫쳐라참깨");
		RunScript("본관21층연결2", "문_본관1._닫쳐라참깨2");		
		return;
	}

	if(GetObjName() == "문_수위퇴장1" || GetObjName() == "문_수위퇴장2")
	{
		if(GetObjValue("MotionName") == "서있기")
		{
			RunScript("문_수위퇴장1", "문_본관1._열려라참깨");
			RunScript("문_수위퇴장2", "문_본관1._열려라참깨2");			
			return;
		}

		RunScript("문_수위퇴장1", "문_본관1._닫쳐라참깨");
		RunScript("문_수위퇴장2", "문_본관1._닫쳐라참깨2");		
		return;
	}

	SendMessage("", "시끄러워", "2");

	switch($OpenFlag)
	{
		case 0:		
			SetValue(GetObjValue("Lock"),UNLOCK);
			SetObjValue("OpenFlag", 1);
			RunScript("", "문_본관1._VIS제어");
			if(GetObjValue("exList") == 0 && $신관_세환_은미이벤트 == 0)
				SendMessage("", "리스트추가", "" + GetObjName());			

			if(GetObjName() == $user_donot_close)			
				$user_donot_close = "";			
			
			if($TypeValue == 0)
			{
				SendMessage("", "애니메이션", "열기");
				return;
			}
				
			SendMessage("", "애니메이션", "열기1");
			return;
		
		case 1:								
			SetObjValue("OpenFlag",0);
			RunScript("", "문_본관1._VIS제어");
			if(GetObjValue("exList") == 0 && GetObjName() != $user_donot_close && $신관_세환_은미이벤트 == 0)
			{
				SendMessage("", "리스트삭제", "" + GetObjName());
				if(GetObjName() == $detect_object)
					$detect_object = "";
			}
			
			if($TypeValue == 0)
			{				
				SendMessage("", "애니메이션", "닫기");
				return;
			}
			
			SendMessage("", "애니메이션", "닫기1");			
			return;
		
		case 2:								
			SetObjValue("OpenFlag",0);
			RunScript("", "문_본관1._VIS제어");
			if(GetObjValue("exList") == 0 && GetObjName() != $user_donot_close && $신관_세환_은미이벤트 == 0)
			{
				SendMessage("", "리스트삭제", "" + GetObjName());
				if(GetObjName() == $detect_object)
					$detect_object = "";
			}
			
			if($TypeValue == 0)
			{				
				SendMessage("", "애니메이션", "닫기");
				return;
			}			
			
			SendMessage("", "애니메이션", "닫기2");
			return;		
	}
}

handle2.pick()
{
		if(GetObjValue("Lock") == "$문_1층서무실옆방화셔터" && $문_1층서무실옆방화셔터 == LOCK && $G_UserItem == "방화셔터열쇠" && $G_금의진해결 == TRUE)
		return "i방화셔터열쇠";

		if(GetObjValue("Lock") == "$문_2층방화셔터" && $문_2층방화셔터 == LOCK && $G_UserItem == "방화셔터열쇠")
		return "i방화셔터열쇠";

		if(GetObjValue("Lock") == "$문_2층계단" && $문_2층계단 == LOCK && $G_UserItem == "방화셔터열쇠")
		return "i방화셔터열쇠";

		if(GetObjValue("Lock") == "$문_3층계단" && $문_3층계단 == LOCK && $G_UserItem == "방화셔터열쇠")
		return "i방화셔터열쇠";

		if(GetObjValue("Lock") == "$문_4층계단" && $문_4층계단 == LOCK && $G_UserItem == "방화셔터열쇠")
		return "i방화셔터열쇠";

	if(GetObjValue("MotionName") == "열기" || GetObjValue("MotionName") == "열기1" || GetObjValue("MotionName") == "열기2" || GetObjValue("MotionName") == "열기1" || GetObjValue("MotionName") == "닫기" || GetObjValue("MotionName") == "닫기1" || GetObjValue("MotionName") == "닫기2")
	{
		SendMessage("", "캐쉬초기화", "");	
		return "";
	}

	return GetObjValue("lock_type") == "never" ? "보기" : "잡기";
}

handle2.click()
{
	$OpenFlag	= GetObjValue("OpenFlag");
	$LockFlag	= GetObjValue("LockFlag");
	$LockValue  = GetValue(GetObjValue("Lock"));
	$TypeValue  = GetObjValue("Type");		
	$Direction  = GetObjValue("Direction"); 	

	switch(GetObjValue("Lock"))
	{
		case "$문_1층서무실옆방화셔터":
			if($문_1층서무실옆방화셔터 == LOCK && $G_금의진해결 == TRUE)
