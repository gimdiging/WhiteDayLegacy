Init()
{
	SetObjName("나무아랫쪽");
	SendMessage("배경", "켜기", "tree_down");
	for($i = 1; $i <= 9; $i++)
	{
		SendMessage("", "스크립트설정", "egg" + $i + " " + $G_File + ".egg" + $i);
		SetObjValue("EggDead" + $i , FALSE);
		SendMessage("", "픽거리설정", "500 500");
	}
	SetObjValue("DeadCount", 9);
	SetObjValue("DeadEggName", "");
	SetObjValue("FadeStep", 255);

//	SendMessage("사운드", "연주3d", GetObjPos("나무아랫쪽") + " loop,모기소리,data/sound/event/모기앵앵.wav");
	SendMessage("", "충돌체크", "off");
	SendMessage("", "애니메이션", "서있기");
}

egg1.pick()
{
	if($old_Mission4_대화 == OFF)
	{
		SendMessage("", "캐쉬초기화", "");		
		return "";
	}

	return (GetObjValue("EggDead1") == FALSE && $G_UserItem == "old_용제") ? "iold_용제" : "";
}

egg1.click()
{
	if($G_UserItem == "old_용제" && GetObjValue("EggDead1") == FALSE)
	{
		SetObjValue("EggDead1", TRUE);
		SetObjValue("DeadEggName", "GeoSphere10");
		SendMessage("타이머", "스크립트설정", "0 0 1 old_e_나무아랫쪽.FadeOut0 *obj 나무아랫쪽");
	}
}

