FadeOut0()
{
//	SendMessage("사운드", "연주", "data/sound/나무_괴로워.wav");
	
	SetObjValue("FadeStep", 255);
	SetObjValue("FadeDelta", 255 / (30.0 * 1.0) + 1);
	SendMessage("타이머", "스크립트설정", "0 0.03333 " + (30.0 * 1.0) + " old_e_나무아랫쪽.FadeOut1 *obj 나무아랫쪽");
	
	SendMessage("자막", "활성화", "");
	SendMessage("자막", "와이드모드", "켜기");	
	
	SetObjValue("KillEnd", FALSE);
	SendMessage("", "발광", GetObjValue("DeadEggName") + " on");
}

FadeOut1()
{
	$FadeStep  = GetObjValue("FadeStep");
	$FadeDelta = GetObjValue("FadeDelta");

	if($FadeStep >= 0)
	{
		SendMessage("", "발광색", GetObjValue("DeadEggName") + " " + $FadeStep + " " + $FadeStep + " " + $FadeStep);
		SetObjValue("FadeStep", Max(Min($FadeStep - $FadeDelta, 255), 0));
	}
	if(GetObjValue("FadeStep") == 0)
	{
		if(GetObjValue("KillEnd") == FALSE)
		{
			SendMessage("타이머", "스크립트설정", "1 0 0 old_e_나무아랫쪽.FadeOut2 *obj 나무아랫쪽");
			SetObjValue("KillEnd", TRUE);
		}
	}
}

FadeOut2()
{
	SendMessage("자막", "비활성", "");
	SendMessage("자막", "와이드모드", "끄기");	
	DeadCheck();
}

DeadCheck()
{
	SetObjValue("DeadCount", GetObjValue("DeadCount") - 1);

	if(GetObjValue("DeadCount") == 1)
	{
		SendMessage("유저", "캡춰", "소영");
		SendMessage("타이머", "스크립트설정", "0.1 0 1 old_e_나무아랫쪽.Capture");
	}

	if(GetObjValue("DeadCount") == 0)
	{
		$old_Mission4_나무 = TRUE;

		SendMessage("자막", "활성화", "");
		SendMessage("자막", "와이드모드", "켜기");	

		SendMessage("유저", "위치쳐다보기", "" + FindPoint("old_아랫나무"));

		SendMessage("나무아랫쪽", "애니메이션", "죽기");
		SendMessage("나무윗쪽", "애니메이션", "죽어있기");
		SendMessage("배경", "끄기", "tree_down");
		SendMessage("배경", "끄기", "tree_up");
		DeleteObject("나무윗쪽줄기");

		for($i = 1; $i <= 9; $i++)
		SendMessage("모기" + $i, "페이드", "Recursive 2 1 0");

		SendMessage("소영", "위치", "" + FindPoint("old_소영위치1"));
		SendMessage("소영", "회전", "6");
		SendMessage("소영", "애니메이션", "힘들어하기");
		SendMessage("소영", "표정바꿔", "지침m");
		SendMessage("소영", "발광", "Recursive on");
		SendMessage("소영", "발광색", "Recursive 104 96 23");
		SendMessage("소영", "캐쉬초기화", "");

		SendMessage("타이머", "스크립트설정", "3 0 1 old_e_나무아랫쪽.Dead");
	}
}

Dead()
{
	SendMessage("유저", "쳐다보지말기", "");
	
	SendMessage("자막", "비활성", "");
	SendMessage("자막", "와이드모드", "끄기");	

	SetObjValue("모기공격", OFF);
	SendMessage("사운드", "연주멈춤", "모기소리");
	for($i = 1; $i <= 9; $i++)	
		DeleteObject("모기" + $i);
}

Event모기1()
{
	if($old_Mission4_나무 == TRUE)
		return;

	SendMessage("타이머", "스크립트설정", "0 0 1 old_e_나무아랫쪽.e모기1 *obj 나무아랫쪽");
	SendMessage("사운드", "연주멈춤", "모기소리");
}

Event모기2()
{
	if($old_Mission4_나무 == TRUE)
		return;

	SendMessage("타이머", "스크립트설정", "0 0 1 old_e_나무아랫쪽.e모기2 *obj 나무아랫쪽");
	SendMessage("사운드", "연주멈춤", "모기소리");
}

Event모기3()
{
	if($old_Mission4_나무 == TRUE)
		return;

	SendMessage("타이머", "스크립트설정", "0 0 1 old_e_나무아랫쪽.e모기3 *obj 나무아랫쪽");
	SendMessage("사운드", "연주3d", GetObjPos("나무아랫쪽") + " loop,모기소리,data/sound/event/모기앵앵.wav");
}

e모기1()
{
	SetObjValue("모기공격", OFF);
}

e모기2()
{
	SetObjValue("모기공격", OFF);
}

e모기3()
{
	if(GetObjValue("모기공격") == OFF)
	{
		SetObjValue("모기공격", ON);
		e모기공격();
	}
}

e모기공격()
{
	if($old_GameOver == TRUE)
		return;

	if(GetObjValue("모기공격") == ON)
	{
		if($G_UserItem == "old_모기약")
		{
			SendMessage("자막", "활성화", "");
			SendMessage("자막", "와이드모드", "켜기");	

			SendMessage("사운드", "연주", "data/sound/모기약.wav");
			SendMessage("자막", "문자출력", "2," +  GetString("old_s11"));

			LoadObject("WObjGas", "모기약연기", GetCameraInfo() + " *aabb -60 -60 -30 60 60 30 *velocity 4");
			SendMessage("타이머", "스크립트설정", "2 0 1 old_e_나무아랫쪽.e모기약죽이기 *obj 나무아랫쪽");

//			SendMessage("타이머", "스크립트설정", "6 0 1 e_나무아랫쪽.e모기공격 *obj 나무아랫쪽");
		}
		else
		{
			SendMessage("유저", "공격", "");
			SendMessage("자막", "문자출력", "1," +  GetString("old_s12"));

			SendMessage("타이머", "스크립트설정", "2 0 1 old_e_나무아랫쪽.e모기공격 *obj 나무아랫쪽");
		}
	}
}

e모기약죽이기()
{
	DeleteObject("모기약연기");
	SendMessage("자막", "비활성", "");
	SendMessage("자막", "와이드모드", "끄기");	
}

Capture()
{
	SendMessage("유저", "놓기", "");
	SendMessage("소영", "유저앞으로", "나무윗쪽줄기");
	SendMessage("소영", "위치y", "100");
	SendMessage("소영", "회전", "60");
}

GetCameraInfo()
{
	$GetCameraInfo = "*matrix 1 0 0 0 1 0 0 0 0 *pos " + GetObjPos("유저");
	return $GetCameraInfo;
}

ready()
{
	DeleteObject("");	// EventArea
	DeleteObject("달수");
	DeleteObject("봉구");
	DeleteObject("희민");
	DeleteObject("성아");
	
	SendMessage("배경", "텍스처교체", "iron_03 iron_00.bmp");
	SendMessage("배경", "텍스처교체", "iron_01 iron_03.bmp");
	SendMessage("배경", "텍스처교체", "iron_00 iron_04.bmp");
	SendMessage("배경", "텍스처교체", "iron_02 iron_05.bmp");
}