_토의진소리()
{
	if($G_토의진해결 == TRUE)
		return;

	if($본관2토의귀기 == 0)
	{
		SendMessage("사운드", "연주3d", GetObjPos("토의관문") + " loop,토의귀기,귀기_루프.wav");
		$본관2토의귀기 = 1;
	}

//*script e_아기소리._토의진소리
}

_토의진소리날려()
{
	if($본관2토의귀기 == 1)
	{
		SendMessage("사운드", "연주멈춤", "토의귀기");
		$본관2토의귀기 = 0;
	}
}

_토의조각소리()
{
	if($본2_영호_미술실이벤트완료 == 1)
		return;

	if($본관2토의조각소리 == 0)
	{
		SendMessage("사운드", "연주3d", GetObjPos("토의조각") + " loop,토조각루프,조각_루프.wav");
		$본관2토의조각소리 = 1;
	}

}

_토의조각소리()
{
	if($본관2토의조각소리 == 1)
	{
		SendMessage("사운드", "연주멈춤", "토조각루프");
		$본관2토의조각소리 = 0;
	}
}


_B루트이동중초기화()
