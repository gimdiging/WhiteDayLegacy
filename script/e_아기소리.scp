sound1()
{
	DeleteObject("");
	if($본2_영호_아기소리3층 == 0)
	{
		$본2_영호_아기소리3층 = 1;
		if($본2_영호_아기발동중 == 0)
		SendMessage("사운드", "연주", "data/sound/event/3층복도애기.wav");
	}
}

sound2()
{
