}

_나영소리()
{
	if($본2_신9나영소리 == 1)
	{
		DeleteObject("");
		SendMessage("사운드", "연주", "나영웃음.wav");
		$본2_신9나영소리 = 2;
	}
}

_빨로비나()
{
	if($본관2빨로비나박스 == 0)
	{
		SendMessage("사운드", "연주3d", GetObjPos("빨로비나상자") + " loop,빨로비나라디오,라디오.wav");
		$본관2빨로비나박스 = 1;
	}
}

_빨로비나날려()
{
	if($본관2빨로비나박스 == 1)
	{
		SendMessage("사운드", "연주멈춤", "빨로비나라디오");
		$본관2빨로비나박스 = 0;
	}
}

