Init()
{
	SendMessage("", "스크립트설정", "left " + $G_File + ".left");
	SendMessage("", "스크립트설정", "right " + $G_File + ".right");
	SendMessage("", "스크립트설정", "handle " + $G_File + ".handle");

	SendMessage("", "스크립트설정", "dummy1 null");
	SendMessage("", "스크립트설정", "dummy2 null");
	SendMessage("", "스크립트설정", "dummy3 null");
	SendMessage("", "스크립트설정", "dummy4 null");
	SendMessage("", "스크립트설정", "dummy5 null");
	
	SetObjValue("RotateValue", 0);
	SetObjValue("RotateDial", 0);
	SetObjValue("Step", 0);
	SetObjValue("OpenFlag", FALSE);
	SetObjValue("Rotate", 0);
	SetObjValue("Direction", "");
	SetObjValue("info", 0);

	if($b_체육부금고 == 1)
	{
		SetObjValue("Step", 4);
		SendMessage("", "애니메이션", "열려있기");
		SetObjValue("OpenFlag", TRUE);
	}
}

left.pick()
{
	if($수위추적모드 == ON)
		return "자동후진";

	if(GetObjValue("info") == 0 || $G_LightFactor <= $standard_light)
		return "보기";

	return GetObjValue("Step") < 4 ? "왼쪽회전" : "";
}
