right.pick()
{
	if($수위추적모드 == ON)
		return "자동후진";

	if(GetObjValue("info") == 0 || $G_LightFactor <= $standard_light)
		return "보기";

	return GetObjValue("Step") < 4 ? "오른쪽회전" : "";
}
