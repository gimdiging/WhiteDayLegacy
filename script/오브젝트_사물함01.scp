Init()
{
	SendMessage("", "НКХЉИГЦЎМГСЄ", "door " + $G_File);
	for($i = 1; $i < 6; $i++)
		SendMessage("", "НКХЉИГЦЎМГСЄ", "dummy" + $i + " null");
	SetObjValue("OpenFlag", 0);
	SetObjValue("Ghost", 0);
}

Init1Йн()
{
	Init();
	SetObjValue("Ghost", 1);
}

Init3Йн()
{
	Init();
	SetObjValue("Ghost", 2);
}

Init4Йн()
{
	Init();
	SetObjValue("Ghost", 3);
}

