_Init남자샤워실()
{
	_Init();
	SendMessage("", "스크립트설정", "lock 강당문._샤워실락");
	SetObjValue("Lock", $체육관_영호_남자샤워실잠김);
	SetObjValue("한번보기",0);
	SetObjValue("남녀확인",1);
}

