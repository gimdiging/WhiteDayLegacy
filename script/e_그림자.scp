	LoadObject("WObjNPC", "목귀신","*scale 1.50 *pet e_목귀신.pet  *block 0 *group -1 *optimize *pos -826.80 130.30 -372.80  *rot 0.00 90.00 0.00 *FlagShow 1 *Show 1");
