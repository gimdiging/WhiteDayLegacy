/////////////////////////////////////////////////////////////

_은미.StartUp()
{	
	if($신관_세환_은미이벤트 == 2)
	{
		DeleteObject("");
		return;
	}

	SendMessage("", "발광색", "Recursive 255 150 150");
	SendMessage("", "발광", "Recursive off");
	
	SendMessage("", "값지정", "스트립트불리거리 1");	
	SendMessage("", "공격대상추가", "유저");	
	SendMessage("", "위치", "0 0 0");
//	SetTimer(5, "캐릭터_은미._은미.첨부터 *obj 은미");
}

_은미.첨부터()
{
	if($신관_세환_은미이벤트 == 2)
		return;

	$은미괴로워하기 = OFF;
	SendMessage("", "걷기동작", "달리기");
	SendMessage("", "따라가기", "유저");	
	SetTimer(0,"check_distance *obj 은미");
	$은미달리기 = 500;
	SendMessage("","이동속도","1");
}

_은미.Process()
{	
	SendMessage("은미", "Stop", "");
	SendMessage("은미", "애니메이션", "서있기");
}

_은미.LockOn()
{
	if($신관_세환_은미이벤트 == 2)
		return;
	
	if($은미공격횟수 == 0)
		$은미공격성공률 = 1;
	else
		$은미공격성공률 = (1.0 * $은미공격성공횟수)/(1.0 * $은미공격횟수);	
	$은미공격횟수++;
	$은미분노게이지 += 2;
	$은미공격성공 = 0;	
		
//	SendMessage("은미", "동작취하기", "던지기공격");
	SendMessage("은미", "동작취하기", "`찌르기공격");
	SendMessage("은미", "미끄러지기", "400 0");	
}

_은미.FailChase()
{	
	SetTimer(1, "캐릭터_은미._은미.첨부터 *obj 은미");
}

_은미.MoveFail()
{	
	SetTimer(1, "캐릭터_은미._은미.첨부터 *obj 은미");	
}

check_distance()
{	
	if($은미찾아내기 == 3 || $은미찾아내기 == 4 || $은미괴로워하기 == ON || $신관_세환_은미이벤트 == 2)
		return;

	if($은미공격성공률 < 0.3)
		SendMessage("은미", "발광", "Recursive on");
	else
		SendMessage("은미", "발광", "Recursive off");

	$xz_dis = xz_distance(GetObjPos(""), GetObjPos("유저"));

	$x_dis = x_distance(GetObjPos(""), GetObjPos("유저"));
	$y_dis = CheckHeight(GetObjPos(""), GetObjPos("유저"));
	$z_dis = z_distance(GetObjPos(""), GetObjPos("유저"));	

	$danger_area = xz_distance(GetObjPos("신관배전판"), GetObjPos("유저"));

	if($y_dis < 300)
		$height = 0;
	else if($y_dis < 600)
		$height = 1000;
	else if($y_dis < 1000)
		$height = 2000;
	else
		$height = 3000;

	$dis = $xz_dis + $height;

//	if($dis > 1500 || ($dis > 500 && $은미공격성공률 < 0.2))				
//	{
//		SendMessage("", "걷기동작", "빨리달리기");		
//		$은미달리기 = 700;
//	}
//	else	
//	{
//		SendMessage("", "걷기동작", "달리기");
//		$은미달리기 = 500;
//	}

	if($dis > 500)
	{		
		$신관_세환_은미거리지속시간++;

		if($신관_세환_은미거리지속시간 == 4)
		{
			$신관_세환_은미거리지속시간 = 0;						
						
			SetTimer(0, "knife_ready *obj 은미");
		}		
		else
			$은미분노게이지 += 0.5;
	}
	else
		$신관_세환_은미거리지속시간 = 0;

	if($신관_세환_은미공격 == OFF && $height > 0)
	{	
		$신관_세환_은미공격 = ON;
		if($danger_area < 500)
			danger_scream();
		else
			scream();
		return;
	}	
			
	SetTimer(3,"check_distance *obj 은미");
}


////////////////////////////////////////////////////////////////////////////
//	칼던지기
//

knife_ready()
{
	if($은미괴로워하기 == ON || $신관_세환_은미이벤트 == 2)
		return;
	
	SendMessage("", "동작취하기", "던지기공격");

	SetTimer(0.4, "knife_attack *obj 은미칼");
}

knife_attack()
{	
	if($은미괴로워하기 == ON || $신관_세환_은미이벤트 == 2)
		return;

	$신관_세환_knife = ON;
	$time = 10 + $은미분노게이지;
	$speed = 300 + 20 * $은미분노게이지;
	SetTimer($time, "knife_hide");
	SetTimer(0.1, "show_knife *obj 은미칼");
		
	$은미분노게이지++;
	SendMessage("", "유도미사일", GetObjPos("은미") + "유저 흔들기 " + $speed + " *script 캐릭터_은미.knife_damage");
}

knife_damage()
{
	if($신관_세환_knife == ON)
	{				
		if($은미공격횟수 == 0)
			$은미공격성공률 = 1;
		else
			$은미공격성공률 = (1.0 * $은미공격성공횟수)/(1.0 * $은미공격횟수);	
		$은미공격횟수++;
		$은미공격성공 = 0;		
		SendMessage("유저", "공격", "은미칼");
		knife_hide();
	}
}

knife_hide()
{
	if($신관_세환_knife == ON)
	{		
		$신관_세환_knife = OFF;
		SendMessage("은미칼", "애니메이션", "꽂히기");
		SendMessage("은미칼", "페이드", "Recursive 1 1 0");
		SendMessage("은미칼", "TurnGlow", "off 0");
		SetTimer(1.5,"knife_stop *obj 은미칼");		
	}
}

knife_stop()
{
	SendMessage("", "Stop", "");	
	SendMessage("", "애니메이션", "서있기");
	if($은미분노게이지 < 10)
		SetTimer(0, "캐릭터_은미._은미.첨부터 *obj 은미");
}

////////////////////////////////////////////////////////////////////////////////
//	벨소리에 주춤거림
//

retreat()
{		
	SendMessage("", "따라가기", "");

	if(CheckArea("은미잘가", GetObjPos("")) && $신관_세환_은미이벤트 == 1)
	{
		DeleteObject("메두사1");
		DeleteObject("메두사2");
		DeleteObject("목줄1");
		DeleteObject("목줄2");

		DeleteObject("그림자귀신1");
		DeleteObject("그림자귀신2");
		DeleteObject("그림자귀신3");

		DeleteObject("도플갱어a");
		DeleteObject("도플갱어b");
		DeleteObject("도플갱어c");

		DeleteObject("복도거미");

		if($게임모드 != 0 && $게임모드 != 4)
		SendMessage("허드", "가스게이지꺼", "");

		$신관_세환_은미이벤트 = 2;		
		SendMessage("", "애니메이션", "정지");
		SendMessage("", "위치", "0 0 0");

		SendMessage("매크로용이수위", "충돌체크", "on");
		SendMessage("매크로용손수위", "충돌체크", "on");
		SendMessage("은미추락막기", "충돌체크", "off");

		if($진행루트 == 1)
			SendMessage("매크로", "Play", "sc24.cut01");
		else
			SendMessage("매크로", "Play", "sc25.cut01");

		return;
	}

	$신관_세환_벨횟수++;
	$은미분노게이지 += 2;
	$은미괴로워하기 = ON;
	
	SendMessage("", "돌고이동", GetObjPos("신관배전판") + " 괴로워하며걷기");	
	
	$y_dis = CheckHeight(GetObjPos(""), GetObjPos("신관배전판"));
	$xz_dis = xz_distance(GetObjPos(""), GetObjPos("신관배전판"));

	$dis = $xz_dis + $y_dis * 5;

	$time = Max(3, (2.0 + (10000.0 / $dis)) * 6.0 / ($신관_세환_벨횟수 + 6.0)) - Max(0, Min(($은미분노게이지 / 10.0), 1.0));

//	TextOut("은미마비시간: " + $time + " 거리:" + $dis);	// debug

	if($time > $신관_세환_벨지속시간)
		$time = $신관_세환_벨지속시간;	

	SetTimer($time,"캐릭터_은미._은미.첨부터 *obj 은미");
	SetTimer($신관_세환_벨지속시간,"check_distance *obj 은미");
}

fall()
{	
	if($은미괴로워하기 == ON && $EnterObj == "은미" && $신관_세환_은미이벤트 == 1)
	{
		$은미괴로워하기 = OFF;
		$신관_세환_은미이벤트 = 2;
		$AI_은미 = OFF;

		if($진행루트 == 1)
			SendMessage("매크로", "Play", "sc24.cut01");
		else
			SendMessage("매크로", "Play", "sc25.cut01");
	}
}

/////////////////////////////////////////////////////////////////////////////////////
//	고함치기
//

scream()
{
	if($은미괴로워하기 == ON || $신관_세환_은미이벤트 == 2)
		return;

	SendMessage("은미", "Stop", "");	
	SendMessage("은미", "따라가기", "");	
	SendMessage("은미", "애니메이션", "%고함치기.MTN");	
	if(Random(2))
		SendMessage("사운드", "연주", "은미웃음01.wav");
	else
		SendMessage("사운드", "연주", "은미웃음02.wav");

	SendMessage("유저", "이동속도", "0.5");	
	
	SetTimer(0.5,"break_window");		
	SetTimer(3,"캐릭터_은미._은미.첨부터 *obj 은미");		
	SetTimer(5,"e_movespeed.normal_speed");	
	if($신관_세환_knife == OFF)
	SetTimer(1.5, "knife_ready *obj 은미");
}

break_window()
{
	if($은미분노게이지 > 10)
	{
		if(GetObjPosY("유저") < 20)
			SendMessage("유저", "공격", "천정폭파");
		else
			$은미분노게이지 += 3;

		SendMessage("사운드", "연주", "유리창02.wav");
		LoadObject("WObjFragments", "", "*area 1660 490 700 2200 470 1200 *fragnum 1024 *defvec 0 0 0 *defamin -300 -100 -200 *defamax 300 0 200 *gennum 256 *gencount 1 *genfreq 1 *lifetime 2 *fadetime 0.5 *timedelta 1 *genscale 3 *genscaledelta 4 *rotangle -2 -0.5 0 *rotangledelta 0 1 -1 *gravec 0 -500 0 *fr 0.2 *elastic 0.1 *bcol 1 *pet0 o_유리파편.pet");
		return;
	}

	
	$은미분노게이지 += 1;

	for($i = 1; $i < $신관_세환_유리창갯수; $i++)
	{
		if(CheckDistance(GetObjPos("유저", "머리"), FindPoint("유리_" + $i)))
		{
			SendMessage("유리_" + $i, "애니메이션", "떨림");			
			SetTimer(0.5,"explode *obj 유리_" + $i);
		}
	}			
}

explode()
{	
	SendMessage("", "애니메이션", "*서있기");
	SendMessage("사운드", "연주3d", FindPoint("" + GetObjName()) + " 유리창01.wav");
	
	$normal = ComparePos(FindPoint("fix_camera"), FindPoint("" + GetObjName()), 2);
	$area = GetParticleArea(FindPoint("" + GetObjName()), $normal);
	$speed = 500 * $normal;	

	LoadObject("WObjFragments", "", "*area " + $area + " *fragnum 128 *defvec 0 0 0 *defamin -100 -50 0 *defamax 100 0 " + $speed + " *gennum 64 *gencount 1 *genfreq 1 *lifetime 1 *fadetime 0.5 *timedelta 0.5 *genscale 1 *genscaledelta 3 *rotangle -2 -0.5 0 *rotangledelta 0 1 -1 *gravec 0 -980 0 *fr 0.2 *elastic 0.3 *bcol 1 *pet0 o_유리파편.pet");
	
	if(Check_WindowDamage(FindPoint("" + GetObjName()), GetObjPos("유저"), $normal) && z_distance(FindPoint("" + GetObjName()), GetObjPos("유저")) < 400)	
	{
		$은미분노게이지 += 1;
		SendMessage("유저", "공격", "유리파편");	
	}
}

danger_scream()
{
	if($은미괴로워하기 == ON || $신관_세환_은미이벤트 == 2)
		return;

	SendMessage("은미", "Stop", "");	
	SendMessage("은미", "따라가기", "");
	SendMessage("은미", "애니메이션", "%고함치기.MTN");

	SendMessage("유저", "이동속도", "0.3");	
	
	SetTimer(0.5,"danger_explode");		
	SetTimer(3,"캐릭터_은미._은미.첨부터 *obj 은미");		
	SetTimer(5,"e_movespeed.normal_speed");	
	if($신관_세환_knife == OFF)
	SetTimer(1.5, "knife_ready *obj 은미");
}

danger_explode()
{
	SendMessage("사운드", "연주3d", FindPoint("배전판앞유리") + " 도플_거울깨지는소리.wav");
	
	$normal = -1.0 * ComparePos(FindPoint("fix_camera"), FindPoint("배전판앞유리"), 2);
	$area = GetParticleArea(FindPoint("배전판앞유리"), $normal);
	$speed = 500 * $normal;	

	LoadObject("WObjFragments", "", "*area " + $area + " *fragnum 256 *defvec 0 0 0 *defamin -100 -50 0 *defamax 100 100 " + $speed + " *gennum 64 *gencount 1 *genfreq 1 *lifetime 2 *fadetime 1 *timedelta 1 *genscale 1 *genscaledelta 3 *rotangle -2 -0.5 0 *rotangledelta 0 1 -1 *gravec 0 -500 0 *fr 0.2 *elastic 0.3 *bcol 1 *pet0 o_유리파편.pet");
	
	if(Check_WindowDamage(FindPoint("배전판앞유리"), GetObjPos("유저"), $normal) && z_distance(FindPoint("배전판앞유리"), GetObjPos("유저")) < 400)	
		SendMessage("유저", "공격", "유리파편");	
}

