special_area()
{
	if($신관_세환_은미이벤트 == 0)
	{
		RunScript("정찰용수위", "캐릭터_수위.special_area");
		return;
	}
	
	if($신관_세환_은미이벤트 == 2 || $은미찾아내기 == 1)
		return;
/*
	if(GetObjPosY("은미") < 20)			
		SetTimer(0, "special_knife *obj 은미");					
	else
	{
		SendMessage("은미", "이동", FindPoint("은미숨기") + " 빨리달리기");		
		$은미달리기 = 500;
		$은미찾아내기 = 2;
	}		
	*/

	$은미찾아내기 = 1;

	SendMessage("은미", "따라가기", "");

	if(ComparePos(FindPoint("fix_camera"), GetObjPos("유저"), 2) > 0)		
		SendMessage("은미", "빨리돌고이동", FindPoint("chase_start1") + " 걷기1 *script 캐릭터_은미.special_turn");
	else
		SendMessage("은미", "빨리돌고이동", FindPoint("chase_start2") + " 걷기1 *script 캐릭터_은미.special_turn");
}

recheck_area()
{
	/*
