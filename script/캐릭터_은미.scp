		SetTimer(0, "special_knife *obj 은미");	
	}
	else
		SetTimer(0, "캐릭터_은미._은미.첨부터 *obj 은미");
		*/

	if($은미찾아내기 == 1)
		SendMessage("은미", "빨리돌기포인트", GetObjPos("유저") + " *script 캐릭터_은미.special_attack1");		
}

