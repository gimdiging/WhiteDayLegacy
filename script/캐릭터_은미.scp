throw_knife()
{
	SetTimer(2, "special_hide");
	SetTimer(6, "recheck_area");
	SetTimer(0.1, "show_knife *obj 은미칼");
				
	SendMessage("은미칼", "유도미사일", GetObjPos("은미") + "유저 흔들기 800 *script 캐릭터_은미.special_damage");
}

show_knife()
{
	SendMessage("", "페이드", "Recursive 0 1 1");	
	SendMessage("", "TurnGlow", "on 0");
}

special_turn()
{
	SendMessage("", "Stop", "");			
	SendMessage("", "빨리돌기포인트", GetObjPos("유저") + " *script 캐릭터_은미.special_attack1");
}

special_attack1()
{		
//	SendMessage("", "이동속도", "0");
	SendMessage("", "동작취하기", "던지기공격");
	$신관_세환_knife = ON;		

	SetTimer(0.4, "throw_knife");	
}

special_attack2()
{	
	SetTimer(2, "special_hide");
	SetTimer(6, "recheck_area");
	
	$신관_세환_knife = ON;
	SendMessage("", "유도미사일", GetObjPos("") + "유저 흔들기 800 *script 캐릭터_은미.special_damage");
}

special_damage()
{
	if($신관_세환_knife == ON)
	{
		SendMessage("유저", "공격", "은미칼");
		special_hide();
	}
}

special_hide()
{
	if($신관_세환_knife == ON)
	{		
		$신관_세환_knife = OFF;
		SendMessage("은미칼", "애니메이션", "꽂히기");
		SendMessage("은미칼", "페이드", "Recursive 1 1 0");
		SendMessage("은미칼", "TurnGlow", "off 0");	
	}
}

///////////////////////////// 기타 //////////////////////////////////////

Nopick()
{
	if($신관_세환_시간간격유지B == 1)
		SendMessage("유저", "픽금지", "off");

	$신관_세환_시간간격유지B--;
}

//////////////////////////// 매크로용 유리깨짐 /////////////////////////////

macro_break()
{
	SendMessage("", "애니메이션", "*서있기");	

	$normal = ComparePos(FindPoint("fix_camera"), FindPoint("" + GetObjName()), 2);
	$area = GetParticleArea(FindPoint("" + GetObjName()), $normal);
	$speed = 500 * $normal;	

	LoadObject("WObjFragments", "", "*area " + $area + " *fragnum 128 *defvec 0 0 0 *defamin -100 -50 0 *defamax 100 0 " + $speed + " *gennum 64 *gencount 1 *genfreq 1 *lifetime 1 *fadetime 0.5 *timedelta 0.5 *genscale 1 *genscaledelta 3 *rotangle -2 -0.5 0 *rotangledelta 0 1 -1 *gravec 0 -980 0 *fr 0.2 *elastic 0.3 *bcol 1 *pet0 o_유리파편.pet");
}


////////////////////// 은미배틀용 쳐다보기귀신 //////////////////////

_메두사.StartUp()
{
	SendMessage("", "충돌체크", "off");
	SendMessage("", "끄기", "");	
	if($신관_세환_은미이벤트 == 2)
		DeleteObject("");
}

_메두사.첨부터()
{
	SendMessage("", "켜기", "");
	SendMessage("", "애니메이션", "서있기");	
	SendMessage("", "나만봐라", "유저");	

	SendMessage("", "텍스쳐변경", "hi_face_ghost");
	SendMessage("", "텍스쳐변경", "hi_body_ghost");	
	SendMessage("", "텍스쳐변경", "he_ghost_02");	
	SendMessage("", "텍스쳐변경", "he_ghost_03");	
	SendMessage("", "텍스쳐변경", "he_ghost_04");	
	SendMessage("", "텍스쳐변경", "he_ghost_05");	
	SendMessage("", "텍스쳐변경", "he_ghost_06");	
	SendMessage("", "텍스쳐변경", "he_ghost_08");	
	SendMessage("", "텍스쳐변경", "he_ghost_09");	
	SendMessage("", "텍스쳐변경", "he_ghost_12");	
}

_메두사.Near()
{	
	if(CheckHeight(GetObjPos(""), GetObjPos("유저")) > 200)
		return;

	switch($게임모드)
	{
		case 0:
			$power = 120;
			break;
		case 1:
			$power = 150;
			break;
		case 2:
			$power = 180;
			break;
		case 3:
			$power = 210;
			break;
		case 4:
			$power = 90;
			break;
	}

	SendMessage("유저", "쳐다보기", GetObjName() + " " + $power);
	SendMessage("사운드","연주","loop,바닥귀신,바닥귀신.wav");
	SendMessage("유저", "이동속도", "0.5");
	$AI_형체있는인간 = OFF;
	RunScript("복도거미", "천정귀신.corridorspider_restrict");
}

_메두사.Far()
{
	if(CheckHeight(GetObjPos(""), GetObjPos("유저")) > 200)
		return;

	switch($게임모드)
	{
		case 0:
			$power = 60;
			break;
		case 1:
			$power = 90;
			break;
		case 2:
			$power = 120;
			break;
		case 3:
			$power = 150;
			break;
		case 4:
			$power = 60;
			break;
	}

	SendMessage("유저", "쳐다보기", GetObjName() + " " + $power);
	SendMessage("사운드","연주","loop,바닥귀신,바닥귀신.wav");
	SendMessage("유저", "이동속도", "0.5");
	$AI_형체있는인간 = OFF;
	RunScript("복도거미", "천정귀신.corridorspider_restrict");
}

_메두사.Out()
{
	if(CheckHeight(GetObjPos(""), GetObjPos("유저")) > 200)
		return;

	SendMessage("유저", "쳐다보지말기", "");
	$AI_형체있는인간 = ON;
	SendMessage("유저", "이동속도", "1");
	SendMessage("사운드", "연주멈춤", "바닥귀신");
	RunScript("복도거미", "천정귀신.corridorspider_appear");
}
