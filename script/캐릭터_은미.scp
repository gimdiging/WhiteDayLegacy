Init()
{
	SendMessage("", "위치", "0 0 0");		
	SendMessage("", "목각도제한", "-75");
}

start_event()
{
	SetTimer(60, "playTime");
	SendMessage("은미", "이동속도", "1");
	RunScript("은미", "캐릭터_은미._은미.첨부터");
	SetTimer(0.1, "Ycheck");

	SendMessage("매크로용이수위", "충돌체크", "off");
	SendMessage("매크로용손수위", "충돌체크", "off");
	SendMessage("구름다리막기", "충돌체크", "off");

	SendMessage("렌턴_매크로용이수위", "끄기", "");
	SendMessage("렌턴_매크로용손수위", "끄기", "");
	SendMessage("매크로용이수위", "발광", "flash-an off");
	SendMessage("매크로용손수위", "발광", "flash-an off");

	RunScript("메두사1", "캐릭터_은미._메두사.첨부터");
	RunScript("메두사2", "캐릭터_은미._메두사.첨부터");		
	SendMessage("목줄1", "페이드", "Recursive 0 1 1");
	SendMessage("목줄2", "페이드", "Recursive 0 1 1");

	SendMessage("그림자귀신1", "켜기", "");
	SendMessage("그림자귀신2", "켜기", "");
	SendMessage("그림자귀신3", "켜기", "");

	if($게임모드 != 0 && $게임모드 != 4)
	SendMessage("허드", "가스게이지켜", "400");

	RunScript("복도거미", "천정귀신.corridorspider_appear");

	for($i = 1; $i < 4; $i++)	
		RunScript("문_K" + $i, "문_신관._닫쳐있어");			
}

playTime()
{
	$은미배틀시간 = ON;
}

Ycheck()
{
	$y = GetObjPosY("유저");
	if($y > 370)
	{
		SetTimer(0, "캐릭터_은미._도플갱어");	
		return;
	}
	SetTimer(0.1, "Ycheck");
}

