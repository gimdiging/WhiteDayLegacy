{	
	LoadObject("WObjNPC", "도플갱어1","*scale 1.00 *pet 캐릭터_도플갱어.pet  *block 0 *group -1 *optimize *pos -1480 70 -607 *rot 0.00 0.00 0.00 *FlagShow 1 *Show 1");
