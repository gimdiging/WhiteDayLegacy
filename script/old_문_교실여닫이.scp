Init()
{
	SendMessage("", "스크립트설정", "handle " + $G_File);
	SendMessage("", "스크립트설정", "lock " + $G_File + ".lockbox");
	SendMessage("", "스크립트설정", "dummy1 null");
	SendMessage("", "스크립트설정", "dummy2 null");
	SetObjValue("MotionName", "");
	SetObjValue("OpenFlag", CLOSE);
	SetObjValue("LockFlag", UNLOCK);
	SendMessage("", "애니메이션", "서있기");
}

