OpenDoor()
{
	SendMessage("", "애니메이션", "열려있기");
	SetObjValue("OpenFlag", OPEN);
}

lockbox.pick()
{
	return ($G_UserItem == "old_가정실습실열쇠" && GetObjValue("OpenFlag") == CLOSE) ? "iold_가정실습실열쇠" : "";
}

lockbox.click()
{
	$OpenFlag = GetObjValue("OpenFlag");
	$LockFlag = GetObjValue("LockFlag");
//	$LockValue = GetValue(GetObjValue("Lock"));
	
	if($G_UserItem == GetObjValue("KeyName") && GetObjValue("OpenFlag") == CLOSE)
	{
		SendMessage("자막", "문자출력", "2," + ($LockFlag == LOCK ? GetString("old_s31") : GetString("old_s32")));
		SetObjValue("LockFlag", $LockFlag == LOCK ? UNLOCK : LOCK);
//		SetValue(GetObjValue("Lock"),($LockValue == LOCK ? UNLOCK : LOCK));
		SendMessage("사운드", "연주", "잠긴소리01,data/sound/열쇠로나무문열기.wav");
	}
}

pick()
{
	return "잡기";
}

click()
{
	$OpenFlag	= GetObjValue("OpenFlag");
	$LockFlag	= GetObjValue("LockFlag");
	$LockValue  = GetValue(GetObjValue("Lock"));
	
	if($LockFlag == UNLOCK)
	{
		if($LockValue == UNLOCK)
		{
			if($OpenFlag == CLOSE) 
			{
				SendMessage("", "애니메이션", "열기");
				if(GetObjValue("MotionName") != "열기")
				{
					return;
				}
			}
			else
			{
				SendMessage("", "애니메이션", "닫기");
				if(GetObjValue("MotionName") != "닫기")
				{
					return;
				}
			}
			SetObjValue("OpenFlag", $OpenFlag == OPEN ? CLOSE : OPEN);
			return;
		}
	}

	SendMessage("사운드", "연주", "잠긴소리01,data/sound/나무문잠긴것.wav");
	SendMessage("자막", "문자출력", "2," +  GetString("old_s32"));
}