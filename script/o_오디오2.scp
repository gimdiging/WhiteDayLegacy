//		SetTimer(1,"start");
//	}
}

start()
{			
	SendMessage("유저", "쳐다보지말기", "");	
	SendMessage("사운드", "연주", "도플_웃음01.wav");	
	
	$이동속도 = $신관_세환_무용실내이동속도;
	SendMessage("유저", "이동속도", "" + $이동속도);
	SetTimer(0,"e_도플갱어.start");
	SetTimer(0,"o_무용실스피커.audio_on");
	return;
}



close()
{	
	SendMessage("", "애니메이션", "닫힘 0.5");
	SendMessage("", "캐쉬초기화", "");
	
	if(GetObjName() == "무용실가짜오디오")
	SendMessage("자막", "비활성", "");

	if($신관_세환_무용실이벤트 == 1)
	{		
		if(GetObjName() == "무용실진짜오디오")			
			SetTimer(3,"play_ready");
	}
}

fake_body.pick()
{
	if($신관_세환_무용실이벤트 <= 1)
		return "";

	if($G_UserItem == "리모콘" && $special_event1 == ON)
		return "i리모콘";

	return "보기";
}

fake_body.click()
{
	if(GetObjValue("special_cd") == 0)
	{
		SendMessage("자막", "문자출력후대기", GetString("s79"));			
		return;
	}

//	if(GetObjValue("step") <= 5)
//	{
//		SendMessage("자막", "문자출력후대기", GetString("s79"));			
//		SetObjValue("step", GetObjValue("step") + 1);
//		return;
//	}

	switch(GetObjValue("step"))
	{	
		case 1:
			SendMessage("자막", "문자출력후대기", GetString("s79"));
			break;

		case 2:
			SendMessage("자막", "문자출력후대기", GetString("s106"));
			break;

		case 3:
			SendMessage("자막", "문자출력후대기", GetString("s6"));
			break;

		case 4:
			SendMessage("자막", "문자출력후대기", GetString("s81"));
			break;

		case 5:
			SendMessage("자막", "문자출력후대기", GetString("s87"));
			break;

		case 6:
			SendMessage("자막", "문자출력후대기", GetString("s944"));
			break;

		case 7:
			SendMessage("자막", "문자출력후대기", GetString("s945"));
			$special_event1 = ON;
			break;

		case 8:
			if($G_UserItem == "리모콘")
			{
				TextOut(GetString("s946"));
				SetTimer(3,"start_event");
			}
			else 
			{
				SendMessage("자막", "문자출력후대기", GetString("s947"));
				SetObjValue("step", 7);
			}
			break;			
	}

	SetObjValue("step", GetObjValue("step") + 1);

}

fake_cd.pick()
{	
	if($신관_세환_무용실이벤트 <= 1)
		return "";

	if(GetObjValue("MotionName") == "열림" || GetObjValue("MotionName") == "닫힘")
	{
		SendMessage("", "캐쉬초기화", "");
		return "";
	}

	if($G_UserItem == "열쇠뺀시디" && GetObjValue("OpenFlag") == 1)
		return "i시디";

	return "잡기";
}

fake_cd.click()
{	
	if(GetObjValue("OpenFlag") == 0)
	{
		SendMessage("", "애니메이션", "열림");
		SetObjValue("OpenFlag", 1);				
	}
	else
	{
		if($G_UserItem == "열쇠뺀시디")
		{
			SetObjValue("special_cd", 1);
			SendMessage("자막", "활성화", "");			
			SendMessage("", "페이드", "Cylinder01 1 0 1");
			SendMessage("유저", "폐기", "열쇠뺀시디");
			SetObjValue("OpenFlag", 0);
			SetTimer(2,"close *obj 무용실가짜오디오");
			return;
		}
		
		if(GetObjValue("special_cd") == 1)
		{
			SetObjValue("special_cd", 0);
			SendMessage("", "페이드", "Cylinder01 1 1 0");
			SendMessage("유저", "획득", "열쇠뺀시디");
			SendMessage("자막", "활성화", "");
			SetTimer(2,"close *obj 무용실가짜오디오");
			return;
		}				

		SendMessage("", "애니메이션", "닫힘 0.5");
		SetObjValue("OpenFlag", 0);					
	}		
}

start_event()
{
	TextOut(GetString("s948"));
}

remotemode()
{	
	if($신관_세환_리모콘거리 == OFF)
	{
		$신관_세환_리모콘거리 = ON;
		SetTimer(0,"pickdistance");
	}
}

handmode()
{
	$신관_세환_리모콘거리 = OFF;
}

pickdistance()
{	
	if($신관_세환_리모콘거리 == ON && $신관_세환_무용실이벤트 != 1)
	{
		if($G_UserItem == "리모콘")
			SendMessage("무용실진짜오디오", "픽거리설정", "500 600");
		else
			SendMessage("무용실진짜오디오", "픽거리설정", "100 300");

		SendMessage("무용실진짜오디오", "캐쉬초기화", "");

		SetTimer(1,"pickdistance");
	}
}
