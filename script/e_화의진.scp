	SendMessage("파티1" , "파티클생성", "*start_pos aabb 969.4 50.6 -1201.8 971.7 -28.8 -1273.6 *target_pos delta_aabb -100 0 0 -110 0 0 " + GetWDBParticle("particle.wdb", "동문불", "파티클내용") );
}

_북문불()
{
	SendMessage("파티2" , "파티클생성", "*start_pos aabb 541.6 50.3 -435.1 609.1 -20.5 -435.1 *target_pos delta_aabb 0 0 -200 0 0 -210 " + GetWDBParticle("particle.wdb", "북문불", "파티클내용") );
	
	LoadObject("WObjFirePlane", "강당불놀이메인4_1", "*area " + GetEventAABB("불창고") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *col 2 *progresstime 0.1f *num 50");
	LoadObject("WObjFirePlane", "강당불놀이메인4_2", "*area " + GetEventAABB("불창고") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 1 *col 2 *progresstime 0.1f *num 50");
