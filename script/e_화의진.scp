_스프링클러틀기()
{

	$i = 0;
	for($i = 1; $i <= 6; $i++)
	{
		SendMessage("증기" + $i, "파티클생성", "*loop off");
	}

	$i = 0;
	for($i = 1; $i <= 20; $i=$i+2)
	{
		SendMessage("파티"+$i, "파티클생성", "*origin pos " + FindPoint("cooler" + $i) + " " + GetWDBParticle("particle2.wdb", "스프링쿨러01", "파티클내용") );
		//SendMessage("파티" + ($i+1), "파티클생성", "*origin pos " + FindPoint("cooler" + ($i+1)) + " " + GetWDBParticle("particle2.wdb", "스프링쿨러01", "파티클내용") );
		SendMessage("파티"+($i+1), "파티클생성", "*origin pos " + FindPoint("bcooler" + $i) + " " + GetWDBParticle("particle2.wdb", "스프링쿨러02", "파티클내용") );
	}
	SendMessage("사운드","연주","loop,스쿨소리,스프링쿨러.wav");

}

_바닥에불지르기()
{
	RunScript("","e_바닥불._load");
}

_스프링클러끄기()
{
	$i = 0;
	for($i = 1; $i <= 20; $i++)
	{
		SendMessage("파티" + $i, "파티클생성", "*loop off");
		SendMessage("파티" + ($i + 1), "파티클생성", "*loop off");

	}
	SendMessage("사운드","연주멈춤","스쿨소리");
}

_시작()
{
	// 조명에 그라비티 먹여서 떨어뜨리기.

	RunScript("","e_화의진._나영나타나");
	if($게임모드 != 0 && $게임모드 != 4)
	SendMessage("허드", "가스게이지켜", "500");
	$AI_은미 = ON;
	SetTimer(0,"_gym._은미.첨부터 *obj 은미");
	$체육관_영호_방화이벤트 = 1;
	SendMessage("더미4", "켜기", "");
	SendMessage("더미5", "켜기", "");
	LoadObject("WObjFirePlane", "E형으로끄는불1", "*area " + GetEventAABB("E형으로끄는불") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 5.0f *num 20 *direction 0 *col 2");
	LoadObject("WObjFirePlane", "E형으로끄는불2", "*area " + GetEventAABB("E형으로끄는불") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 1 *progresstime 5.0f *num 20 *direction 0 *col 2");
	LoadObject("WObjFirePlane", "E형으로끄는불3", "*area " + GetEventAABB("E형으로끄는불") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 2 *progresstime 5.0f *num 20 *direction 0 *col 2");
	LoadObject("WObjFirePlane", "E형으로끄는불4", "*area " + GetEventAABB("E형으로끄는불") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 3 *progresstime 5.0f *num 20 *direction 0 *col 2");
	SetTimer(10, "_gym.knife_attack");
}

_폭발1()
{
	// 남자샤워실에서 b형소화기를 찾아 남탈의실을 지나면 문 떨어지는폭발
	if($체육관_영호_소화기b획득 == 1 && $b_여샤워실열쇠 == 1)
	{
		DeleteObject("");
		SendMessage("매크로", "Play", "gym_scenez._002");
	}
}


_폭발2()
{
	// 밸브레버 습득후 문q로.
	if($체육관_영호_밸브레버습득 == 2)
	{
		DeleteObject("");
		SendMessage("매크로", "Play", "gym_scenez._003");
		$체육관_영호_폭발단계 = 1;
	}

}

_폭발3()
{
	// 폭발2이후. 이위치
	if($체육관_영호_폭발단계 == 1)
	{
		DeleteObject("");
		SendMessage("매크로", "Play", "gym_scenez._004");
		$체육관_영호_폭발단계 = 2;
	}
}

_폭발4()
{
	if($체육관_영호_폭발단계 == 2)
	{
		DeleteObject("");
		SendMessage("매크로", "Play", "gym_scenez._005");
		$체육관_영호_폭발단계 = 3;
	}
}

_폭발5()
{
	// 밸브혹은레버삽입후.

	if($체육관_영호_밸브레버작동 == 0)
	{
		if($게임모드 != 0 && $게임모드 != 4)
		SendMessage("허드", "가스게이지꺼", "");
		SendMessage("매크로", "Play", "gym_scenez._006");
		$체육관_영호_밸브레버작동 = 1;
//		RunScript("","e_화의진._화의진끄기");
	}
	
}

_해결()
{
	// 은미죽는씬.
	if($체육관_영호_밸브레버작동 == 1)
	{
		DeleteObject("");
		$AI_은미 = OFF;
		SendMessage("은미", "따라가기", "");
		SendMessage("은미", "충돌체크", "on");
		SendMessage("은미", "NOCLIP", "off");
		SendMessage("매크로", "Play", "sc28.cut01");
	}
}

