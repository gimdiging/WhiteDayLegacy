_A켜기()
{
	LoadObject("WObjFirePlane", "A형으로끄는불1", "*area " + GetEventAABB("A형으로끄는불") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 20");
