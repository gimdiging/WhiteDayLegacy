		DeleteObject("강당불놀이하2_1");
		DeleteObject("강당불놀이좌2");
		DeleteObject("강당불놀이우2");

		DeleteObject("강당불놀이상3");
		DeleteObject("강당불놀이하3");
		DeleteObject("강당불놀이하3_1");
		DeleteObject("강당불놀이좌3");
		DeleteObject("강당불놀이우3");

		DeleteObject("강당불놀이메인1");
		DeleteObject("강당불놀이메인2");
		DeleteObject("강당불놀이메인3");

		DeleteObject("불창문1");
		DeleteObject("불창문2");

//		DeleteObject("강당불놀이메인4_1");
