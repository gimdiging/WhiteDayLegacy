_화의귀기소리()
{
	if($화의귀기소리 == 0)
	{
		SendMessage("사운드", "연주3d", GetObjPos("화의진_위치") + " loop,화의귀기,귀기_루프.wav");
		$화의귀기소리 = 1;
	}
}

_화의귀기소리날려()
{
	if($화의귀기소리 == 1)
	{
		SendMessage("사운드", "연주멈춤", "화의귀기");
		$화의귀기소리 = 0;
	}
}

