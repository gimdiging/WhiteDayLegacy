	SendMessage("카메라", "포그", "");
	SendMessage("main", "그림자렌더링", "끄기");
}

_화의진끄기()
{

	if($화의진끄기 == 0)
	{
		$화의진끄기 = 1;

		RunScript("유저", "오브젝트_유저._유저._아이템장비취소");
		RunScript("유저", "오브젝트_유저._유저._장비아이템_");
//		SendMessage("유저", "폐기", "소화기A");
//		SendMessage("유저", "폐기", "소화기B");
//		SendMessage("유저", "폐기", "소화기C");

		RunScript("","e_화의진._A끄기1");
		RunScript("","e_화의진._B끄기1");
		RunScript("","e_화의진._C끄기1");
		RunScript("","o_더미5._D끄기1");
		RunScript("","o_더미5._E끄기1");

