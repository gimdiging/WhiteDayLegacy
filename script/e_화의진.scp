_오브젝트교환()
{

	$강당오브젝트교환 = 1;
	$i = 0;
	for($i = 1; $i <= 74; $i++)
	{
		DeleteObject("바꿔" + $i);
	}

	for($i = 1; $i <= 92; $i++)
	{
		DeleteObject("날려" + $i);
	}

	DeleteObject("농구대");

	for($i = 1; $i <= 77; $i++)
	{
		SendMessage("바뀜" + $i,"켜기","");
	}

	RunScript("","e_화의진._텍스쳐교환");

	RunScript("","e_화의진._가스나와라");

	SendMessage("카메라", "포그", "50 6000 f66a1e 0 0.6 30");
	SendMessage("main", "그림자렌더링", "끄기");

//	SendMessage("카메라", "카메라거리","50 1500");
	SendMessage("배경", "끄기", "back");
//	SendMessage("배경", "끄기", "stage");

}

_가스나와라()
{
	//강당가스1
	//강당가스2
	LoadObject("WObjGas", "강당가스1", "*matrix 1 0 0 0 1 0 0 0 -1 *pos " + FindPoint("강당가스1") + " *aabb -20 -20 -20 20 20 20 *velocity 3");
	LoadObject("WObjGas", "강당가스2", "*matrix 1 0 0 0 1 0 0 0 -1 *pos " + FindPoint("강당가스2") + " *aabb -20 -20 -20 20 20 20 *velocity 3");
}

