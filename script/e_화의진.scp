		SendMessage("바닥글씨화", "발광", "Recursive off");
		DeleteObject("바닥글씨화");

		SendMessage("카메라", "포그", "50 6000 f66a1e 0 0.6 -10");
		SetTimer(10, "_포그끄기");
		RunScript("","e_바닥불._del");

		DeleteObject("강당불놀이상");
		DeleteObject("강당불놀이하");
		DeleteObject("강당불놀이하_1");
		DeleteObject("강당불놀이좌");
		DeleteObject("강당불놀이우");

		DeleteObject("강당불놀이상1");
		DeleteObject("강당불놀이하1");
		DeleteObject("강당불놀이하1_1");
