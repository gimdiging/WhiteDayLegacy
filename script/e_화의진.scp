{
	LoadObject("WObjFirePlane", "강당불놀이하2_1", "*area " + GetEventAABB("불북서충돌") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 1 *progresstime 5.0f *num 1 *direction 0 *col 2");
	LoadObject("WObjFirePlane", "강당불놀이상2", "*area " + GetEventAABB("불북서쪽") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 5.0f *num 60 *direction 0 *col 2");
	LoadObject("WObjFirePlane", "강당불놀이하2", "*area " + GetEventAABB("불북서쪽") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 1 *progresstime 5.0f *num 60 *direction 0 *col 2");
	LoadObject("WObjFirePlane", "강당불놀이좌2", "*area " + GetEventAABB("불북서쪽") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 2 *progresstime 5.0f *num 60 *direction 0 *col 2");
	LoadObject("WObjFirePlane", "강당불놀이우2", "*area " + GetEventAABB("불북서쪽") + " *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 3 *progresstime 5.0f *num 60 *direction 0 *col 2");
}

