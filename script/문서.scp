pick()
{
	if(GetObjValue("Step") == 3)
		return "";

	if($G_LightFactor < $standard_light && (GetObjValue("switchLight") == 0 || (GetObjValue("switchLight") == 1 && TakeObjValue(GetObjValue("switchName"), "상태") == OFF)))
		return "보기";	

	return GetObjValue("Step") < GetObjValue("look_count") ? "보기" : "잡기";
}

click()
{	
	if($G_LightFactor < $standard_light && (GetObValue("switchLight") == 0 || (GetObjValue("switchLight") == 1 && TakeObjValue(GetObjValue("switchName"), "상태") == OFF)))
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));
		return;
	}

	if(GetObjValue("Step") < GetObjValue("look_count"))
	{
		SetObjValue("Step", GetObjValue("Step") + 1);
		SendMessage("자막", "문자출력후대기", "" + GetObjValue("info_look" + GetObjValue("Step")));
		return;
	}
	
	$다이어리문서개수++;
	SendMessage("다이어리", "획득", GetObjValue("papername"));
	SendMessage("자막", "문자출력", "3," + GetObjValue("info_get"));
	SendMessage("", "페이드", "Recursive 1 1 0");
	SetValue("$b_" + GetObjValue("ObjName"), 1);
	SetObjValue("Step", 3);
	SetTimer(1,"Release");			
	SendMessage("사운드", "연주", "data/sound/아이템획득.wav");			
	
	
	if(GetObjValue("ObjName") == "쪽지03")
		$Mission2_공이벤트 = TRUE;

	if(GetObjName() == "알림1")
		DeleteObject("알림2");

	if(GetObjName() == "알림2")
		DeleteObject("알림1");
}

Release()
{
	DeleteObject("");	
}

///////////////////////////////////////////////////////////////////////////////////////
//
//	 보기만 하는 문서들.
//
///////////////////////////////////////////////////////////////////////////////////////

InitRead()
{
	SendMessage("", "스크립트설정", "item " + $G_File + ".Read");
	SetObjValue("data","");	
	if(GetValue("$b_" + GetObjValue("ObjName")) == 1)
		SendMessage("", "반짝", "off");
}

Read.pick()
{
	return "보기";
}

Read.click()
{
	if($G_LightFactor < $standard_light)
		SendMessage("자막", "문자출력후대기", GetString("s4"));
	else
	{
		SendMessage("자막", "문자출력후대기", GetObjValue("data"));
		SendMessage("", "반짝", "off");
		SetValue("$b_" + GetObjValue("ObjName"), 1);
	}
}

Init테스트()
{
	InitRead();
	SetObjValue("data", GetWDBItem("diary.wdb", "학원괴담 (4)", "내용"));
}