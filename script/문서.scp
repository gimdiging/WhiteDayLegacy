Init()
{
	SendMessage("", "스크립트설정", "item " + $G_File);
	SendMessage("", "픽거리설정", "170 200");
	SetObjValue("Step", 0);
	SetObjValue("look_count", 1);
	SetObjValue("switchLight", 0);
	SetObjValue("switchName", "");
	SetObjValue("switchLight", 0);
}


