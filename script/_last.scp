_last시작()
{
	SendMessage("허드", "라스트맵켜", "" );
	$AI_유령성아 = ON;
	SendMessage("유령성아", "위치", "" + FindPoint("시작위치"));
	SetTimer(0, "캐릭터_성아._유령성아.첨부터 *obj 유령성아");
	LoadObject("WObjFirePlane", "불a", "*area -387.00 0.00 34.03 -363.83 34.35 94.73 *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 10 *col 2 *script _last.test.fire *list *pick");
	LoadObject("WObjFirePlane", "불b", "*area -437.11 0.00 349.83 -414.75 45.93 409.46 *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 10 *col 2 *script _last.test.fire *list *pick");
	LoadObject("WObjFirePlane", "불c", "*area 320.96 0.00 515.90 383.56 44.60 549.44 *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 10 *col 2 *script _last.test.fire *list *pick");
	LoadObject("WObjFirePlane", "불d", "*area 64.91 0.00 -179.91 95.05 52.18 -148.31 *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 10 *col 2 *script _last.test.fire *list *pick");
	LoadObject("WObjFirePlane", "불e", "*area 384.17 0.00 -305.29 414.61 39.11 -294.67 *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 10 *col 2 *script _last.test.fire *list *pick");
	LoadObject("WObjFirePlane", "불f", "*area 611.10 0.00 -638.76 629.66 39.03 -608.86 *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 10 *col 2 *script _last.test.fire *list *pick");
	LoadObject("WObjFirePlane", "불g", "*area -639.89 0.00 -360.27 -609.58 39.04 -343.87 *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 10 *col 2 *script _last.test.fire *list *pick");
	LoadObject("WObjFirePlane", "불h", "*area -210.61 0.00 -446.29 -178.93 18.37 -416.86 *sprsizex 32.0f *sprsizey 32.0f *sizex 128.0f *sizey 128.0f *firetype 0 *progresstime 0.1f *num 10 *col 2 *script _last.test.fire *list *pick");
	if($게임모드 != 0 && $게임모드 != 4)
	SendMessage("허드", "가스게이지켜", "500");
}

_last끝()
{
	SendMessage("유령성아", "Stop", "");
	$AI_유령성아 = OFF;
	SendMessage("유령성아", "페이드", "Recursive 3 1 0");
	if($게임모드 != 0 && $게임모드 != 4)
	SendMessage("허드", "가스게이지꺼", "");
}

test.fire.Collision()
{
}

test.fire.Init()
{
	SetObjValue("밝기", 1.0);
}

test.fire.Damage()
{
	SetObjValue("밝기", GetObjValue("밝기") - 0.1);

	if (GetObjValue("밝기") < 0.1)
	{
		SendMessage("유령성아", "위치", "" + GetObjPos("유저"));
		DeleteObject("");
		return;
	}

	SendMessage("", "사이즈변환", GetObjValue("밝기") + " 1");
}