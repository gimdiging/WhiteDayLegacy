Create()
{
	RunScript("","_testValue.Init");

	$현재스테이지 = "미궁";
	RunScript("", "_whiteday.StartBanner");

	LoadWed("data/last.wep", 1);

	LoadObject("WObjParticle", "파티", "");
	SetTimer(0, "Create_init");
}

Create_init()
{
	LoadObject("WObjStaticBody", "구름", "*scale 2.0 *motion 회전 *pos 0 0 0 *nolight *matchcam *pet data/puppet/effect/구름/구름.pet *showall *group 0");

	SendMessage("유저", "위치", "" + FindPoint("시작위치"));
	LoadObject("WTune", "오디오BGM", "");
	LoadObject("WTune", "오디오폰", "");

	SendMessage("배경", "bspmode", "4");



//SendMessage("오디오BGM", "연주이어서", "2 data/sound/bgm/라스트/@lastbgm_루프.adp");
//SendMessage("오디오BGM", "연주이어서", "-1 data/sound/bgm/라스트/lastbgm_끝.adp");
}

_로딩후시작()
{
	SendMessage("자막", "비활성", "");
	SendMessage("매크로", "Play", "sc56.cut01");
}

_lastmacro()
{
	// 이부분은 세이브 후에 부릅니다.
	SendMessage("매크로", "Play", "sc56.cut01");
}

Destroy()
{
	DeleteObject("오디오BGM");
	DeleteObject("오디오폰");
	DeleteObject("구름");
	DeleteObject("파티");
	RunScript("", "_whiteday.ResetMainGameObject");
}

_엔딩으로()
{
	RunScript("유저", "_last.Destroy");

	SetTimer(0, "_staffroll._시작");
}

Create4Debug()
{

	LoadObject("WObjPlayer", "유저", "*ai 오브젝트_유저._유저 *gravity");
	SendMessage("유저", "위치", "" + FindPoint("시작위치"));
	SendMessage("유저", "캡춰", "카메라 머리");
	SendMessage("허드", "켜기", "normal");
	SendMessage("타이머", "스크립트설정", "0 0 1 _last._게임시작");
	SendMessage("main", "게임시작", "시작");
}

ScriptMain()
{
	Create();
	Create4Debug();
}

