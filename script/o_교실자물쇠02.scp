Init()
{
	SendMessage("", "스크립트설정", "lock " + $G_File);
	SetObjValue("KeyName", "마스터키");
	SetObjValue("iconname", "마스터키");
	SetObjValue("열쇠버리기",0);// 0이면안버리기 1이면버리기
}

Init남자탈의실잠김()
{
	Init();
	SetObjValue("Lock", "$체육관_영호_남자탈의실잠김");
	SetObjValue("KeyName", "열쇠9");
	SetObjValue("iconname", "열쇠9");
	if($체육관_영호_남자탈의실잠김 ==  UNLOCK)
		DeleteObject("");	
}

