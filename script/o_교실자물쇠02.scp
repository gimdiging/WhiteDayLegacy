Init중앙통로자물쇠()
{
	Init();
	SetObjValue("Lock", "$문_중앙통로");
	SetObjValue("KeyName", "중앙통로열쇠");
	SetObjValue("iconname", "중앙통로열쇠");
	SetObjValue("열쇠버리기", 1);
	SendMessage("", "페이드", "Tube 0 1 0");
	SendMessage("", "페이드", "Tube_leave 0 1 0");
	SendMessage("", "발광", "Recursive on");
	if($문_중앙통로 ==  UNLOCK)
		DeleteObject("");	
}

pick()
{
	$KeyName = GetObjValue("KeyName");
	$Lock = GetValue(GetObjValue("Lock"));

	if ($Lock == LOCK)
	{
		if($본관1_세환_교실앞대화 == FALSE && $G_UserItem == "마스터키")
		if(GetObjValue("Lock") == "$문_산악동아리" || GetObjValue("Lock") == "$문_사진동아리" || GetObjValue("Lock") == "$문_체육창고앞")
			return "자동후진";

		if($G_UserItem == $KeyName)		
			return "i" + GetObjValue("iconname");
		
		return "잡기";
	}
	return "";
}

click()
{
	$KeyName  = GetObjValue("KeyName");
	$Lock = GetValue(GetObjValue("Lock"));	

	if($Lock == LOCK)
	{
		if(GetObjValue("Lock") == "$문_교실2_8앞" && $G_UserItem == "마스터키")
		{
			SendMessage("자막", "문자출력후대기", GetString("s32"));
			return;
		}

		if($본관1_세환_교실앞대화 == FALSE && $G_UserItem == "마스터키")
		{
			if(GetObjValue("Lock") == "$문_산악동아리" || GetObjValue("Lock") == "$문_사진동아리" || GetObjValue("Lock") == "$문_체육창고앞")
			{
			SendMessage("사운드", "연주", "조작불가.wav");
			SendMessage("자막", "문자출력후대기", GetString("s910"));
			return;
			}
		}

		SendMessage("", "시끄러워", "1");

		if($G_UserItem == $KeyName)
		{
			SendMessage("", "페이드", "ja 1 1 0");
			if(GetObjValue("Lock") != "$문_중앙통로")
				SendMessage("", "페이드", "Tube 1 1 0");
			
			SendMessage("사운드", "연주", "열쇠로자물쇠열기,열쇠로자물쇠열기.wav");

			if($KeyName == "마스터키")
				$마스터키Unlock++;

			if($KeyName == "열쇠9")
			$문_탈의실++;

			if(GetObjValue("열쇠버리기") == 1 || $마스터키Unlock == 23 || $문_탈의실 == 2)
			{
				if($마스터키Unlock == 23)
					$마스터키Unlock++;

				SendMessage("유저", "폐기", "@" + $G_UserItem);
				SendMessage("자막", "문자출력후대기", GetString("s29"));
			}
			else
				SendMessage("자막", "문자출력후대기", GetString("s30"));

			if(GetObjValue("Lock") == "$체육관_영호_남자탈의실잠김")
				RunScript("남자탈의실문","강당문.lockon");

			if(GetObjValue("Lock") == "$체육관_영호_여자탈의실잠김")
				RunScript("여자탈의실문","강당문.lockon");

			if (GetObjValue("Lock") == "$문_중앙통로")
				SendMessage("문_중앙통로", "캐쉬초기화", "");

			SetValue(GetObjValue("Lock"), UNLOCK);			

			if (GetObjValue("Lock") == "$문_체육창고앞")
				$문_체육창고뒤 = UNLOCK;	

			if (GetObjValue("Lock") == "$문_교실2_2앞")
				$문_교실2_2뒤 = UNLOCK;			

			if (GetObjValue("Lock") == "$문_학생부실B")
				$문_학생부실A = UNLOCK;	
		}
		else
		{
			SendMessage("", "애니메이션", "흔들기");
			SendMessage("사운드", "연주", "자물쇠소리,data/sound/자물쇠흔드는소리.wav");
			SendMessage("자막", "문자출력후대기", GetString("s31"));
		}
	}
}
