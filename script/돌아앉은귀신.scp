Event0()
{
	if($b_음악실거미 == 0 || $음악감상실귀신진행 == 2)
		return;

	DeleteObject(""); //EventArea
	SendMessage("자막", "활성화", "");
	LoadObject("WObjNPC", "돌아앉은귀신1","*scale 1.00 *pet 성아캔01.pet  *block 0 *group -1 *optimize *pos 1792 -36 1522  *rot 0.00 90.00 0.00 *FlagShow 1 *Show 1");
	SendMessage("돌아앉은귀신1", "발광", "Recursive on");
	SendMessage("배경", "끄기", "b1-4");
	SendMessage("돌아앉은귀신1", "쳐다보기", "유저");
	SendMessage("유저", "쳐다보기", "돌아앉은귀신1");
	SendMessage("사운드", "연주", "data/sound/나영웃음.wav");
	SetTimer(5, "돌아앉은귀신.start");
	SendMessage("타이머", "스크립트설정", "3 0 1 돌아앉은귀신.Event1");
}

Event1()
{
	SendMessage("돌아앉은귀신1", "페이드", "Recursive 1 1 0");
	SendMessage("타이머", "스크립트설정", "1 0 1 돌아앉은귀신.Event2");
}

Event2()
{
	SendMessage("유저", "쳐다보지말기", "");
