damage0()
{
	$음악감상실귀신실패++;
	if($음악감상실귀신실패 == 3 || $음악감상실귀신실패 == 4)
	{
	SendMessage("유저", "heal", "-100");
	}
	if($음악감상실귀신실패 == 5)
	{
	SendMessage("유저","아이템장비","취소");
	RunScript("", "오브젝트_유저._유저.dead");
	SetTimer(20,"randompos");
	}
	else
	SetTimer(10,"randompos");

	SetTimer(0,"taeguek");
	SendMessage("돌아선귀신", "발광", "Recursive on");
	SendMessage("돌아앉은귀신", "발광", "Recursive on");
	SendMessage("돌아앉은귀신","애니메이션","%sc46_cut06_소영.mtn");
	SendMessage("돌아선귀신","애니메이션","%sc46_cut06_소영.mtn");
	$음악감상실귀신++;
	$음악감상실귀신_집지마 = 1;
	SendMessage("카메라", "카메라떨림", "40 30 2");
	SendMessage("카메라", "카메라떨림", "30 25 3");
	SendMessage("카메라", "카메라떨림", "20 20 3");
	SendMessage("카메라", "공격", "-100 30 10 75 200 5");
	LoadObject("WObjPanel", "", "*diffuse ff0000 *delay 1 *type 1");
	RunScript("","_whiteday.FlashBack");
	SendMessage("허드", "더하기BPM", "130");
	if($음악감상실귀신 == 9)
	SetTimer(5,"end");
}

damage1()
{
	if($음악감상실귀신진행 == 2)
		return;
	
	if($음악감상실귀신비교 == 1 && $음악감상실귀신 == 0)
	SetTimer(0,"damage0");
}
