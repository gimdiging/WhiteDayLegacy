push()
{
	if($신관_세환_버튼누름방지 == ON)
		return;

	if($신관_세환_녹음기버튼번호 == $신관_세환_녹음기이전버튼번호 && $신관_세환_녹음기버튼번호 != 5)
		return;

	if($신관_세환_테이프있나 == 2)
		SendMessage("자막", "문자출력후대기", GetString("s6"));

	if($신관_세환_녹음기이전버튼번호 != 5)
		RunScript("신관음악실녹음기",$G_File + ".spring");		
	else
		SendMessage("사운드", "연주", "data/sound/카세트start.wav");			

	$신관_세환_녹음기이전버튼번호 = $신관_세환_녹음기버튼번호;
	
	switch($신관_세환_녹음기버튼번호)
	{
		case 1:
			SendMessage("신관음악실녹음기","본이동","play 0 0 0");
			SendMessage("신관음악실녹음기","발광","play on");
			break;
		case 2:
			SendMessage("신관음악실녹음기","본이동","rec 0 0 0");
			SendMessage("신관음악실녹음기","발광","rec on");
			break;
		case 3:
			SendMessage("신관음악실녹음기","본이동","rew 0 0 0");
			SendMessage("신관음악실녹음기","발광","rew on");
			break;
		case 4:
			SendMessage("신관음악실녹음기","본이동","ffw 0 0 0");
			SendMessage("신관음악실녹음기","발광","ffw on");
			break;
		case 5:
			SendMessage("신관음악실녹음기","본이동","stop 0 0 0");
			SendMessage("신관음악실녹음기","발광","stop on");
			SetTimer(1,"spring");
			$신관_세환_버튼누름방지 = ON;
			break;		
	}
}

spring()
{
	SendMessage("사운드", "연주", "data/sound/카세트start.wav");			

	switch($신관_세환_녹음기이전버튼번호)
	{
		case 0:
			break;		
		case 1:
			SendMessage("신관음악실녹음기","본이동","play 0 -0.2 0.2");
			SendMessage("신관음악실녹음기","발광","play off");
			break;
		case 2:
			SendMessage("신관음악실녹음기","본이동","rec 0 -0.2 0.2");
			SendMessage("신관음악실녹음기","발광","rec off");
			break;
		case 3:
			SendMessage("신관음악실녹음기","본이동","rew 0 -0.2 0.2");
			SendMessage("신관음악실녹음기","발광","rew off");
			break;
		case 4:
			SendMessage("신관음악실녹음기","본이동","ffw 0 -0.2 0.2");
			SendMessage("신관음악실녹음기","발광","ffw off");
			break;
		case 5:
			SendMessage("신관음악실녹음기","본이동","stop 0 -0.2 0.2");			
			SendMessage("신관음악실녹음기","발광","stop off");
			$신관_세환_버튼누름방지 = OFF;
			break;
	}
}
