Init()
{
	SendMessage("", "스크립트설정", "button " + $G_File + ".button");
	SendMessage("", "스크립트설정", "cover_case " + $G_File + ".change");
	SendMessage("", "스크립트설정", "play_button " + $G_File + ".push1");
	SendMessage("", "스크립트설정", "rec_button " + $G_File + ".push2");
	SendMessage("", "스크립트설정", "rew_button " + $G_File + ".push3");
	SendMessage("", "스크립트설정", "ffw_button " + $G_File + ".push4");
	SendMessage("", "스크립트설정", "stop_button " + $G_File + ".push5");
	
	SetObjValue("함보기", 0);

	SetObjValue("Step", 0);

	SetObjValue("MotionName" , "");
	SendMessage("", "페이드", "band_twist 0 0 0");

	SendMessage("","본이동","play 0 -0.2 0.2");
	SendMessage("","본이동","rec 0 -0.2 0.2");
	SendMessage("","본이동","rew 0 -0.2 0.2");
	SendMessage("","본이동","ffw 0 -0.2 0.2");
	SendMessage("","본이동","stop 0 -0.2 0.2");

	SendMessage("","발광색","play 128 255 128");
	SendMessage("","발광색","rec 128 255 128");
	SendMessage("","발광색","rew 128 255 128");
	SendMessage("","발광색","ffw 128 255 128");
	SendMessage("","발광색","stop 255 128 128");

	if($신관_세환_벨트있나 != 1)
	{
		SendMessage("", "페이드", "band 0 0 0");
		SendMessage("", "페이드", "cover 0 0 0");
	}
}

button.pick()
{
	if($수위추적모드 == ON)
		return "자동후진";

//	if(GetObjValue("함보기") == 0 || $G_LightFactor <= $standard_light)
		return "보기";

//	return "잡기";
}

button.click()
{
	if($수위추적모드 == ON)
	{
		SendMessage("사운드", "연주", "조작불가.wav");
		SendMessage("자막", "문자출력", "3," + GetString("s12"));
		return;
	}

	if($G_LightFactor < $standard_light)
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));	
		return;
	}

	if(GetObjValue("함보기") == 0)
	{
		SendMessage("자막", "문자출력후대기", GetString("s44"));
		SetObjValue("함보기",1);
		return;
	}

	SendMessage("자막", "문자출력후대기", GetString("s45"));
}

push1.pick()
{
	if(GetObjValue("함보기") == 0 || $G_LightFactor <= $standard_light)
		return "보기";

	return "잡기";
}

push1.click()
{
	if($G_LightFactor < $standard_light)
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));	
		return;
	}

	if(GetObjValue("함보기") == 0)
	{
		SendMessage("자막", "문자출력후대기", GetString("s44"));
		SetObjValue("함보기",1);
	}

	$신관_세환_녹음기버튼번호 = 1;
	SetTimer(0.5,"push");
}

