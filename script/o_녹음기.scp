change.pick()
{
	if($b_음악실거미 == 0 || $음악감상실귀신진행 != 2)
		return "자동후진";

	if($수위추적모드 == ON)
		return "자동후진";

	if(GetObjValue("함보기") == 0 || $G_LightFactor <= $standard_light)
		return "보기";

	if($신관_세환_벨트있나 == 1)
		return "잡기";

	if($G_UserItem == "고무벨트")
		return "i고무벨트";

	return "보기";
}

change.click()
{
	if($수위추적모드 == ON)
	{
		SendMessage("사운드", "연주", "조작불가.wav");
		SendMessage("자막", "문자출력", "3," + GetString("s12"));
		return;
	}

	if($b_음악실거미 == 0 || $음악감상실귀신진행 != 2)
	{
		SendMessage("사운드", "연주", "조작불가.wav");
		SendMessage("자막", "문자출력후대기", GetString("s910"));	
		return;
	}

	if($G_LightFactor < $standard_light)
	{
		SendMessage("자막", "문자출력후대기", GetString("s4"));	
		return;
	}

	if(GetObjValue("함보기") == 0)
	{
		SendMessage("자막", "문자출력후대기", GetString("s44"));
		SetObjValue("함보기",1);
		if($게임모드 != 0 && $게임모드 != 4)
		SendMessage("허드", "가스게이지꺼", "");
		$문_신관화장실 = UNLOCK;
		return;
	}

	if($신관_세환_벨트있나 == 1)
	{		
		if(GetObjValue("함보기") == 1)
		{
			SendMessage("신관음악실녹음기", "페이드", "cover 1 1 0");
			SendMessage("자막", "문자출력후대기", GetString("s46"));
			SetObjValue("함보기",2);
			$b_카세트열기 = 1;			
			return;
		}

		SendMessage("자막", "활성화", "");
		SendMessage("자막", "와이드모드", "켜기");
		SetTimer(0.5,"getvelt");
	}	
	else if($G_UserItem == "고무벨트")	
	{		
		SendMessage("신관음악실녹음기", "페이드", "band 1 0 1");	
		$신관_세환_벨트있나 = 1;		
		SendMessage("유저", "폐기", "@고무벨트");
		SendMessage("신관음악실녹음기", "캐쉬초기화", "");
	}
	else	
		SendMessage("자막", "문자출력후대기", GetString("s47"));	
}

getvelt()
{ 	
	SendMessage("자막", "실행함수", "o_녹음기.getvelt3");
	SendMessage("자막", "선택", GetString("s226"));
}

getvelt3()
{
	switch($G_UserSelect)
	{
		case 0:
			$신관_세환_벨트있나 = 0;	
			SetTimer(1,"fade");
			SendMessage("유저", "획득", "고무벨트");
			SendMessage("자막", "문자출력", "3," + GetString("it_102"));

			if($신관_세환_어학실이벤트 == FALSE)
			{
				SendMessage("지현", "애니메이션", "정지");
				SendMessage("지현", "위치", "0 0 0");
				$신관_세환_어학실이벤트 = TRUE;
			}
			break;

		case 1:			
			break;
	}

	SendMessage("자막", "와이드모드", "끄기");
	SendMessage("자막","비활성","");
}

fade()
{
	SendMessage("신관음악실녹음기", "페이드", "band 1 1 0");
}