			{
				$신관_세환_오른쪽앞스피커 = 0;
				$신관_세환_소리강도 = $신관_세환_소리강도 - 1;
				_stop();	
				TextOut("Waa");	// debug
			}
			break;
		case 3:
			if($신관_세환_왼쪽뒤스피커 != 0)
			{
				$신관_세환_왼쪽뒤스피커 = 0;
				_stop();			
