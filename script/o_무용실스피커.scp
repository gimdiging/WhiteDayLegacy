*/	
	$USER_CAPTUREITEM = TRUE;
	$신관_세환_스피커 = TRUE;
	SendMessage("유저", "캡춰", GetObjName() + " 팔");
	SendMessage("", "페이드", "Recursive 0 0.5 0.5");
	SendMessage("", "애니메이션", "서있기");
	$신관_세환_스피커이름 = GetObjName();
	$이동속도 = $이동속도 * 0.5;
	SendMessage("유저", "이동속도", "" + $이동속도);	
	SendMessage("배경", "끄기", "b1-5");	
	_stop();
}

_play()
{
	if($신관_세환_오디오전원 == ON)
	{
		if($신관_세환_스피커이름 == "오른쪽스피커")
		{
			SendMessage("오른쪽스피커", "애니메이션", "작동");
			SendMessage("사운드", "SetVolume", $신관_세환_오른쪽사운드 + " 1");			
		}
		else if($신관_세환_스피커이름 == "왼쪽스피커")
		{
			SendMessage("왼쪽스피커", "애니메이션", "작동");
			SendMessage("사운드", "SetVolume", $신관_세환_왼쪽사운드 + " 1");			
		}		
	}
}

_stop()
{
	if($신관_세환_오디오전원 == ON)
	{
		if($신관_세환_스피커이름 == "오른쪽스피커")
		{
			SendMessage("오른쪽스피커", "애니메이션", "*서있기");
			SendMessage("사운드", "SetVolume", $신관_세환_오른쪽사운드 + " 0");			
		}
		else if($신관_세환_스피커이름 == "왼쪽스피커")
		{
			SendMessage("왼쪽스피커", "애니메이션", "*서있기");
			SendMessage("사운드", "SetVolume", $신관_세환_왼쪽사운드 + " 0");			
		}		
	}
}

audio_on()
{
	if($신관_세환_오디오전원 == ON)
	{
		SendMessage("오른쪽스피커","애니메이션","작동");
		SendMessage("왼쪽스피커","애니메이션","작동");

		SendMessage("사운드","연주3d", GetObjPos("오른쪽스피커") + " 오른쪽오디오사운드,최면01.wav"); 
		SendMessage("사운드","연주3d", GetObjPos("왼쪽스피커") + " 왼쪽오디오사운드,최면01.wav");
		SetTimer(62, "repeat");
	}
}

audio_off()
{
	SendMessage("오른쪽스피커", "애니메이션", "*서있기");
	SendMessage("왼쪽스피커", "애니메이션", "*서있기");
	SendMessage("사운드", "연주멈춤", "" + $신관_세환_오른쪽사운드);
	SendMessage("사운드", "연주멈춤", "" + $신관_세환_왼쪽사운드);	
}

repeat()
{
	if($신관_세환_오디오전원 == OFF)
		return;

	SendMessage("사운드","연주3d", GetObjPos("오른쪽스피커") + " loop,오른쪽반복사운드,최면02.wav"); 
	SendMessage("사운드","연주3d", GetObjPos("왼쪽스피커") + " loop,왼쪽반복사운드,최면02.wav");
	$신관_세환_오른쪽사운드 = "오른쪽반복사운드";
	$신관_세환_왼쪽사운드 = "왼쪽반복사운드";	
}
