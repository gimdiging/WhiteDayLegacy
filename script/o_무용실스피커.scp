Init()
{
	SendMessage("", "스크립트설정", "speaker " + $G_File);		// 잡기
	SendMessage("", "스크립트설정", "dummy null");
	SendMessage("", "애니메이션", "서있기");

	SetObjValue("step" , 0);
	SetObjValue("setting", OFF);
	SendMessage("", "중력", "on");	
}

Init가짜()
{	
	SendMessage("", "애니메이션", "서있기");
	SendMessage("", "중력", "on");	
}

pick()
{	
	if($신관_세환_무용실이벤트 == 2 || GetObjValue("setting") == ON || $USER_CAPTUREITEM == TRUE)
	{
		SendMessage("", "캐쉬초기화", "");		
		return "";
	}

	if($G_LightFactor <= $standard_light)
		return "보기";

	if($신관_세환_오디오전원 == OFF)
		return "보기";

	return "잡기";
}

click()
{
	if($G_LightFactor < $standard_light)
	{
		TextOut(GetString("s4"));
		return;
	}

	if($신관_세환_오디오전원 == OFF)
	{
		SendMessage("자막", "문자출력후대기", GetString("s56"));
		return;
	}
