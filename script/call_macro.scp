_10b()
{
	if($수위추적모드 == ON)
		return;

	//열쇠를 얻었을때.
	if($진행루트 == 0)
		return;

	if ($EnterObj == "소영")
	{
		$본2_영호_소영b루트도착변수 = 1;
		if($본2_영호_유저교무실앞이동중 == 1)
		{
			DeleteObject("");
			if($_10b == 0)
			{
				$_10b = 1;
				SendMessage("매크로", "Play", "sc35.cut01");
			}
		}
		return;
	}

	if ($EnterObj == "유저")
	{
		$본2_영호_유저교무실앞이동중 = 1;
		if($본2_영호_소영b루트도착변수 == 1)
		{
			$본2_영호_유저교무실앞이동중 = 0;
			DeleteObject("");
			
			if($_10b == 0)
			{
				$_10b = 1;						
				SendMessage("매크로", "Play", "sc35.cut01");			
			}
		}
		
	}

}

