_09a_1()
{
	if($수위추적모드 == ON)
		return;

// 이벤트 박스로 호출되지 않는다. 함수호출
	if($진행루트 == 1)
		return;
	
	if($_09a_1 == 0)
	{
		$_09a_1 = 1;

		RunScript("정찰용수위", "캐릭터_수위.Disable");	
		SendMessage("매크로", "Play", "sc09.cut01");
	}
}

