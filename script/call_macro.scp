_1()
{				
	DeleteObject("");
	if($본관1_세환_기계실앞대화 == FALSE)
	{
		$본관1_세환_기계실앞대화 = TRUE;		
		SendMessage("매크로", "Play", "sc01.cut01");
		RunScript("문_시작통로", "문_본관1.열려라참깨");
	}
}

_2()
{	
	DeleteObject("");
	if($본관1_세환_알람이벤트 == FALSE && $b_가정실습실열쇠 == 1)
	{
		$본관1_세환_알람이벤트 = TRUE;
		SendMessage("매크로", "Play", "sc03.cut01");
	}
}

_3()
{				
	DeleteObject("");
	if($본관1_세환_학적부실이벤트 == FALSE)
	{
		RunScript("성아", "캐릭터_성아._성아.Disable");
		SendMessage("성아", "위치", "0 0 0");
		$본관1_세환_학적부실이벤트 = TRUE;
		SendMessage("매크로", "Play", "sc03-1.cut01");				
		SendMessage("개구멍막기", "켜기", "");
		SendMessage("기계실막기", "켜기", "");
		SendMessage("화장실막기", "켜기", "");			
	}
}

_5()
{	
	if($본관1_세환_시작통로2층 == CLOSE || $본관1_세환_교실앞대화 == TRUE || $수위추적모드 == ON || $b_번개 == 0)
		return;
	
	DeleteObject("");
	
	$매크로전_문상태 = TakeObjValue("문_중앙통로2층", "OpenFlag");
	SendMessage("문_중앙통로2층", "애니메이션", "*서있기");
	ChangeObjValue("문_중앙통로2층", "OpenFlag", 0);		
	
	SendMessage("소영", "쳐다보지말기", "");
	RunScript("정찰용수위", "캐릭터_수위.Disable");	
	$본관1_세환_교실앞대화 = TRUE;	
	SendMessage("매크로", "Play", "sc05.cut01");	
}

_소영등장()
{
	if(Version() != "Demo" && $G_금의진해결 == TRUE && $본관1_세환_교실앞대화 == FALSE && $본관1_세환_시작통로2층 == CLOSE)
	{
		DeleteObject("");
		$AI_소영 = ON;
		SendMessage("소영", "좋은위치", "" + FindPoint("목이벤트전소영위치"));
		SendMessage("소영", "애니메이션", "서있기");
		SendMessage("소영", "쳐다보기", "유저");
		SendMessage("소영", "회전", "0");
		$본관1_세환_시작통로2층 = OPEN;
	}

	if($b_나영다시등장 == 1)	
		$b_나영다시등장 = 2;				
}

_6()
{			
	if($본관1_세환_방송실이벤트 == FALSE && $b_목의조각 == 1 && $수위추적모드 == OFF)
	{				
		DeleteObject("");
		$본관1_세환_방송실이벤트 = TRUE;
		RunScript("정찰용수위", "캐릭터_수위.Disable");	
		SendMessage("매크로", "Play", "sc07.cut01");			
		$문_2층방화셔터 = UNLOCK;
		return;
	}	
}

