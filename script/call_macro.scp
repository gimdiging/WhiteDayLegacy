_12b_1()	// 역사관 앞에 소영이와 둘이 도착했을 때
{		
	if($신관_세환_역사관앞대화 == FALSE)		
	{
	$신관_세환_역사관앞대화 = TRUE;
	RunScript("문_역사관1","문_본관1._닫쳐있어");
	RunScript("문_역사관2","문_본관1._닫쳐있어");
	RunScript("문_역사관3","문_본관1._닫쳐있어");
	RunScript("문_역사관4","문_본관1._닫쳐있어");
	RunScript("소영", "캐릭터_소영._소영.Disable");

	SendMessage("매크로", "Play", "sc48.cut01");	
	}
}

_12b_2()	// 일정거리 이상 벗어나서 소영이 문을 열 경우
{	
	if($진행루트 == 1 && $신관_세환_캔커피이벤트 == 0 && $신관_세환_신관앞대화 == TRUE)
	{		
		DeleteObject("");
		$신관_세환_캔커피이벤트 = 1;
		SendMessage("매크로", "Play", "sc43.cut01-1");
	}
}

_12b_3()	// 유저가 문을 열었을 경우
{
	$신관_세환_캔커피이벤트 = 1;
	ChangeObjValue("문_휴계실", "No_Auto", 0);
	SendMessage("매크로", "Play", "sc43.cut01");	
}

_12b_4()	// 소영이가 노란색 카드키로 문 열어주는 매크로
{
	if($신관_세환_홀진입문앞대화 == FALSE)
	{
		$신관_세환_홀진입문앞대화 = TRUE;
		RunScript("소영", "캐릭터_소영._소영.Disable");
		SendMessage("매크로", "Play", "sc50.cut00");
	}
}

// 커피캔 이벤트 관련..

NoAction()
{	
	if($신관_세환_캔커피이벤트 == 1)
	{
		$신관_세환_캔커피이벤트 = 2;		

		$대화단계 = 0;
		$대화_소영 = "_대화12B_3";
		$대화상태 = OFF;
		SendMessage("소영", "캐쉬초기화", "");

		if($신관_세환_휴계실에있나 == TRUE)
		{
			SendMessage("자막", "활성화", "");
			RunScript("", "_whiteday.FadeOut");						
			SetTimer(2, "_소영역사관으로");
		}
		else					
		{
			SendMessage("소영", "좋은위치", "" + FindPoint("소영역사관으로"));	
			SendMessage("소영", "이동", FindPoint("소영마중나오기") + " 걷기 *script 캐릭터_소영._소영.따라가기");						
		}
	}
}

_소영역사관으로()
{
	SendMessage("소영", "애니메이션", "서있기");
	SendMessage("소영", "좋은위치", "" + FindPoint("소영역사관으로"));	
	SendMessage("자막", "말하는사람", "소영");
	SendMessage("자막", "다이얼로그출력", "d12b_043b");	
	
	RunScript("소영", "캐릭터_소영.따라가기");
	RunScript("", "_whiteday.FadeIn");
	SendMessage("자막", "비활성", "");
}

restingroom_in()
{
	$신관_세환_휴계실있나 = TRUE;

	if($신관_세환_캔커피이벤트 == 1)
	{
		SendMessage("유저", "찾기아이템", "캔커피 $신관_세환_캔커피소지");			
		SendMessage("소영", "캐쉬초기화", "");
	}
}

restingroom_out()
{
	$신관_세환_휴계실있나 = FALSE;
}

