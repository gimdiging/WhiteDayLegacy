_11a_1()
{
	if($수위추적모드 == ON)
		return;

	if($본2_영호_음악실이벤트완료 != 2)
		return;
	DeleteObject("");
	if($진행루트 == 1)
		return;

	if($대화_10 == 3)
		return;

	if($대화_10 == 2 && $지현_호감도 < $지현_호감도기준1)
		return;
	
	if($_11a_1 == 0)
	{
		$_11a_1 = 1;

		SendMessage("매크로", "Play", "sc12.cut01");
	}
}

