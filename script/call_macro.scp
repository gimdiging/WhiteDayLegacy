// A,B 루트 분기에서 결정을 못 했을 경우
select()
{
	if($본관1_세환_분기결정 == FALSE)
	{
		$본관1_세환_분기결정 = TRUE;		
		SendMessage("자막", "선택아이템", "0");		
		SendMessage("매크로", "Play", "sc08.cut01");		
	}
}

into_history()
{
	if($진행루트 == 0 || $신관_세환_캔커피이벤트 == 0 || $신관_세환_역사관앞대화 == TRUE)
		return;

	switch($EnterObj)
	{
		case "유저":
			if($신관_세환_역사관앞도착 == 2)
			{
				$신관_세환_역사관앞도착 = 3;
				_12b_1();
			}
			else if($신관_세환_역사관앞도착 == 0)
				$신관_세환_역사관앞도착 = 1;

			break;

		case "소영":
			if($신관_세환_역사관앞도착 == 1)
			{
				$신관_세환_역사관앞도착 = 3;
				_12b_1();
			}
			else if($신관_세환_역사관앞도착 == 0)
				$신관_세환_역사관앞도착 = 2;

			break;
	}
}

out_history()
{
	if($진행루트 == 0 || $신관_세환_캔커피이벤트 == 0 || $신관_세환_역사관앞대화 == TRUE)
		return;

	switch($EnterObj)
	{
		case "유저":
			if($신관_세환_역사관앞도착 == 1)
				$신관_세환_역사관앞도착 = 0;

			break;
		case "소영":
			if($신관_세환_역사관앞도착 == 2)
				$신관_세환_역사관앞도착 = 0;

			break;
	}
}

front_of_door()
{
	if($진행루트 == 0 || $b_카드키_황 == 0 || $신관_세환_홀진입문앞대화 == TRUE)
		return;

	switch($EnterObj)
	{
		case "유저":
			if($신관_세환_2층문앞도착 == 2)
			{
				$신관_세환_2층문앞도착 = 3;				
				_12b_4();
			}
			else if($신관_세환_2층문앞도착 == 0)
				$신관_세환_2층문앞도착 = 1;
			break;

		case "소영":
			if($신관_세환_2층문앞도착 == 1)
			{
				$신관_세환_2층문앞도착 = 3;				
				_12b_4();
			}
			else if($신관_세환_2층문앞도착 == 0)
				$신관_세환_2층문앞도착 = 2;
			break;
	}	
}

out_of_door()
{
	if($진행루트 == 0 || $b_카드키_황 == 0 || $신관_세환_홀진입문앞대화 == TRUE)
		return;

	if($신관_세환_2층문앞도착 == 1)
		$신관_세환_2층문앞도착 = 0;	
}

