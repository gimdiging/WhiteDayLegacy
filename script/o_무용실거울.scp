Init()
{
	SendMessage("무용실거울", "텍스쳐변경", "[ta");

	if($신관_세환_무용실이벤트 == 2)
	{
		for($j = 1; $j <= 9; $j++)
			SendMessage("무용실거울", "페이드", "Bone0" + $j + " 0 0 0");
			 
		for($j = 0; $j <= 2; $j++)
			SendMessage("무용실거울", "페이드", "Bone1" + $j + " 0 0 0");
				
		DeleteObject("무용실더미");
	}
}

_진동()
{
	if($신관_세환_오디오전원 == ON)
	{
		switch($신관_세환_소리강도)
		{
			case 2:
				SendMessage("무용실거울","애니메이션","약한진동");
				break;
			case 4:
				SendMessage("무용실거울","애니메이션","중간진동");				
				break;
			case 6:
				SendMessage("무용실거울","애니메이션","강한진동");				
				break;
		}		
	}	
}

show_speaker()
{
	SendMessage("카메라", "fov", "-40");	

	switch($신관_세환_스피커번호)
	{
		case 1:
			SendMessage("카메라", "쳐다보기", "" + FindCamera("왼쪽앞스피커"));
			break;
		case 2:
			SendMessage("카메라", "쳐다보기", "" + FindCamera("오른쪽앞스피커"));
			break;
		case 3:
			SendMessage("카메라", "쳐다보기", "" + FindCamera("왼쪽뒤스피커"));
			break;
		case 4:
			SendMessage("카메라", "쳐다보기", "" + FindCamera("오른쪽뒤스피커"));
			break;
	}
			
	SetTimer(2,"show_mirror");
}

ghost_die()
{	
	DeleteObject("무용실더미");
	
	for($i = 1; $i < 10; $i++)
	{		
		$j = $i + 10;
		DeleteObject("러커" + $i);
		DeleteObject("러커" + $j);
	}

	SendMessage("매크로", "Play", "ghost_event.cut01");	
}

show_mirror()
{
	SendMessage("카메라", "fov", "-" + $FOV);
	SendMessage("카메라", "쳐다보기", "" + FindCamera("무용실유리떨림"));

	SetTimer(1, "window_crack");
	
	if($신관_세환_소리강도 == 6)
		SetTimer(4,"ghost_die");
	else
		SetTimer(4, "end_show");
}

window_crack()
{
	switch($신관_세환_소리강도)
	{
		case 4:			
			SendMessage("무용실거울", "텍스쳐변경", "[ta1");
			SendMessage("사운드", "연주", "도플_유리갈.wav");
			break;
		case 6:			
			SendMessage("무용실거울", "텍스쳐변경", "[ta2");
			SendMessage("사운드", "연주", "도플_유리갈.wav");
			break;
	}		
}

end_show()
{
	SendMessage("카메라", "쳐다보지말기", "");
	SendMessage("자막", "와이드모드", "끄기");
	SendMessage("자막", "비활성", "");
	SendMessage("유저", "카메라3인칭뷰", "off");
	$신관_세환_무용실매크로 = OFF;
	$도플갱어공격 = OFF;
	SetTimer(0,"e_도플갱어.attack_pattern *obj 도플갱어");
	if($신관_세환_소리강도 == 2 || $신관_세환_소리강도 == 4)
	SetTimer(0, "random");
	if($신관_세환_소리강도 == 4 && $신관_세환_도플갱어upgrade == 0)
	{
		$신관_세환_장풍공격횟수 = 5;
		RunScript("도플갱어", "e_도플갱어.upgrade");
	}
}

random()
{	
	ChangeObjValue("왼쪽스피커", "setting", OFF);
	ChangeObjValue("오른쪽스피커", "setting", OFF);								
	$신관_세환_스피커위치 = FALSE;	
	switch(Random()%6)
	{
		case 0: 
		{
			SendMessage("왼쪽스피커", "위치", "1855.4 -12.3 1514.6");
			SendMessage("오른쪽스피커", "위치", "1855.4 -12.3 1344.6");
