_깨져라()
{	
	SendMessage("사운드", "연주", "신관_무용실거울깨짐,도플_거울깨지는소리.wav");
	LoadObject("WObjFragments", "", "*area 2135 64 1537 2140 -10 1314 *fragnum 128 *defvec 0 0 0 *defamin 0 0 -100 *defamax -300 50 100 *gennum 64 *gencount 1 *genfreq 4 *lifetime 2 *fadetime 1 *timedelta 1 *genscale 1 *genscaledelta 2 *rotangle -2 -0.5 0 *rotangledelta 0 1 -1 *gravec 0 -500 0 *fr 0.2 *elastic 0.3 *bcol 1 *pet0 p_무용실파편01.pet *pet1 p_무용실파편02.pet *pet2 p_무용실파편03.pet");
	LoadObject("WObjFragments", "", "*area 2135 64 1537 2140 -10 1314 *fragnum 128 *defvec 0 0 0 *defamin 0 0 -100 *defamax -300 50 100 *gennum 64 *gencount 1 *genfreq 4 *lifetime 2 *fadetime 1 *timedelta 1 *genscale 1 *genscaledelta 2 *rotangle -2 -0.5 0 *rotangledelta 0 1 -1 *gravec 0 -500 0 *fr 0.2 *elastic 0.3 *bcol 1 *pet0 p_무용실파편04.pet *pet1 p_무용실파편05.pet *pet2 p_무용실파편06.pet");	

	for($j = 1; $j <= 9; $j++)
		SendMessage("무용실거울", "페이드", "Bone0" + $j + " 0 0 0");
		 
	for($j = 0; $j <= 2; $j++)
		SendMessage("무용실거울", "페이드", "Bone1" + $j + " 0 0 0");	
}

end_event()
{
	$문_무용실 = UNLOCK;		
	$문_무용실1 = UNLOCK;
	$문_무용실폐쇄 = UNLOCK;		
	SetTimer(0,"e_핸드폰메시지._태극패정보");
	$신관_세환_오디오전원 = OFF;
	SetTimer(0.5,"o_무용실스피커.audio_off");
	SendMessage("무용실진짜오디오", "애니메이션", "열림");
	RunScript("정찰용수위", "캐릭터_수위._정지");
	if($게임모드 != 0 && $게임모드 != 4)
	SendMessage("허드", "가스게이지꺼", "");
	$문_신관화장실 = UNLOCK;
	
	SendMessage("유저", "이동속도", "1");	
	SendMessage("오디오LCD", "페이드", "Recursive 0 0 0");
}