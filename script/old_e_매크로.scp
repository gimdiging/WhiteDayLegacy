Event7()
{
	if($old_e_매크로 < 10)
		return;

	DeleteObject("");	// EventArea
	DeleteObject("수위macro");
	DeleteObject("주인공macro");
	SendMessage("유저", "쳐다보지말기", "");
	SendMessage("유저", "위치", "-2010.0 -10.0 -490.0");
	SendMessage("유저", "회전", "270");
	SetTimer(0.1,"old_e_매크로.Event9");
}

Event8()
{
	SendMessage("유저", "이동속도", "0.5");
	SendMessage("수위macro", "애니메이션", "서있기");
}

Event9()
{
	SendMessage("유저", "공격", "");
	SendMessage("유저", "damage", "1");
	$HP -= 1;
}