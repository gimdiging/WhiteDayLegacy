Init()
{
	SendMessage("", "스크립트설정", "talk " + $G_File);
	SendMessage("", "스크립트설정", "dummy null");
	SendMessage("", "픽거리설정", "100 200");		
	SendMessage("", "목각도제한", "-75");
	SendMessage("", "위치", "0 0 0");

	if (GetRegistry("Option\CostumeShow") == "1")
	{
		if (GetRegistry("Option\RemovedCostume") == "1")
		SendMessage("", "ChangeMesh", "100_지현_cos.pet"); 
		else
		SendMessage("", "ChangeMesh", "지현_cos.pet"); 
	}
	else if (GetRegistry("Option\LowPolygon") == "0") 
	    SendMessage("", "ChangeMesh", "지현_high.pet"); 	
}

InitGym()
{
	SendMessage("", "스크립트설정", "talk " + $G_File + ".gym");
	SendMessage("", "스크립트설정", "dummy null");
	SendMessage("", "픽거리설정", "100 200");		
	SendMessage("", "목각도제한", "-75");
	SendMessage("", "위치", "0 0 0");

	if (GetRegistry("Option\CostumeShow") == "1")
	{
		if (GetRegistry("Option\RemovedCostume") == "1")
		SendMessage("", "ChangeMesh", "100_지현_cos.pet"); 
		else
		SendMessage("", "ChangeMesh", "지현_cos.pet"); 
	}
	else if (GetRegistry("Option\LowPolygon") == "0") 
	    SendMessage("", "ChangeMesh", "지현_high.pet"); 	
}

gym.pick()
{
	return "보기";
}

gym.click()
{
	SendMessage("자막", "문자출력후대기", GetString("s181"));
}

pick()
{
	if(GetObjValue("지진") == ON)
	{
		SendMessage("", "캐쉬초기화", "");
		return "";
	}

	if($수위추적모드 == ON)
		return "말하기";

	if($대화단계 == -1 || $현재스테이지 == "강당")
		return "";

	if($대화상태 == ON)
	{
		SendMessage("", "캐쉬초기화", "");
		return "";
	}
	
	return "말하기";
}

click()
{
	if($수위추적모드 == ON)
	{
		SendMessage("자막", "문자출력", "3,......");
		return;
	}

	$대화상태 = ON;
//	SendMessage("", "애니메이션", "서있기");
	SendMessage("자막", "실행함수", "캐릭터_지현." + $대화_지현);
	RunScript("지현", "캐릭터_지현." + $대화_지현);
}

_대화10A()
{
	switch($대화단계)
	{
		case 0:
			SendMessage("자막", "다이얼로그출력", "d10a_043");
			break;
		case 1:
			$대화상태 = OFF;			
			break;
		case 2:
			SendMessage("자막", "다이얼로그출력", "d10a_044");
			break;
		case 3:
			$대화상태 = OFF;		
			break;
		case 4:
			SendMessage("자막", "다이얼로그출력", "d10a_045");
			break;
		case 5:
			$대화상태 = OFF;			
			break;
		case 6:
			SendMessage("자막", "다이얼로그출력", "d10a_046");
			break;
		case 7:
			$대화상태 = OFF;			
			break;
		case 8:
			SendMessage("자막", "다이얼로그출력", "d10a_047");
			break;		
	}

	if($대화단계 == 8)
	{
		$지현_호감도--;
		$대화단계 = -1;
		$대화상태 = OFF;
		SendMessage("", "캐쉬초기화", "");
		SendMessage("자막", "실행함수", "");
		return;
	}

	$대화단계++;
}

